{
  "id": "brokentales",
  "title": "Broken Tales",
  "description": "A dark fairy tale roleplaying game system for Foundry VTT",
  "version": "1.0.0",
  "compatibility": {
    "minimum": "11",
    "verified": "13.350",
    "maximum": "13.350"
  },
  "type": "system",
  "authors": [
    {
      "name": "Broken Tales System Developer",
      "discord": "https://discord.gg/zrmWwTvXSH",
      "url": "https://github.com/brokentales/foundryvtt-brokentales"
    },
    {
      "name": "Atsushiai Hiroshi",
      "discord": "Atsushiai",
      "url": "https://github.com/AtsushiaiHiroshi"
    }
  ],
  "esmodules": [
    "module/brokentales.mjs",
    "module/documents/actor.mjs",
    "module/documents/item.mjs",
    "module/sheets/actor-sheet.mjs",
    "module/sheets/item-sheet.mjs",
    "module/helpers/config.mjs",
    "module/helpers/templates.mjs",
    "module/helpers/settings.mjs"
  ],
  "scripts": [],
  "styles": ["styles/brokentales.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "es",
      "name": "Español",
      "path": "lang/es.json"
    }
  ],
  "packs": [
    {
      "name": "pre-generated-hunters",
      "label": "Pre-Generated Hunters",
      "path": "packs/actors/pre-generated-hunters",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "pre-generated-npcs",
      "label": "Pre-Generated NPCs",
      "path": "packs/actors/pre-generated-npcs",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "adversaries",
      "label": "Adversaries",
      "path": "packs/actors/adversaries",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "broken-ones",
      "label": "Broken Ones",
      "path": "packs/actors/broken-ones",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "creatures",
      "label": "Creatures",
      "path": "packs/actors/creatures",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "villagers",
      "label": "Villagers",
      "path": "packs/actors/villagers",
      "type": "Actor",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "scenario-gifts",
      "label": "Scenario Gifts",
      "path": "packs/actors/scenario-gifts",
      "type": "Item",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "maps-en",
      "label": "Maps (English)",
      "path": "packs/maps/en",
      "type": "Scene",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "maps-es",
      "label": "Mapas (Español)",
      "path": "packs/maps/es",
      "type": "Scene",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "playlists-environment",
      "label": "Playlists - Environment",
      "path": "packs/playlists/environment",
      "type": "Playlist",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "playlists-sound",
      "label": "Playlists - Sound Effects",
      "path": "packs/playlists/sound",
      "type": "Playlist",

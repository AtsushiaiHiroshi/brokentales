      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "scenarios-campaign",
      "label": "Scenarios - Campaign",
      "path": "packs/scenarios/campaign",

      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "scenarios-oneshot",
      "label": "Scenarios - One-Shot",
      "path": "packs/scenarios/one-shot",
      "type": "JournalEntry",
      "system": "brokentales",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "packFolders": [
    {
      "name": "Actors",
      "sorting": "m",
      "packs": ["pre-generated-hunters", "pre-generated-npcs"],
      "folders": [
        {
          "name": "NPCs by Type",
          "sorting": "m",
          "packs": ["adversaries", "broken-ones", "creatures", "villagers"]
        }
      ]
    },
    {
      "name": "Items",
      "sorting": "m",
      "packs": ["scenario-gifts"]
    },
    {
      "name": "Scenes",
      "sorting": "m",
      "packs": ["maps-en", "maps-es"]
    },
    {
      "name": "Audio",
      "sorting": "m",
      "packs": ["playlists-environment", "playlists-sound"]
    },
    {
      "name": "Scenarios",
      "sorting": "m",
      "packs": ["scenarios-campaign", "scenarios-oneshot"]
    }
  ],
  "socket": true,
  "url": "https://github.com/brokentales/foundryvtt-brokentales",
  "manifest": "https://github.com/brokentales/foundryvtt-brokentales/releases/latest/download/system.json",
  "download": "https://github.com/brokentales/foundryvtt-brokentales/archive/refs/heads/main.zip",
  "background": "styles/background/broken_tales_sheet.webp",
  "initiative": "1d6 + @attributes.soma.value",
  "gridDistance": 1,
  "gridUnits": "m",
  "primaryTokenAttribute": "attributes.soma",
  "secondaryTokenAttribute": "attributes.wounds"
}

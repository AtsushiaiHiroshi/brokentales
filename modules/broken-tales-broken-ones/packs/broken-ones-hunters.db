ifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"Pv39DxLXLl31DgCx","name":"A braid of hair which belonged to the one I loved","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"equipment6.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"equipment","sequence":6}},"system":{"description":"A braid of hair which belonged to the one I loved","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","quantity":1,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"equipment6.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"Ooo66xVqY5WEakmo","name":"A letter from a comrade fallen in battle","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"equipment7.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"equipment","sequence":7}},"system":{"description":"A letter from a comrade fallen in battle","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","quantity":1,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"equipment7.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModified
lt":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241646,"modifiedTime":1783973241646,"lastModifiedBy":null,"exportSource":null}},{"_id":"8kam2uGUM17FSj8E","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Wound. Carlo the LivingPuppet","source":"The Broken Ones","category":"hunter","contentKey":"source.wound-carlo-the-livingpuppet","ownerKey":"cazador.wound-carlo-the-livingpuppet","role":"source","sequence":0}},"system":{"description":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 8.</p>","notes":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 8","owner":"Wound. Carlo the LivingPuppet","source":"The Broken Ones","category":"hunter","key":"source.wound-carlo-the-livingpuppet"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241646,"modifiedTime":1783973241646,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"the-broken-ones-wound-carlo-the-livingpuppet","pregenCollection":"The Broken Ones","source":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf","pages":"8"}},"system":{"details":{"concept":"The Broken Ones","origin":"Wound. Carlo the LivingPuppet","role":"Hunter of the Order","notes":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 8.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241646,"modifiedTime":1783973241646,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rxP5XU141HYY9ueC","name":"Alice of Other Worlds","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/the-broken-ones-alice-of-other-worlds.png","items":[{"_id":"S3XzyxCk1Dqj2uXP","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-principal.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"principal-descriptor","sequence":0}},"system":{"description":"I am a young doctor who has dedicated her whole life to the treatment of mental illnesses. I understand \nthem, for I am suffering from one as well, and only those who burned themselves while playing with \nfire can understand its dangers. After a dark period during which I managed a sanatorium, the Order \nstripped me of all academic honors and degrees, reducing me to the status of a criminal. But it didn’t \ntake long for them to understand the extent of my studies and the magnitude of my abilities. After \npossessing the Pope himself, I struck a deal with the Order. They will allow me to continue my studies, \nbut I may only study the creatures they fight. And perhaps, through the distorted minds of the Broken \nTales, I can prove that the worlds I visited as a child are real and not the ramblings of a mad mind.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","positive":"I am a young doctor who has dedicated her whole life to the treatment of mental illnesses. I understand them, for I am suffering from one as well, and only those who burned themselves while playing with fire can understand its dangers. After a dark period during which I managed a sanatorium, the Order stripped me of all academic honors and degrees, reducing me to the status of a criminal. But it didn’t take long for them to understand the extent of my studies and the magnitude of my abilities. After possessing the Pope himself, I struck a deal with the Order. They will allow me to continue my studies, but I may only study the creatures they fight. And perhaps, through the distorted minds of the Broken Tales, I can prove that the worlds I visited as a child are real and not the ramblings of a mad mind.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"descriptor-principal.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZGBQmWIBTK35UsSf","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"descriptor1-don1.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"gift-descriptor","sequence":1}},"system":{"description":"I am a skilled physician and psychiatrist, and \ndiagnosing illnesses is simple. My work has made me \nparticularly cold and detached.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","positive":"I am a skilled physician and psychiatrist, and diagnosing illnesses is simple. My work has made me particularly cold and detached.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"descriptor1-don1.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"oB5HqqvUvbJWQLsh","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"descriptor2-don2.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"gift-descriptor","sequence":2}},"system":{"description":"Cheshire, my faithful trained lynx, is the most \ntrustworthy of companions – a shadow keeping \nme safe from threats. Cheshire’s attachment is an \nobsession and she may even threaten those who don’t \nwant to hurt me.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","positive":"Cheshire, my faithful trained lynx, is the most trustworthy of companions – a shadow keeping me safe from threats. Cheshire’s attachment is an obsession and she may even threaten those who don’t want to hurt me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"descriptor2-don2.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"m3pJimakfmvWOMxb","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-darkego.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"Alice of\nOther Worlds\nAs a child I traveled to other worlds and my mind can perceive and see \nthings beyond common perception. Memories of my childhood haunt me, \nand I often get lost in visions of the past.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","positive":"Alice of Other Worlds As a child I traveled to other worlds and my mind can perceive and see things beyond common perception. Memories of my childhood haunt me, and I often get lost in visions of the past.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"descriptor-darkego.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"FZe4yw7cmoEqwr0U","name":"Physician","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"don1.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"gift","sequence":1}},"system":{"description":"Once per Scenario, when you take the \ntime to treat an injury, you may heal 1 Wound suffered \nby one of your patients, also bringing them back from \napparent death or unconsciousness. Y ou may spend 1 \nSoma to reassure and calm someone who is frightened or \nexperiencing any negative feeling. If you do, you receive \n1 Additional Success to any Check involving interactions \nwith that patient for the remaining of the Scenario.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"don1.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"6GWPdYyWedOX1p2K","name":"Cheshire the Lynx","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"don2.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"gift","sequence":2}},"system":{"description":"Cheshire is an NPC fully \nunder your control, with the following profile:\nOL Medium 5 – (2 Wounds) \nDescriptor: I am a big, short-tempered wild lynx and I only \nlive to serve Alice.\nGift - Two Souls: Y ou share your soul with Cheshire, and \nyou can see and feel through her senses. Y ou can spend \n1 Soma to make Cheshire immaterial for an action and \nallow her to cross any obstacle.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"don2.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"pbuTXswDODdOVXhx","name":"Dark Ego - Alice of Other Worlds","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"darkego.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"dark-ego","sequence":0}},"system":{"description":"As an action, you may spend \n1 Soma to try to possess the body of a person or animal that is looking into \nyour eyes. Particularly powerful individuals may require a Position Check for \nyou to succeed. Y ou can act through the body you possess and continue to use \nyour Gifts and Descriptors, but you receive an additional Descriptor created \nby the Storyteller and representing the abilities of the body you are possessing. \nThe possession ends at the end of the Scene, when the possessed body suffers 1 \nWound, or you decide to return to your body of your own volition. While you \ncontrol someone else’s body, your original body is inert and at the mercy of the \nworld. Y ou cannot possess Broken Tales or supernatural creatures. Y our mind is \nnot easy to control, so you gain 1 Additional Success for Defense Checks against \nany kind of mind control and magic.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"trigger":"You notice a detail that does not match what you consider normal.\nXP\nSoma\n 5","owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"darkego.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"IoAUtmr9D7VyUxPm","name":"A valuable doctor’s coat","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment1.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":1}},"system":{"description":"A valuable doctor’s coat","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment1.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"Xh3YwHaZIzarVDUl","name":"Books about the human psyche","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment2.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":2}},"system":{"description":"Books about the human psyche","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment2.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"DBJyV6EPrkIhsSYK","name":"A watch, a gift from someone I met on my travels","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment3.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":3}},"system":{"description":"A watch, a gift from someone I met on my travels","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment3.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"cJjvpMaLDVMhDjeH","name":"A lucky rabbit’s foot","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment4.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":4}},"system":{"description":"A lucky rabbit’s foot","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment4.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"PfWciYal9n5EpIRW","name":"A set of sharp scalpels","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment5.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":5}},"system":{"description":"A set of sharp scalpels","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment5.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"4wPBfwWt2uNdUYt0","name":"A doctor’s bag","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment6.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":6}},"system":{"description":"A doctor’s bag","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment6.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"v7eqX0bjZ9kvL11S","name":"A deck of cards which is missing the queen of hearts","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"equipment7.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"equipment","sequence":7}},"system":{"description":"A deck of cards which is missing the queen of hearts","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.","quantity":1,"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"equipment7.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"FnQTFkY1pRfYU6Cb","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","contentKey":"source.alice-of-other-worlds","ownerKey":"cazador.alice-of-other-worlds","role":"source","sequence":0}},"system":{"description":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2.</p>","notes":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 2","owner":"Alice of Other Worlds","source":"The Broken Ones","category":"hunter","key":"source.alice-of-other-worlds"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"the-broken-ones-alice-of-other-worlds","pregenCollection":"The Broken Ones","source":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf","pages":"2"}},"system":{"details":{"concept":"The Broken Ones","origin":"Alice of Other Worlds","role":"Hunter of the Order","notes":"I am a young doctor who has dedicated her whole life to the treatment of mental illnesses. I understand \nthem, for I am suffering from one as well, and only those who burned themselves while playing with \nfire can understand its dangers. After a dark period during which I managed a sanatorium, the Order \nstripped me of all academic honors and degrees, reducing me to the status of a criminal. But it didn’t \ntake long for them to understand the extent of my studies and the magnitude of my abilities. After \npossessing the Pope himself, I struck a deal with the Order. They will allow me to continue my studies, \nbut I may only study the creatures they fight. And perhaps, through the distorted minds of the Broken \nTales, I can prove that the worlds I visited as a child are real and not the ramblings of a mad mind."},"resources":{"soma":{"value":5,"max":5},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}}
{"_id":"twi7RLRgqCKhLgnZ","name":"Beauty and her Beast","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/the-broken-ones-beauty-and-her-beast.png","items":[{"_id":"ggxsrqLgAKO6rjjR","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-principal.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"principal-descriptor","sequence":0}},"system":{"description":"I am Bellina Cantalupo, but everyone calls me Bella. I was once a servant to the bride of the monstrous Dionysus \nGonsalva. I played my cards well, charmed the nobleman, and rose to power. Unfortunately, the Order got in the \nway and sabotaged everything I had built. As a punishment, I was magically bound to Dionysus and now our \nsouls are intertwined. I feel his pain and his beastly instincts. Dionysus perceives, in turn, my disgust for him, \nbut it doesn’t affect the mad love he feels for me. I serve the Order in the hope of gaining its grace and being \nreleased from this punishment. But, deep down in my heart, I still long for the power that I was denied being born \na peasant, but that I know I deserve.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","positive":"I am Bellina Cantalupo, but everyone calls me Bella. I was once a servant to the bride of the monstrous Dionysus Gonsalva. I played my cards well, charmed the nobleman, and rose to power. Unfortunately, the Order got in the way and sabotaged everything I had built. As a punishment, I was magically bound to Dionysus and now our souls are intertwined. I feel his pain and his beastly instincts. Dionysus perceives, in turn, my disgust for him, but it doesn’t affect the mad love he feels for me. I serve the Order in the hope of gaining its grace and being released from this punishment. But, deep down in my heart, I still long for the power that I was denied being born a peasant, but that I know I deserve.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"descriptor-principal.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"Ar0qp36Pd5KJgaRE","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"descriptor1-don1.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"gift-descriptor","sequence":1}},"system":{"description":"Dionysus follows me and protects me like a faithful beast, \nand responds to all my commands. As useful as this is, I feel \ndisgusted every time he comes near me.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","positive":"Dionysus follows me and protects me like a faithful beast, and responds to all my commands. As useful as this is, I feel disgusted every time he comes near me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"descriptor1-don1.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"RJMoaw0GKfkexbZT","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"descriptor2-don2.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"gift-descriptor","sequence":2}},"system":{"description":"I am charismatic and affable. My innate air of superiority \nfascinates simple people. I love having all my eyes on me.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","positive":"I am charismatic and affable. My innate air of superiority fascinates simple people. I love having all my eyes on me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"descriptor2-don2.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"pH46Mx1IySiVMzv8","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-darkego.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"I am linked to Dionysus and we share pain and perceptions. He will \nalways know where I am and vice versa. For me, that’s the most \nhumiliating part of the curse.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","positive":"I am linked to Dionysus and we share pain and perceptions. He will always know where I am and vice versa. For me, that’s the most humiliating part of the curse.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"descriptor-darkego.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"ixp1GR9k5NIfO7Bd","name":"The Beast","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"don1.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"gift","sequence":1}},"system":{"description":"Dionysus is an NPC fully under your control, \nwith the following profile:\nOL Medium 5 – (Wounds: as Bella’s current value) \nDescriptor: I am a powerful and feral beastman. Only Bella’s scent \nkeeps me under control.\nGift - Monstrous: If he intends to kill someone, Dionysus may \nact twice in each Exchange. Once per Scene, Dionysus can break \nor lift even a large object with extreme ease. \nDuring Scenes, you decide how Dionysus acts. Any Wound one \nof you suffers also applies to the other. When Dionysus is within \na few steps, you receive 1 Penalty to each Check due to the strong \ndisgust you feel for him.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"don1.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"dEKP4Pt4TPTUURQx","name":"The Beauty","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"don2.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"gift","sequence":2}},"system":{"description":"Once per Scene, when you meet a new subject, \nyou may spend 1 Soma and declare that you have met them in the \npast and that you made some kind of deal with them. Create, in \nagreement with the Storyteller, an Agenda for them representing \nthe deal. If you take the time to talk to someone, the Storyteller \nmust reveal a clue about their current Agenda or a drawback of \none of their Descriptors. When someone shows a strong interest \nin you, Dionysus, if present, loses the use of the Monstrous Gift \nbecause of the strong jealousy and shame he feels for himself.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"don2.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"fxdo949lsr9WhhzJ","name":"Dark Ego - Beasts in Body and Soul","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"darkego.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"dark-ego","sequence":0}},"system":{"description":"When you reveal your \ntrue nature everyone is horrified. One is a beast in body, while the other \nis a beast in her soul. Y ou receive 3 Savagery Tokens that you can spend \nduring the Scene to: \n1. Inflict 1 additional Wound, if Dionysus spends an action to help you in \nthe attack. The Wound will be a strikingly bloody gash.\n2. Have a minor NPC lose their action as they are intimidated, having \nwitnessed the fury of Dionysus.\n3. If Dionysus is not present in the Scene, he can appear immediately \n(possibly tearing a new opening in the environment, demolishing any \npossible obstacle) to support you. \n4. Perform a second action in the Exchange, if Dionysus spends one of his \nto open the way for you.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"trigger":"Unleash the feral power of Dionysus, or humiliate or betray \nsomeone, revealing your true nature.","owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"darkego.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"Lkj7KiyLZlDsDvMs","name":"A leather whip and metal needles","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment1.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":1}},"system":{"description":"A leather whip and metal needles","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment1.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"1GdTTKl9fdpk1aPX","name":"A noble dress","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment2.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":2}},"system":{"description":"A noble dress","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment2.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"8q7qXsDXuh8V6wM3","name":"Fine dresses and jewelry","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment3.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":3}},"system":{"description":"Fine dresses and jewelry","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment3.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"y8puTKX2yqz6SxL6","name":"A rose that never fades","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment4.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":4}},"system":{"description":"A rose that never fades","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment4.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"TC0QO2nhmSK8uDbm","name":"A bag with dried meat with which to keep Dionysus’ hunger at bay","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment5.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":5}},"system":{"description":"A bag with dried meat with which to keep Dionysus’ hunger at bay","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment5.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"jgdQvZ0YktCI0BJi","name":"Soaps and feminine perfumes","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment6.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":6}},"system":{"description":"Soaps and feminine perfumes","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment6.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"KCMLe0YHCrvaS03W","name":"A poisoned stiletto that I keep hidden for any eventuality","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"equipment7.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"equipment","sequence":7}},"system":{"description":"A poisoned stiletto that I keep hidden for any eventuality","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.","quantity":1,"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"equipment7.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}},{"_id":"LwAMPpLwulbQr1Fu","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","contentKey":"source.beauty-and-her-beast","ownerKey":"cazador.beauty-and-her-beast","role":"source","sequence":0}},"system":{"description":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4.</p>","notes":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 4","owner":"Beauty and her Beast","source":"The Broken Ones","category":"hunter","key":"source.beauty-and-her-beast"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241645,"modifiedTime":1783973241645,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"the-broken-ones-beauty-and-her-beast","pregenCollection":"The Broken Ones","source":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf","pages":"4"}},"system":{"details":{"concept":"The Broken Ones","origin":"Beauty and her Beast","role":"Hunter of the Order","notes":"I am Bellina Cantalupo, but everyone calls me Bella. I was once a servant to the bride of the monstrous Dionysus \nGonsalva. I played my cards well, charmed the nobleman, and rose to power. Unfortunately, the Order got in the \nway and sabotaged everything I had built. As a punishment, I was magically bound to Dionysus and now our \nsouls are intertwined. I feel his pain and his beastly instincts. Dionysus perceives, in turn, my disgust for him, \nbut it doesn’t affect the mad love he feels for me. I serve the Order in the hope of gaining its grace and being \nreleased from this punishment. But, deep down in my heart, I still long for the power that I was denied being born \na peasant, but that I know I deserve."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241646,"modifiedTime":1783973241646,"lastModifiedBy":null,"exportSource":null}}
{"_id":"xnX4tRKmyO5dpX9y","name":"The Knight with a Hundred Heads","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/the-broken-ones-the-knight-with-a-hundred-heads.png","items":[{"_id":"xHdG7v74IcYm3S4b","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-principal.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"principal-descriptor","sequence":0}},"system":{"description":"I am a swordsman and a Hussar knight with finely honed \ncombat skills. Ordog is more than a common horse and he \noften saved me with his magic. Sometimes I wonder who the \nreal Hunter of the Order is.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","positive":"I am a swordsman and a Hussar knight with finely honed combat skills. Ordog is more than a common horse and he often saved me with his magic. Sometimes I wonder who the real Hunter of the Order is.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"descriptor-principal.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"DEloYWu0jr4Ac7Dr","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"descriptor1-don1.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"gift-descriptor","sequence":1}},"system":{"description":"I am a tenacious defender and in my previous life, I always \nstood my ground, never retreating. The memory of my loved \nones makes me melancholic and I cannot forgive those who \nhurt families.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","positive":"I am a tenacious defender and in my previous life, I always stood my ground, never retreating. The memory of my loved ones makes me melancholic and I cannot forgive those who hurt families.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"descriptor1-don1.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"vdBIvoFvOyi5Ca4O","name":"Ordog the Trusty Horse","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"don1.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"gift","sequence":1}},"system":{"description":"Ordog is a strange horseshaped entity. He can speak and is uncannily smart, but he is very \nsarcastic and capricious. Ordog will always know how to find you \nand will overcome all obstacles to reach you. When you ask for his \nhelp, Ordog will manifest his magical power and the Storyteller \nwill create a Descriptor that will allow him to do incredible things, \nsuch as fly or pass through the walls. The Storyteller has full \ncontrol of Ordog’s will and whims, so expect to have to promise \nhim something or convince him of your reasons.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"don1.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"TyAnyz31r1GLvqJk","name":"The Bridge","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"don2.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"gift","sequence":2}},"system":{"description":"When you protect a place or honor an oath \nyou have taken, nothing can overwhelm you. Once per Scene, you \nmay declare an oath in which you swear to defend something and \ngain 3 Oath Tokens. As long as you act to fulfill your oath, you can \nspend 1 Token to:\n1. Resist being separated from what you are defending.\n2. Gain 1 Additional Success for a Defense Check.\n3. Inflict 1 additional Wound to an enemy, but only if this allows \nyou to eliminate them. If you do, you must decapitate them. \nIf you break your oath, the magic that animates you weakens and \nthe Storyteller gains 1 Sleep Token that they can spend at any time \nto have you automatically fail a Check.\nThe Knight with \na Hundred\nHeads","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"don2.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"Wggrnkx27H9iNaPE","name":"Dark Ego - The Headless Knight","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"darkego.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"dark-ego","sequence":0}},"system":{"description":"Y ou are an immortal \nvengeful spirit. When you suffer your last Wound, you dissolve into \nthin air to return at the beginning of the next Scene having recovered 2","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"trigger":"","owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"darkego.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"gaTCYfF83gWdv32A","name":"A worn and colorful military uniform","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"equipment1.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"equipment","sequence":1}},"system":{"description":"A worn and colorful military uniform","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","quantity":1,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"equipment1.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"XOVMgsjOo9sHDUl0","name":"My trusty dueling saber","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"equipment2.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"equipment","sequence":2}},"system":{"description":"My trusty dueling saber","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","quantity":1,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"equipment2.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"qEbXLInnBZRQR2Pa","name":"A pair of finely made guns","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","contentKey":"equipment3.the-knight-with-a-hundred-heads","ownerKey":"cazador.the-knight-with-a-hundred-heads","role":"equipment","sequence":3}},"system":{"description":"A pair of finely made guns","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 12.","quantity":1,"owner":"The Knight with a Hundred Heads","source":"The Broken Ones","category":"hunter","key":"equipment3.the-knight-with-a-hundred-heads"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSo
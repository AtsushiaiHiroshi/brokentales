,"img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","contentKey":"equipment7.the-gang-of-three-pigs","ownerKey":"cazador.the-gang-of-three-pigs","role":"equipment","sequence":7}},"system":{"description":"Miners’ lanterns","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16.","quantity":1,"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","key":"equipment7.the-gang-of-three-pigs"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}},{"_id":"1w7LefsTOmemiALV","name":"Heavy leather work coats","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","contentKey":"equipment8.the-gang-of-three-pigs","ownerKey":"cazador.the-gang-of-three-pigs","role":"equipment","sequence":8}},"system":{"description":"Heavy leather work coats","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16.","quantity":1,"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","key":"equipment8.the-gang-of-three-pigs"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}},{"_id":"UxXS4OM6ZKMFeoFg","name":"A reinforced case containing the flesh of the God Under the Mine","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","contentKey":"equipment9.the-gang-of-three-pigs","ownerKey":"cazador.the-gang-of-three-pigs","role":"equipment","sequence":9}},"system":{"description":"A reinforced case containing the flesh of the God Under the Mine","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16.","quantity":1,"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","key":"equipment9.the-gang-of-three-pigs"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}},{"_id":"7Z2TpSKkXraPEOQw","name":"Three keys","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","contentKey":"equipment10.the-gang-of-three-pigs","ownerKey":"cazador.the-gang-of-three-pigs","role":"equipment","sequence":10}},"system":{"description":"Three keys","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16.","quantity":1,"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","key":"equipment10.the-gang-of-three-pigs"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}},{"_id":"pkrHkYwwcPOptGRy","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","contentKey":"source.the-gang-of-three-pigs","ownerKey":"cazador.the-gang-of-three-pigs","role":"source","sequence":0}},"system":{"description":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16.</p>","notes":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 16","owner":"The Gang of three Pigs","source":"The Broken Ones","category":"hunter","key":"source.the-gang-of-three-pigs"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"the-broken-ones-the-gang-of-three-pigs","pregenCollection":"The Broken Ones","source":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf","pages":"16"}},"system":{"details":{"concept":"The Broken Ones","origin":"The Gang of three Pigs","role":"Hunter of the Order","notes":"We are three brothers who renounced their names to become emissaries of the God Under the Mine. We \nwere a group of anarchists and rebels, but the Order captured us, forcing us to become Hunters. We carry with \nus the last piece of the God Under the Mine, an ancient and powerful creature. We keep the remains of the God a \nsecret so that the Order won’t get their grubby hands on it. By feeding on it, our bodies can regenerate and even \nreturn from death, effectively making our gang immortal."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241648,"modifiedTime":1783973241648,"lastModifiedBy":null,"exportSource":null}}
{"_id":"M9YZNVHZzJ7NAmbo","name":"Yvonne of the Dark","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/the-broken-ones-yvonne-of-the-dark.png","items":[{"_id":"KxdpWVJSRNIR410X","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"descriptor-principal.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"principal-descriptor","sequence":0}},"system":{"description":"I died with my beloved candles in my hand and \nwas reborn with the power to control fire. I hate \nstaying in the darkness and I always want at least \na small source of light.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","positive":"I died with my beloved candles in my hand and was reborn with the power to control fire. I hate staying in the darkness and I always want at least a small source of light.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"descriptor-principal.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"sD7e1baguX895RkY","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"descriptor1-don1.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"gift-descriptor","sequence":1}},"system":{"description":"I have no choice but to remain in my childish \nbody for eternity. I have a sweet smile and \npeople often feel protective towards me. Animals \nperceive me for who I really am and they act up \nin my presence.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","positive":"I have no choice but to remain in my childish body for eternity. I have a sweet smile and people often feel protective towards me. Animals perceive me for who I really am and they act up in my presence.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"descriptor1-don1.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"THbScmOrdMv8RZBN","name":"Light the Flame","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"don1.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"gift","sequence":1}},"system":{"description":"Y ou can manipulate fire, as \nlong as there is already a flame in the environment. \nDecide whether to increase or decrease its size or \nintensity, as well as the direction it burns. Y ou can \nalso manipulate the flame to hit something within \nnine feet of it. Y ou gain 1 Additional Success to each \naction you take while manipulating fire. The first time \nyou use this Gift in a Scene, the Storyteller may decide \nthat your action will spread the flames in some way.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","somaCost":0,"automaticSuccesses":0,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"don1.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"0rABW0VedKU8zMBv","name":"Innocent Smile","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"don2.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"gift","sequence":2}},"system":{"description":"When you talk to someone, \nyou can spend 1 Soma to provoke their sympathy (the \nStoryteller will evaluate whether or not the subject is \nsensitive to your influence) to create an Agenda in \nwhich the target feels somehow responsible for you. \nDuring a Scene, if the location is crowded, you can \nact or move without anyone noticing.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","somaCost":0,"automaticSuccesses":0,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"don2.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"v8NdPwxOWEf8Dn3g","name":"Dark Ego – Solitary Ghost","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"darkego.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"dark-ego","sequence":0}},"system":{"description":"When you decide to take on your ghostly \nform, you receive 1 Solitude Token and become intangible. Y ou cannot have any kind \nof physical interaction with the world (not even talking) and no one can touch you, \nexcept through magic. However, you do not become invisible to the human eye and so \nthose who see you will understand that you are a ghost. In the form of a specter, your \naffinity to fire is more intense and you gain 1 Additional Success in any action involving \nthe flames you are manipulating. In addition, you can spend 1 Soma to ignite a flame \nfrom thin air and set something on fire. The effect of this Gift lasts until you decide to \nstop it, but the Storyteller can spend 1 Solitude Token to force you to remain ethereal \nfor a few more minutes. When you take an Interlude or spend time with someone who cares about you, remove all Solitude Tokens. When you use this Gift without satisfying \nthe Activator, you can ignore the Wound and take 1 Solitude Token instead.","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","somaCost":0,"automaticSuccesses":0,"trigger":"React angrily when the world ignores you or makes it clear to you that no one cares about you.","owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"darkego.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"55XppiujrtVVlCqf","name":"A worn-out cape","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"equipment1.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"equipment","sequence":1}},"system":{"description":"A worn-out cape","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","quantity":1,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"equipment1.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"Nrfwes4e5Wz1inUI","name":"A bag full of candles","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"equipment2.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"equipment","sequence":2}},"system":{"description":"A bag full of candles","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","quantity":1,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"equipment2.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"syGwae9oXW2gy1Nw","name":"A tinderbox and dry sticks","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","contentKey":"equipment3.yvonne-of-the-dark","ownerKey":"cazador.yvonne-of-the-dark","role":"equipment","sequence":3}},"system":{"description":"A tinderbox and dry sticks","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 26.","quantity":1,"owner":"Yvonne of the Dark","source":"The Broken Ones","category":"hunter","key":"equipment3.yvonne-of-the-dark"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"la
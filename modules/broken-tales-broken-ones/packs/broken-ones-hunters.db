tifunction bullets","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 10.","quantity":1,"owner":"Hatta Carter","source":"The Broken Ones","category":"hunter","key":"equipment6.hatta-carter"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"cXXyOrdSMmhIwYhR","name":"A fancy tea set","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Hatta Carter","source":"The Broken Ones","category":"hunter","contentKey":"equipment7.hatta-carter","ownerKey":"cazador.hatta-carter","role":"equipment","sequence":7}},"system":{"description":"A fancy tea set","notes":"See bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 10.","quantity":1,"owner":"Hatta Carter","source":"The Broken Ones","category":"hunter","key":"equipment7.hatta-carter"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241647,"modifiedTime":1783973241647,"lastModifiedBy":null,"exportSource":null}},{"_id":"uIADSqRsKFz1b9XZ","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Hatta Carter","source":"The Broken Ones","category":"hunter","contentKey":"source.hatta-carter","ownerKey":"cazador.hatta-carter","role":"source","sequence":0}},"system":{"description":"<p><strong>The Broken Ones</strong></p><p>bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 10.</p>","notes":"bt-tbo-sheets-eng-final-screen [2022-06-14].pdf, pages 10","owner":"Hatta Carter","source":"The Broken Ones","category":"hunter","key":"source.hatta-carter"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicate
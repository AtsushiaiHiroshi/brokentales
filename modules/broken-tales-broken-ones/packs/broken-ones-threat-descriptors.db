{"_id":"BeataCzerninTheN","name":"Beáta Czernin the Noblewoman - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01r1c65w01bhb11h","flags":{"broken-tales":{"owner":"Beáta Czernin the Noblewoman","sourcePack":"broken-ones-actors","source":"The Broken Ones, I Will Stay with You Always","category":"threat"}},"system":{"description":"<p>I am part of the city’s elite and I take advantage \nof it. Sometimes, my vanity and arrogance unexpectedly \ncause annoyances.</p>","notes":"I Will Stay with You Always - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 166.","positive":"I am part of the city’s elite and I take advantage \nof it. Sometimes, my vanity and arrogance unexpectedly \ncause annoyances.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Beáta Czernin the Noblewoman","category":"threat","source":"The Broken Ones, I Will Stay with You Always"},"sort":4600000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557637466,"modifiedTime":1781557637466,"lastModifiedBy":null,"exportSource":null}}

{"_id":"TheQuietGuards48","name":"The Quiet Guards - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01pnc8bv008tpffo","flags":{"broken-tales":{"owner":"The Quiet Guards","sourcePack":"broken-ones-actors","source":"The Broken Ones, Stegeborg's Quiet","category":"threat"}},"system":{"description":"<p>We are the poor inhabitants of the village, fused \nwith some of the castle’s furnishings. Our transformations \nhave driven us to madness and we blindly obey the will of \nTalia.</p>","notes":"Stegeborg's Quiet - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 138.","positive":"We are the poor inhabitants of the village, fused \nwith some of the castle’s furnishings. Our transformations \nhave driven us to madness and we blindly obey the will of \nTalia.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Quiet Guards","category":"threat","source":"The Broken Ones, Stegeborg's Quiet"},"sort":4900000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557636197,"modifiedTime":1781557636197,"lastModifiedBy":null,"exportSource":null}}

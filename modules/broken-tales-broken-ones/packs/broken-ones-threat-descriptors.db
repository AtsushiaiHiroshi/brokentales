{"_id":"Hanse00xxxxxxxxx","name":"Hanse - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Hanse","sourcePack":"broken-ones-actors"}},"system":{"description":"<p>I am the incarnation of the power of the great Maw. My body \nregenerates thanks to the flesh I eat. My strength and my speed are unbelievable.</p>","notes":"Hunger Island - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 101.","positive":"I am the incarnation of the power of the great Maw. My body \nregenerates thanks to the flesh I eat. My strength and my speed are unbelievable.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Hanse","category":"threat","source":"The Broken Ones"},"sort":100000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557626419,"modifiedTime":1781557626419,"lastModifiedBy":null,"exportSource":null}}

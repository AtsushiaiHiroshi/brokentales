{"_id":"AkimTheTamer19xx","name":"Akim the Tamer - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Akim the Tamer","sourcePack":"broken-ones-actors"}},"system":{"description":"<p>I am a brave and skilled \ntamer. The tiger Tasha and the bear \nBerto are both dear to me, as they obey \nmy every command.</p>","notes":"In Your Eyes, with Your Feet - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 158.","positive":"I am a brave and skilled \ntamer. The tiger Tasha and the bear \nBerto are both dear to me, as they obey \nmy every command.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Akim the Tamer","category":"threat","source":"The Broken Ones"},"sort":2000000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557637149,"modifiedTime":1781557637149,"lastModifiedBy":null,"exportSource":null}}

{"_id":"EduardoAndFelipe","name":"Eduardo and Felipe - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"006w94xs00kfsqyr","flags":{"broken-tales":{"owner":"Eduardo and Felipe","sourcePack":"broken-ones-actors","source":"The Broken Ones, In Your Eyes, with Your Feet, In Your Eyes, with Your Feet","category":"threat"}},"system":{"description":"<p>We are two guards who are content to leave \nthinking to other people. We do as we’re told while doing as \nlittle as possible. \nThe Di Bello Family \nHouse\nDescriptor: A large, abandoned villa in the bourgeois \ndistricts of Vigo.</p>","notes":"In Your Eyes, with Your Feet - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 156.","positive":"We are two guards who are content to leave \nthinking to other people. We do as we’re told while doing as \nlittle as possible. \nThe Di Bello Family \nHouse\nDescriptor: A large, abandoned villa in the bourgeois \ndistricts of Vigo.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Eduardo and Felipe","category":"threat","source":"The Broken Ones, In Your Eyes, with Your Feet, In Your Eyes, with Your Feet"},"sort":3100000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557637071,"modifiedTime":1781557637071,"lastModifiedBy":null,"exportSource":null}}

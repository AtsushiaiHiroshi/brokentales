{"_id":"TheMaws27xxxxxxx","name":"The Maws - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Maws","sourcePack":"broken-ones-actors"}},"system":{"description":"<p>We are a new people, children of the great \nMaw. Our bodies regenerate thanks to the flesh we eat. Our \nstrength and speed are incredible.</p>","notes":"Hunger Island - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 97.","positive":"We are a new people, children of the great \nMaw. Our bodies regenerate thanks to the flesh we eat. Our \nstrength and speed are incredible.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Maws","category":"threat","source":"The Broken Ones"},"sort":2800000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557626309,"modifiedTime":1781557626309,"lastModifiedBy":null,"exportSource":null}}

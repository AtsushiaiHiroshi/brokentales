{"_id":"BerendTheCrazedC","name":"Berend the Crazed Captain - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01m3ysoh000i34hy","flags":{"broken-tales":{"owner":"Berend the Crazed Captain","sourcePack":"broken-ones-actors","source":"The Broken Ones, Hunger Island","category":"threat"}},"system":{"description":"<p>I am the captain of the previous expedition \nand the only one left of my crew. I learned to survive by \nmasking my smell with the stench of rotten fish.</p>","notes":"Hunger Island - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 98.","positive":"I am the captain of the previous expedition \nand the only one left of my crew. I learned to survive by \nmasking my smell with the stench of rotten fish.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Berend the Crazed Captain","category":"threat","source":"The Broken Ones, Hunger Island"},"sort":5000000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557626341,"modifiedTime":1781557626341,"lastModifiedBy":null,"exportSource":null}}

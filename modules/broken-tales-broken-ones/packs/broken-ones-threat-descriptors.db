{"_id":"Pietrik34xxxxxxx","name":"Pietrik - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik","sourcePack":"broken-ones-actors"}},"system":{"description":"<p>I am a young rebel and I fight the creeping industrialization of London with \nall my strength.</p>","notes":"I Don't Believe - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 87.","positive":"I am a young rebel and I fight the creeping industrialization of London with \nall my strength.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pietrik","category":"threat","source":"The Broken Ones"},"sort":3500000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557625744,"modifiedTime":1781557625744,"lastModifiedBy":null,"exportSource":null}}
{"_id":"MtyryaTheFairyAl","name":"Mtyrya the Fairy also called the Cauldron Fae - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Mtyrya the Fairy also called the Cauldron Fae","sourcePack":"broken-ones-actors"}},"system":{"description":"<p>I am an ancient fairy bound to nature. I hate humans and modernity. Thanks \nto my power, anything others believe to be impossible, I can make possible.</p>","notes":"I Don't Believe - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 85.","positive":"I am an ancient fairy bound to nature. I hate humans and modernity. Thanks \nto my power, anything others believe to be impossible, I can make possible.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Mtyrya the Fairy also called the Cauldron Fae","category":"threat","source":"The Broken Ones"},"sort":3600000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557625700,"modifiedTime":1781557625700,"lastModifiedBy":null,"exportSource":null}}

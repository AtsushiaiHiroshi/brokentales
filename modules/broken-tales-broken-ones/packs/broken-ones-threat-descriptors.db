{"_id":"Gwendolyn44xxxxx","name":"Gwendolyn - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01ev3uxj01fj0k10","flags":{"broken-tales":{"owner":"Gwendolyn","sourcePack":"broken-ones-actors","source":"The Broken Ones, I Don't Believe","category":"threat"}},"system":{"description":"<p>I am the young heir of \nthe Carnarvon family, but I dream \nof a life of travel and freedom, \nexploring the world. I am good at \ntelling stories, and that is how I \ngot closer to Pietrik.</p>","notes":"I Don't Believe - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 88.","positive":"I am the young heir of \nthe Carnarvon family, but I dream \nof a life of travel and freedom, \nexploring the world. I am good at \ntelling stories, and that is how I \ngot closer to Pietrik.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Gwendolyn","category":"threat","source":"The Broken Ones, I Don't Believe"},"sort":4500000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557625775,"modifiedTime":1781557625775,"lastModifiedBy":null,"exportSource":null}}

{"_id":"FranciscaAndMart","name":"Francisca and Marta the Vengeful Sisters - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01ximyc3003s7acy","flags":{"broken-tales":{"owner":"Francisca and Marta the Vengeful Sisters","sourcePack":"broken-ones-actors","source":"The Broken Ones, In Your Eyes, with Your Feet, In Your Eyes, with Your Feet","category":"threat"}},"system":{"description":"<p>We are two poor sisters sewn together in one \nbody. We move with perfect coordination and cooperate \neffortlessly, each aiding the other against any danger.</p>","notes":"In Your Eyes, with Your Feet - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 157.","positive":"We are two poor sisters sewn together in one \nbody. We move with perfect coordination and cooperate \neffortlessly, each aiding the other against any danger.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Francisca and Marta the Vengeful Sisters","category":"threat","source":"The Broken Ones, In Your Eyes, with Your Feet, In Your Eyes, with Your Feet"},"sort":1500000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557637117,"modifiedTime":1781557637117,"lastModifiedBy":null,"exportSource":null}}

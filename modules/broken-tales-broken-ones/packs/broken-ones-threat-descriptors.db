{"_id":"DionisoGonsalvaC","name":"Dioniso Gonsalva called the Beast - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":"01122urb00biswq8","flags":{"broken-tales":{"owner":"Dioniso Gonsalva called the Beast","sourcePack":"broken-ones-actors","source":"The Broken Ones, The House of Roses","category":"threat"}},"system":{"description":"<p>I am a young man afflicted by a curse \nthat turned me into a fierce beast. Only Bella’s scent \nkeeps my incredible ferocity in check.</p>","notes":"The House of Roses - bt-tbo-1-eng-final-screen [2022-06-29].pdf, page 130.","positive":"I am a young man afflicted by a curse \nthat turned me into a fierce beast. Only Bella’s scent \nkeeps my incredible ferocity in check.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Dioniso Gonsalva called the Beast","category":"threat","source":"The Broken Ones, The House of Roses"},"sort":2500000,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557632137,"modifiedTime":1781557632137,"lastModifiedBy":null,"exportSource":null}}

{"_id":"vqeTB3IIfFys5lPx","name":"Circe the Alchemist","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-circe-the-alchemist.png","items":[{"_id":"rx8zjaptROfZB033","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"principal-descriptor","sequence":0}},"system":{"description":"Eurylochus cannot use more than one Pharmaka special effect per Scene.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","positive":"Eurylochus cannot use more than one Pharmaka special effect per Scene.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"descriptor-principal.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"pCUlqXRwbYCxIMrF","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"gift-descriptor","sequence":1}},"system":{"description":"I have studied alchemy with the greatest masters, and my potions can produce wondrous effects. I am so drawn to knowledge that I neglect \nmy own safety.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","positive":"I have studied alchemy with the greatest masters, and my potions can produce wondrous effects. I am so drawn to knowledge that I neglect my own safety.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"xV4DpZ5gThpseyne","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"gift-descriptor","sequence":2}},"system":{"description":"Eurylochus is my faithful servant pig and helps me with every task. He \nhas an almost human intelligence and one look is enough to understand \nus. I love him like a brother.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","positive":"Eurylochus is my faithful servant pig and helps me with every task. He has an almost human intelligence and one look is enough to understand us. I love him like a brother.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"lgrT0RheV90dtbC9","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"descriptor-darkego.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"I have a special power over people who are hopelessly attracted to my \npresence. I am shy and often break down when I receive too much \nexplicit attention.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","positive":"I have a special power over people who are hopelessly attracted to my presence. I am shy and often break down when I receive too much explicit attention.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"descriptor-darkego.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"mdybBbYpSm5enONx","name":"Pharmaka","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"don1.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"gift","sequence":1}},"system":{"description":"At the beginning of each Scenario, you receive 3 Pharmaka \nTokens. Spend 1 Token when someone ingests one of your potions, then pick \none of the following effects:\n1. The subject transforms into an animal of your choice for the remainder of \nthe Scene. The person retains their human intelligence. \n2. The subject is in a confused state, which lowers their OL by 1 (or 1 Penalty in the case of a Hunter) for the rest of the Scene.\n3. The subject regains vitality and gains an Additional Wound that fades at \nthe end of the Scene.\nY ou are naturally resistant to your creations, and if you want to activate an \neffect on yourself, you must spend 1 Soma in addition to a Pharmaka Token. \nParticularly powerful subjects and Hunters may require you to perform \na Position Check before they suffer the effects of your potions. During an Interlude, or if you get your hands on valuable alchemical ingredients, you can \nrecover 1 Pharmaka Token.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","somaCost":0,"automaticSuccesses":0,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"don1.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"6Lg9hAAXBTSdJkja","name":"Travel Companion","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"don2.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"gift","sequence":2}},"system":{"description":"Eurylochus is a Minor NPC with the following profile:\nOL 5 Medium - (2 Wounds) \nDescriptor: I am Circe’s faithful pig servant and would do anything for her. \nEurylochus has always been your companion in experimentation, and over the \nyears he has been imbued with the power of Pharmaka. By spending 1 Soma, \nyou can activate one of the following effects:\n1. Human Form: Eurylochus takes the form of a handsome young man with \nflowing blond hair. He cannot speak but gains all the other advantages of a \nhuman body.\n2. Size Change: Eurylochus can shrink to the size of a mouse or grow to the \nsize of an elephant. The effect lasts for the duration of the Scene.\n3. Regeneration: Eurylochus will recover all of his Wounds, which can also \nbring him back into action if he is down to zero.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","somaCost":0,"automaticSuccesses":0,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"don2.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"muizoCPq8B0cqXUq","name":"Dark Ego - Goddess Blood","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"darkego.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"dark-ego","sequence":0}},"system":{"description":"Y ou have the power of a goddess within you, \neven if you do not know how to use it. When you activate your aura, you \nchoose an NPC who will be kind to you and try to fulfill your every wish. This \nGift will have no effect on someone who has hostile intentions towards you, \nbut you will gain 2 Additional Successes on all Defense Checks you make, \nsince harming you seems an unnatural action even to those who hate you.\nY ou can activate all of the Travel Companion Gift’s effects on Eurylochus at \nthe same time.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","somaCost":0,"automaticSuccesses":0,"trigger":"Unleash your divine power with a charming or swaggering attitude \nat the most inopportune moment.","owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"darkego.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"AUZUBKQbtNY6lP88","name":"Your precious portable laboratory","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"equipment1.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"equipment","sequence":1}},"system":{"description":"Your precious portable laboratory","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","quantity":1,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"equipment1.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"9BtJLzxU9Dmag9jk","name":"A bag of alchemical components","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","contentKey":"equipment2.circe-the-alchemist","ownerKey":"cazador.circe-the-alchemist","role":"equipment","sequence":2}},"system":{"description":"A bag of alchemical components","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 20.","quantity":1,"owner":"Circe the Alchemist","source":"Lost Stories","category":"hunter","key":"equipment2.circe-the-alchemist"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"DHompJ1nqahy2jSf","name
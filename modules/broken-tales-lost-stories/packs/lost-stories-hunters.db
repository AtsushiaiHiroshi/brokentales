ies","category":"hunter","key":"equipment4.prince-trollo-the-innocent"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"qXL1PvFvjJMYLyCh","name":"A precious bracelet engraved with a cradle, a gift from my mother","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","contentKey":"equipment5.prince-trollo-the-innocent","ownerKey":"cazador.prince-trollo-the-innocent","role":"equipment","sequence":5}},"system":{"description":"A precious bracelet engraved with a cradle, a gift from my mother","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 6.","quantity":1,"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","key":"equipment5.prince-trollo-the-innocent"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"pMuf0PCkSnOlSRVT","name":"A well-worn blanket that I love and use as a cloak","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","contentKey":"equipment6.prince-trollo-the-innocent","ownerKey":"cazador.prince-trollo-the-innocent","role":"equipment","sequence":6}},"system":{"description":"A well-worn blanket that I love and use as a cloak","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 6.","quantity":1,"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","key":"equipment6.prince-trollo-the-innocent"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"5dteOCxgbZ2V0G97","name":"A bag full of coins and valuables that I often lose","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","contentKey":"equipment7.prince-trollo-the-innocent","ownerKey":"cazador.prince-trollo-the-innocent","role":"equipment","sequence":7}},"system":{"description":"A bag full of coins and valuables that I often lose","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 6.","quantity":1,"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","key":"equipment7.prince-trollo-the-innocent"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"Y9vXrqvxA97Rb367","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","contentKey":"source.prince-trollo-the-innocent","ownerKey":"cazador.prince-trollo-the-innocent","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 6.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 6","owner":"Prince Trollo the Innocent","source":"Lost Stories","category":"hunter","key":"source.prince-trollo-the-innocent"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-prince-trollo-the-innocent","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"6"}},"system":{"details":{"concept":"Lost Stories","origin":"Prince Trollo the Innocent","role":"Hunter of the Order","notes":"Y ou gain 1 Additional Success for each Check you make when trying \nto persuade someone to do the right thing. Once per Scenario, if you \nsuffer 1 Wound to stand up for what you believe in, you set an example \nfor those who help you. Each ally recovers 1 Soma, and a target of your \nchoice (Hunter or NPC) immediately gains an additional action they \nmust use to try to help you or get you to safety."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}}
{"_id":"OSQeEX3bvHY3Rw3J","name":"Karasu Kuroi the Wandering Monk","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-karasu-kuroi-the-wandering-monk.png","items":[{"_id":"M6MEkz88ywnFnDQt","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"principal-descriptor","sequence":0}},"system":{"description":"Y ou can mentally communicate for the rest of the Scene.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","positive":"Y ou can mentally communicate for the rest of the Scene.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"descriptor-principal.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"Qvk101dWECvOFZZj","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"gift-descriptor","sequence":1}},"system":{"description":"I am an exorcist monk. My body is tempered by a lifetime of asceticism \nand fighting evil spirits. I do not tolerate blasphemy and those who use \nknowledge for personal gain.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","positive":"I am an exorcist monk. My body is tempered by a lifetime of asceticism and fighting evil spirits. I do not tolerate blasphemy and those who use knowledge for personal gain.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"HadOmgKS9bWo2Agx","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"gift-descriptor","sequence":2}},"system":{"description":"Prayer keeps my mind steadfast and my words are an inspiration to \nthose who have faith. I do not tolerate the concepts of faith and \ndevotion being questioned.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","positive":"Prayer keeps my mind steadfast and my words are an inspiration to those who have faith. I do not tolerate the concepts of faith and devotion being questioned.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"CXMvdKWUbV7P1csh","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"descriptor-darkego.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"My greatest secret is that I am like those I fight. My true essence is that \nof a Yokai ghost, which is why I have a talent for unearthing Broken \nTales. I try to do good deeds in the hope of reincarnating as a human.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","positive":"My greatest secret is that I am like those I fight. My true essence is that of a Yokai ghost, which is why I have a talent for unearthing Broken Tales. I try to do good deeds in the hope of reincarnating as a human.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"descriptor-darkego.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"GOCMKSRuSK6LWFIE","name":"Monk","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"don1.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"gift","sequence":1}},"system":{"description":"Y ou can spend 1 Soma to activate a piece of your Spirit Hunter \nEquipment:\n1. Pastoral Shakujo: Banging your staff on the ground can temporarily \ninterrupt the effect of a spell or curse. The duration of the interruption (set by \nthe Storyteller) can vary from a few moments to the entire Scene, depending \non the power of the spell.\n2. Hauchiwa Fan: With a fan blast, you can make a leap of up to ten meters \nforward or upward. Y ou can use this effect on an ally.\n3. Tengu-gui Mask: Y ou can wear your mask to change your facial features, taking on a physical appearance appropriate to the context. Create a \nDescriptor that represents your appearance, but remember that you cannot \nreplicate the features of a specific subject. When you activate a Gift or suffer 1 \nWound, you will revert to your original appearance. \nThe use of this Gift is limited by the possession of the corresponding \nEquipment: if you lose an item, you cannot use the relevant option until you \nrecover it. During an Interlude, you recover any missing Equipment.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","somaCost":0,"automaticSuccesses":0,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"don1.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"smzJjqsrED08uB6Q","name":"Moral Rigor","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"don2.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"gift","sequence":2}},"system":{"description":"Y ou demonstrate righteousness in word and deed. Y ou gain \n1 Additional Success on all Position Checks where you make a commitment \nby giving your word as a guarantee. By spending 1 Soma, you can make \nmental contact with a subject present in the Scene who must accept the link.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","somaCost":0,"automaticSuccesses":0,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"don2.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"X0SxHR64azshj6Lj","name":"Dark Ego - You Are What You Fight","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"darkego.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"dark-ego","sequence":0}},"system":{"description":"When you reveal your true nature, \nyour body changes into the form of a humanoid raven. Y ou will gain the \nfollowing abilities:\n1. Y ou can move by flying thanks to the large wings on your back. Y ou gain \n1 Additional Success on all Defense Checks while hovering in the air. \n2. Y ou can use your large beak to strike an enemy as an additional action, \nbut you cannot communicate by speaking.\n3. Y ou gain 1 Additional Success if you act to injure someone who has \ninflicted 1 Wound on you in the current Scene.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","somaCost":0,"automaticSuccesses":0,"trigger":"You reveal your true nature to prove that not all spirits are evil.","owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"darkego.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"rLpJLFZ461M9vFPc","name":"My prized traveling Shakujō","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment1.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":1}},"system":{"description":"My prized traveling Shakujō","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment1.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"YqfO0OuPUYVY3KdK","name":"My prized Hauchiwa fan","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment2.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":2}},"system":{"description":"My prized Hauchiwa fan","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment2.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"GrygUEKvWKI33bda","name":"A Tengu-gui raven mask","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment3.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":3}},"system":{"description":"A Tengu-gui raven mask","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment3.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"Qvs4wO002VuibwTL","name":"A theater mask with a long nose that I use to hide my Asian features","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment4.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":4}},"system":{"description":"A theater mask with a long nose that I use to hide my Asian features","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment4.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"yRMkENh4mW0YJsCo","name":"A katana that belonged to a famous samurai","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment5.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":5}},"system":{"description":"A katana that belonged to a famous samurai","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment5.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"zh6jocvLvqL7rgRw","name":"A traveling bag containing boiled rice and bean paste","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"equipment6.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"equipment","sequence":6}},"system":{"description":"A traveling bag containing boiled rice and bean paste","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.","quantity":1,"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"equipment6.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"OF4RVxjjqns1i6MX","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","contentKey":"source.karasu-kuroi-the-wandering-monk","ownerKey":"cazador.karasu-kuroi-the-wandering-monk","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 14","owner":"Karasu Kuroi the Wandering Monk","source":"Lost Stories","category":"hunter","key":"source.karasu-kuroi-the-wandering-monk"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-karasu-kuroi-the-wandering-monk","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"14"}},"system":{"details":{"concept":"Lost Stories","origin":"Karasu Kuroi the Wandering Monk","role":"Hunter of the Order","notes":"Y ou can mentally communicate for the rest of the Scene."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}}
{"_id":"P9s6BDnrb6lYUNOW","name":"Vivienne of the Lake","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-exclusives-lost-stories-exclusives-hunter-5.png","items":[{"_id":"ss96PgHABCPhvrZc","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-principal.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"principal-descriptor","sequence":0}},"system":{"description":"If your Champion is knocked out or killed, a new Champion will arrive at \nthe beginning of the next Scenario. Y ou gain 1 Additional Success on all \nChecks where your action removes you from your Champion’s obsessive \nattention.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","positive":"If your Champion is knocked out or killed, a new Champion will arrive at the beginning of the next Scenario. Y ou gain 1 Additional Success on all Checks where your action removes you from your Champion’s obsessive attention.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-principal.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"JIMkEhd9eT0iulFQ","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor1-don1.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"gift-descriptor","sequence":1}},"system":{"description":"I have a talent for assessing people’s merits and flaws, so I am good at \ncoordinating the efforts of those who trust me. I have a soft spot for those \nwho fail but try hard, and though I don’t like to admit it, sometimes the \ninstinct to help losers still takes over.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","positive":"I have a talent for assessing people’s merits and flaws, so I am good at coordinating the efforts of those who trust me. I have a soft spot for those who fail but try hard, and though I don’t like to admit it, sometimes the instinct to help losers still takes over.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor1-don1.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"uxlI1M6d7H4TKpvv","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor2-don2.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"gift-descriptor","sequence":2}},"system":{"description":"I am very vain and love to waste time admiring my own image.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","positive":"I am very vain and love to waste time admiring my own image.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor2-don2.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"56F0zsDutAqw25OW","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-darkego.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"I am an ancient fairy and my magic allows me to manipulate and \ndominate water. I don’t like to be recognized by humans, so I try to \nkeep my powers hidden from prying eyes.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","positive":"I am an ancient fairy and my magic allows me to manipulate and dominate water. I don’t like to be recognized by humans, so I try to keep my powers hidden from prying eyes.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-darkego.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"zKm4twRaiDGMCqyr","name":"Blessing of the Defeated","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don1.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"gift","sequence":1}},"system":{"description":"If your ally suffers a Wound or fails a Check, \nthey will gain 1 Additional Success (or increase their OL by 1 in the case \nof an NPC) on their next action. Alternatively, once per Scenario, you can \nchoose to have them recover 2 Soma or 1 Wound, or alternatively gain 2 XP . \nIf an NPC achieves their Agenda’s goal thanks to your help, you recover 1 \nSoma and gain 1 XP . \nI have a strong influence on people and my charm cannot be ignored.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","somaCost":0,"automaticSuccesses":0,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"don1.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"OMZdS2PpLIMSYPpE","name":"The Lady’s Champion","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don2.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"gift","sequence":2}},"system":{"description":"There’s always some fool who follows you around \nand proclaims themselves your Champion, until you lose all patience. The \nStoryteller creates an NPC with the following profile at the beginning of the \nScenario:\nOL Medium 5 - (3 Wounds)\nDescriptor: A positive feature that identifies the identity and abilities of the \naspiring Champion. A Downside that identifies total devotion, obsession, love, \nor admiration for Vivienne of the Lake.\nAgenda: Help and protect Vivienne at all costs. Even if my lady tells me not to \nget in her way, I must do so to ensure her safety.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","somaCost":0,"automaticSuccesses":0,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"don2.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"Y4QvofH5Zh00oCU1","name":"Dark Ego - Water Fairy","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"darkego.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"dark-ego","sequence":0}},"system":{"description":"Y ou can spend 1 Soma to create 2 small pools \nof lake water, three feet wide and five inches deep. The pools will be created \non any surface, and you can create them anywhere within your field of vision. \nWhen you dip your feet into the water, you unleash your thousand-year-old \nfairy powers. Y ou can choose one of these effects as an additional action in \nany Exchange:\n1. Recover 1 Wound you suffered during this Scene.\n2. Move immediately to a place that you can see. No one can stop you, but \nyou must end up with your feet in contact with the water.\n3. Create a dense fog from a water source that limits visibility but has no \neffect on you.\n4. Hit a target with a jet of water from a pool you create. This is a normal \nattack that requires a Position Check and causes 1 Wound.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","somaCost":0,"automaticSuccesses":0,"trigger":"Dive into the water of a lake and drop your disguise, or give advice \nto someone you really care about.","owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"darkego.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"igwah8FJkAhMki4q","name":"Fine clothes","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment1.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"equipment","sequence":1}},"system":{"description":"Fine clothes","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","quantity":1,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"equipment1.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"YLexdD1aQnZhNVNW","name":"Wigs, tricks, and masks","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment2.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"equipment","sequence":2}},"system":{"description":"Wigs, tricks, and masks","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","quantity":1,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"equipment2.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"qFC4dJR3YL7R0yV3","name":"A few trinkets the Order insists on calling “Treasures”","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment3.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"equipment","sequence":3}},"system":{"description":"A few trinkets the Order insists on calling “Treasures”","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","quantity":1,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"equipment3.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"jtIabv6sbsUz94Ni","name":"A small portrait of the only human I ever loved","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment4.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"equipment","sequence":4}},"system":{"description":"A small portrait of the only human I ever loved","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.","quantity":1,"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"equipment4.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"iYodYv5j8dj2EtEJ","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","contentKey":"source.vivienne-of-the-lake","ownerKey":"cazador.vivienne-of-the-lake","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10.</p>","notes":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 10","owner":"Vivienne of the Lake","source":"Lost Stories Exclusives","category":"hunter","key":"source.vivienne-of-the-lake"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-exclusives-vivienne-of-the-lake","pregenCollection":"Lost Stories Exclusives","source":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf","pages":"10","contentKey":"hunter.vivienne-of-the-lake"}},"system":{"details":{"concept":"Lost Stories Exclusives","origin":"Vivienne of the Lake","role":"Hunter of the Order","notes":"If your Champion is knocked out or killed, a new Champion will arrive at \nthe beginning of the next Scenario. Y ou gain 1 Additional Success on all \nChecks where your action removes you from your Champion’s obsessive \nattention."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Q0uwORWywNW8rx2l","name":"The Pale Medic","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-exclusives-the-pale-medic.png","items":[{"_id":"kiG0HELYXtcqKY8W","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-principal.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"principal-descriptor","sequence":0}},"system":{"description":"I am a good doctor and I know the cure for every disease, I can tell the \nphysical state of health of a patient just by looking at them. I hate \nviolence and physical confrontation.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","positive":"I am a good doctor and I know the cure for every disease, I can tell the physical state of health of a patient just by looking at them. I hate violence and physical confrontation.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-principal.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZGZTQhukF6dHPii1","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor1-don1.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"gift-descriptor","sequence":1}},"system":{"description":"I have a certain amount of charm and I know how to put people at ease \nwith my polite manner. I feel uncomfortable in places where I have not \nbeen invited or where it is obvious that my presence is unwelcome.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","positive":"I have a certain amount of charm and I know how to put people at ease with my polite manner. I feel uncomfortable in places where I have not been invited or where it is obvious that my presence is unwelcome.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor1-don1.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"lqYjm1dKE1EkZ4wR","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor2-don2.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"gift-descriptor","sequence":2}},"system":{"description":"I have vampire blood in me and my strength is far superior to that of \nan ordinary human. I am extremely sensitive to sunlight and try to \navoid it as much as possible.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","positive":"I have vampire blood in me and my strength is far superior to that of an ordinary human. I am extremely sensitive to sunlight and try to avoid it as much as possible.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor2-don2.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"V42SBvWsWPd4BM5w","name":"Cursed Blood","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don1.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"gift","sequence":1}},"system":{"description":"Y our blood has incredible properties, so at the end of each \nScene, you recover 1 Wound; this can allow you to return even if you have \nno Wounds left. Self-inflict 1 Wound to draw your blood. Whoever drinks it \n(except you) can choose one of the following effects:\n1. Recover 1 Wound.\n2. Gain 1 Additional Success (increases OL by 1 in the case of an NPC) on \nall Checks for the rest of the Scene. For each Check in which this bonus \nis used, roll a die: if you roll a 5 or 6, the blood’s effect ends.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"don1.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"G3PzPVf3M0rATGo3","name":"Welcome to My House","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don2.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"gift","sequence":2}},"system":{"description":"If you care for an NPC, or are able to talk to them \nin a social setting, you gain 1 Additional Success on any Position Checks you \nmake to influence them. If the Check results in a Positive Outcome, you gain \n1 Additional Success on all Checks you make against that NPC for the rest of \nthe Scenario. After your conversation, the Storyteller will reveal something \nyou didn’t know about the NPC, such as part of their Agenda or a Gift you \nhaven’t seen in action.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"don2.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"f0fMh4qYHJx5NuVn","name":"Dark Ego - The Vampire","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"darkego.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"dark-ego","sequence":0}},"system":{"description":"Self-inflict 1 Wound and release the power of \nthe ancient curse that permeates your body. Y ou gain 1 Additional Success for \neach Position Check you make using your supernatural power. Y ou can use \neach of the following powers once per Scene:\n1. Turn into a cloud of mist. In this form, you will move slowly but can \navoid all obstacles. While in this form, you retain all your senses, can \nonly be injured by magic, and cannot physically interact with objects or \npeople.\n2. Summon three wolves that will act under your total control. The wolves \nare Minor NPCs with the following profiles: \nOL Medium 5 - (1 Wound) - Descriptor: I am a big wild wolf, ready to \nfight to the death for my master. \n3. Communicate telepathically with another person on whom you used one \nof your Gifts during the Scenario.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","somaCost":0,"automaticSuccesses":0,"trigger":"Drink and savor human blood in front of someone. Alternatively, \nbreak a crucifix or throw away garlic in disgust.","owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"darkego.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"3rYcsEfRr4LRstpT","name":"A dark doctor’s uniform","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment1.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":1}},"system":{"description":"A dark doctor’s uniform","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment1.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"4q2k0L1zFgiW3Ebp","name":"A pair of fine dark glasses","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment2.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":2}},"system":{"description":"A pair of fine dark glasses","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment2.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"6fpG9X9S3cptOnhr","name":"A vial of Transylvanian soil","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment3.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":3}},"system":{"description":"A vial of Transylvanian soil","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment3.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"fEYr0XrXcNrHCCAk","name":"An ash stake crusted with blood","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment4.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":4}},"system":{"description":"An ash stake crusted with blood","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment4.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"do1Ab5ydTSPtHXwa","name":"A doctor’s bag","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment5.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":5}},"system":{"description":"A doctor’s bag","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment5.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"JOkSIFtl2XhSGkRZ","name":"A dozen vials of my blood","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment6.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":6}},"system":{"description":"A dozen vials of my blood","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment6.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"hcn8qInNjegImK3z","name":"A necklace made by nomads","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment7.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":7}},"system":{"description":"A necklace made by nomads","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment7.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"RAxCBMa7WU7VFx5k","name":"A vial of precious human blood","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment8.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"equipment","sequence":8}},"system":{"description":"A vial of precious human blood","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.","quantity":1,"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"equipment8.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}},{"_id":"K4PGCeFvlw0kFshn","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","contentKey":"source.the-pale-medic","ownerKey":"cazador.the-pale-medic","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.</p>","notes":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4","owner":"The Pale Medic","source":"Lost Stories Exclusives","category":"hunter","key":"source.the-pale-medic"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-exclusives-the-pale-medic","pregenCollection":"Lost Stories Exclusives","source":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf","pages":"4"}},"system":{"details":{"concept":"Lost Stories Exclusives","origin":"The Pale Medic","role":"Hunter of the Order","notes":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 4.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}}
{"_id":"T8tm6XUaYiG0c9LL","name":"Moriarty the Gentleman Thief","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-exclusives-moriarty-the-gentleman-thief.png","items":[{"_id":"LZqxitn4bxt11yMy","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-principal.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"principal-descriptor","sequence":0}},"system":{"description":"I am an experienced criminal and I know what it takes to pull off \na perfect heist. Planning and precision are the basis for success, \nand I refuse to rely on improvisation or luck.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","positive":"I am an experienced criminal and I know what it takes to pull off a perfect heist. Planning and precision are the basis for success, and I refuse to rely on improvisation or luck.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-principal.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"Tb9RuAoGM0T6Qmzy","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor1-don1.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"gift-descriptor","sequence":1}},"system":{"description":"My misdeeds have made me a real celebrity - I have clashed with \nheroes, nobles, and religious people, and I know how to deal with \neach of them. Sometimes I like to give my enemies a small \nadvantage just to make the challenge more interesting.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","positive":"My misdeeds have made me a real celebrity - I have clashed with heroes, nobles, and religious people, and I know how to deal with each of them. Sometimes I like to give my enemies a small advantage just to make the challenge more interesting.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor1-don1.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"fPdDc27jTKDlSwOE","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor2-don2.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"gift-descriptor","sequence":2}},"system":{"description":"I am as ingenious in the use of concealed weapons and low blows \nas I am in plotting crime. The memory of my lost love has changed \nme deeply, and I try to prevent crime from creating innocent \nvictims.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","positive":"I am as ingenious in the use of concealed weapons and low blows as I am in plotting crime. The memory of my lost love has changed me deeply, and I try to prevent crime from creating innocent victims.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor2-don2.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"9zcvNzmxiqsIgtqn","name":"Diabolical Plan","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don1.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"gift","sequence":1}},"system":{"description":"Once per Scenario, you can do each of the \nfollowing:\n1. Find a useful item (that you had previously planted) in your location. Receive 1 Spider Web Token.\n2. Deliver a message to someone without anyone else noticing. The \nmessage will be delivered during the Scene and, if you wish, you \nwill receive a reply at the beginning of the next Scene. Receive 1 \nSpider Web Token.\n3. Introduce an allied Minor NPC of yours to the Scene, who will be \nwilling to testify on your behalf. Receive 1 Spider Web Token.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"don1.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"5AGW4sX2vUfCAslk","name":"Dark Eminence","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don2.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"gift","sequence":2}},"system":{"description":"Gain 1 Additional Success on all Checks involving \ndeception or obtaining something illegally. When you arrive at a new \nlocation, the Storyteller will reveal the possible presence of criminal \norganizations and their misdeeds. If you strike a beneficial pact with \na criminal or powerful organization, you will receive 1 Spider Web \nToken.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"don2.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"dctqlxgg8ITLwkAZ","name":"Dark Ego - The Napoleon of Crime","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"darkego.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"dark-ego","sequence":0}},"system":{"description":"When you reveal your plan in \nall its glory, the unsuspecting pawns of your game will be left speechless. \nY ou will receive 2 Spider Web Tokens. Y ou can spend them as if they \nwere Soma points. Y ou can also activate the following effects at any time \nin the Scene at a cost of 1 Spider Web Token each:\n1. Discovering the Gift of an NPC. \n2. Allow an ally to activate their Dark Ego by ignoring the Activator. \n3. Provide 1 Additional Success to an Ally’s Position Check.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"trigger":"Announce your plan loudly. Show everyone that what you \nhave done before has created an advantage in the current situation.","owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"darkego.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"MBZf6FarxZim2qtp","name":"Refined dandy’s clothes","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment1.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":1}},"system":{"description":"Refined dandy’s clothes","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment1.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"59Rv2Pj4CIcNGbOj","name":"A fine pipe to remember me by","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment2.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":2}},"system":{"description":"A fine pipe to remember me by","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment2.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"NpUchRM2Izer2rdd","name":"A futuristic air pistol","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment3.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":3}},"system":{"description":"A futuristic air pistol","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment3.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"vVnbsuaj900WdIgT","name":"A monocle of fine workmanship","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment4.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":4}},"system":{"description":"A monocle of fine workmanship","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment4.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"OErBlAmYbeEZ7hsY","name":"A broad cape concealing stilettos and poisons","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment5.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":5}},"system":{"description":"A broad cape concealing stilettos and poisons","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment5.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"2ixJSfpwmM7yenid","name":"A bouquet of passe-partout","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment6.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":6}},"system":{"description":"A bouquet of passe-partout","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment6.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"5vgKlQ06tFQRiXJM","name":"An animated staff","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment7.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":7}},"system":{"description":"An animated staff","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment7.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"INwWyZnSgvP4HTmm","name":"Boots with hidden pockets. I am the greatest criminal mastermind of all time, and the echoes of my misdeeds have reverberated around the world. Thanks to my incredible cunning, I have always made fools of the authorities, pulled off the most incredible thefts, and manipulated institutions like puppets in my hands. All this until I crossed paths with the World’s Most Famous Investigator. I knew immediately that he would be a challenge worthy of my talents, and for years we battled each other through misdeeds and investigations. On the day of our showdown, however, I realized the truth that I had always tried to hide in my heart. What united us was not rivalry, but the love that can only be felt for someone who is your perfect better half. Feigning death, we retired to private life, but the idyll was shortlived. Called to duty on an international case, he broke our pact and returned to the limelight to do what he does best. Distraught and wounded, I took refuge in the Order. As a Hunter, I used my brilliant mind to fight the darkness and forget my lost love. Moriarty the Gentleman Thief","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment8.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"equipment","sequence":8}},"system":{"description":"Boots with hidden pockets. I am the greatest criminal mastermind of all time, and the echoes of my misdeeds have reverberated around the world. Thanks to my incredible cunning, I have always made fools of the authorities, pulled off the most incredible thefts, and manipulated institutions like puppets in my hands. All this until I crossed paths with the World’s Most Famous Investigator. I knew immediately that he would be a challenge worthy of my talents, and for years we battled each other through misdeeds and investigations. On the day of our showdown, however, I realized the truth that I had always tried to hide in my heart. What united us was not rivalry, but the love that can only be felt for someone who is your perfect better half. Feigning death, we retired to private life, but the idyll was shortlived. Called to duty on an international case, he broke our pact and returned to the limelight to do what he does best. Distraught and wounded, I took refuge in the Order. As a Hunter, I used my brilliant mind to fight the darkness and forget my lost love. Moriarty the Gentleman Thief","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.","quantity":1,"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"equipment8.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"Ca0ZMM9nuZ5y8cdT","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","contentKey":"source.moriarty-the-gentleman-thief","ownerKey":"cazador.moriarty-the-gentleman-thief","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.</p>","notes":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2","owner":"Moriarty the Gentleman Thief","source":"Lost Stories Exclusives","category":"hunter","key":"source.moriarty-the-gentleman-thief"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-exclusives-moriarty-the-gentleman-thief","pregenCollection":"Lost Stories Exclusives","source":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf","pages":"2"}},"system":{"details":{"concept":"Lost Stories Exclusives","origin":"Moriarty the Gentleman Thief","role":"Hunter of the Order","notes":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 2.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241656,"modifiedTime":1783973241656,"lastModifiedBy":null,"exportSource":null}}
{"_id":"WOetj5VbnIKzAfDC","name":"The 7 Hessian Mercenaries","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-the-7-hessian-mercenaries.png","items":[{"_id":"EVOFtOy8FZjmskN5","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"principal-descriptor","sequence":0}},"system":{"description":"Outcome with an Increment: The goal has been reached, and the team has \nbrought home something important. The Storyteller will tell you what.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","positive":"Outcome with an Increment: The goal has been reached, and the team has brought home something important. The Storyteller will tell you what.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"descriptor-principal.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"vQkgAhk2nLf1f5gN","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"gift-descriptor","sequence":1}},"system":{"description":"We are experienced mercenaries and have seen every battlefield. We \nhate working for free and any chance to bring home some extra loot is \ngood.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","positive":"We are experienced mercenaries and have seen every battlefield. We hate working for free and any chance to bring home some extra loot is good.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"K5v6CHq5WZCjuBZq","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"gift-descriptor","sequence":2}},"system":{"description":"We are adept at getting things, information, people, or anything you \nwant - ask and we will find it. We are intolerant of authority and \nanything with a hierarchy of command.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","positive":"We are adept at getting things, information, people, or anything you want - ask and we will find it. We are intolerant of authority and anything with a hierarchy of command.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"YqkrOGJhDoFwANwY","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"descriptor-darkego.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"Discipline and order are the keys to victory. We act as a team because \nthat is what has allowed us to survive so far. Team first and foremost.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","positive":"Discipline and order are the keys to victory. We act as a team because that is what has allowed us to survive so far. Team first and foremost.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"descriptor-darkego.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"I5tXuBobmahFkc4l","name":"The Team","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"don1.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"gift","sequence":1}},"system":{"description":"At the beginning of each Scene, you choose the 3 members \nof the Main Team. Y ou will receive the 3 Gifts and the Special Equipment of \nthe members you have chosen. The other 4 dwarves form the Support Team. \nThe Main Team acts as a single Hunter and receives 1 Penalty to Checks for \neach team member not present in a Scene. Wounds are also cumulative for all \nmembers, and any member can act until the Team takes its last Wound. During \na Scene, you can spend 1 Soma to swap a Main Team member for a Support \nTeam member.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","somaCost":0,"automaticSuccesses":0,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"don1.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"Oek3JjBOj4uBO2X5","name":"On Mission","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"don2.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"gift","sequence":2}},"system":{"description":"Once per Scene, you can send the Support Team on a mission \nto accomplish a goal, such as capturing an NPC, discovering information, or \nanything else you deem useful. The Storyteller sets the OL of the mission just \nlike a normal Position Check. To find out what happens, you must make a \nPosition Check, where you get 1 Base Success for each Support Team Member \n(usually 4), but you cannot spend Soma to get Additional Successes. Depending \non the result:\nFailure: The objective was missed, and one of the team members is out of the \ngame for the rest of the Scenario. Describe what happened in the words of the \nreturning teammates. If the story makes at least one other Player laugh, you will \nrecover 1 Soma.\nOutcome with a Cost: The goal was completed, but there were problems. The \nStoryteller describes how it went and suggests a complication.\nStandard Outcome: Goal completed, no problems.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","somaCost":0,"automaticSuccesses":0,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"don2.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"o5RUBtNKdP7j6JiU","name":"Dark Ego - Heigh-ho, Heigh-ho","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"darkego.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"dark-ego","sequence":0}},"system":{"description":"If you are preparing for a confrontation, \nno one can stand up to you. If it is on a mission, the Support Team immediately \nre-enters the Scene (even if it means interrupting another task assigned through \nthe On Mission Gift), with all the narrative benefits that can bring. For the rest \nof the Scene, the Main and Support Teams will act as a single Hunter 2 times \nper Exchange, not consecutively. Any personal Gifts from the various members \nmay be used.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","somaCost":0,"automaticSuccesses":0,"trigger":"Begin a confrontation or challenge with the singing of your battle \nhymn.","owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"darkego.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"u1DJKv5TN0UMflGa","name":"Swords and guns in abundance","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"equipment1.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"equipment","sequence":1}},"system":{"description":"Swords and guns in abundance","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","quantity":1,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"equipment1.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id":"OJEckieJ3mBWswZ5","name":"Shovels and picks for digging holes and trenches","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","contentKey":"equipment2.the-7-hessian-mercenaries","ownerKey":"cazador.the-7-hessian-mercenaries","role":"equipment","sequence":2}},"system":{"description":"Shovels and picks for digging holes and trenches","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 16.","quantity":1,"owner":"The 7 Hessian Mercenaries","source":"Lost Stories","category":"hunter","key":"equipment2.the-7-hessian-mercenaries"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241654,"modifiedTime":1783973241654,"lastModifiedBy":null,"exportSource":null}},{"_id"
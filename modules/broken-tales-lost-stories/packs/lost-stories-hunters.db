all the men and women whose hearts I have broken","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 10.","quantity":1,"owner":"Loki the Deceiver","source":"Lost Stories","category":"hunter","key":"equipment6.loki-the-deceiver"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"UacQFtkhkREkM5i9","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Loki the Deceiver","source":"Lost Stories","category":"hunter","contentKey":"source.loki-the-deceiver","ownerKey":"cazador.loki-the-deceiver","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 10.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 10","owner":"Loki the Deceiver","source":"Lost Stories","category":"hunter","key":"source.loki-the-deceiver"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-loki-the-deceiver","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"10"}},"system":{"details":{"concept":"Lost Stories","origin":"Loki the Deceiver","role":"Hunter of the Order","notes":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 10.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}}
{"_id":"ea2QBaJsgMhAwSor","name":"Miss Snow and Lady Storm","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-miss-snow-and-lady-storm.png","items":[{"_id":"TNuFjoXJ94GuttZa","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"principal-descriptor","sequence":0}},"system":{"description":"Y ou can spend 1 Soma when you use this Gift to blow a kiss to the target, \nthus avoiding physical contact.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","positive":"Y ou can spend 1 Soma when you use this Gift to blow a kiss to the target, thus avoiding physical contact.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"descriptor-principal.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"V0uncA5fuNXKqmaV","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"gift-descriptor","sequence":1}},"system":{"description":"I am a novice a powerful sorceress with limited power total control \nover cold and snow. My magic can come with dangerous, unintended \nconsequences cause small unwanted effects.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","positive":"I am a novice a powerful sorceress with limited power total control over cold and snow. My magic can come with dangerous, unintended consequences cause small unwanted effects.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"fDTs5jdC8jBrGwKQ","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"gift-descriptor","sequence":2}},"system":{"description":"I am good at understanding dominating people. I have a unique \nability to comprehend their desires. I tend to distrust even close allies \ntrust those I don’t know.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","positive":"I am good at understanding dominating people. I have a unique ability to comprehend their desires. I tend to distrust even close allies trust those I don’t know.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"NFZ2QilmZqiwekwA","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"descriptor-darkego.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"Cold and frost have no effect on me are extensions of my soul and I feel \na great affinity for winter. My heart of pure ice delights is easily touched \nwhen I see others suffer.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","positive":"Cold and frost have no effect on me are extensions of my soul and I feel a great affinity for winter. My heart of pure ice delights is easily touched when I see others suffer.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"descriptor-darkego.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"Fsk1eT2UTyBMPvgz","name":"Snow Sorceress","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"don1.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"gift","sequence":1}},"system":{"description":"Y ou can use magic to create and manipulate the \ncold. Describe the effects of a spell that has one of the following Keywords \nas a condition: Ice, Snow, or Frost. Y ou could, for example, Create an Ice \nBridge to cross a crevasse or Freeze an Enemy to immobilize it. Pay a cost \nof 1 to 3 Soma, decided by the Storyteller, to activate the spell. The effects \nyou describe last until the end of the Scene. The Soma cost is increased by \n1 when environmental conditions are not compatible with cold. Y ou can \ndecide to lower the cost of the spell by 1 Soma, but this will cause a minor \nmagical accident on par with an Outcome with a Cost.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"don1.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"r8WQ89D0qN7THtqV","name":"Winter’s Kiss","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"don2.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"gift","sequence":2}},"system":{"description":"In you lies the power of winter. When you give \nsomeone a chaste kiss, you can choose one of the following effects:\n1. Erase one of their memories. It must be the memory of an event in the \nScene in which you use this effect. Particularly capable Hunters and \nNPCs may require a Position Check for the effect to succeed.\n2. Make the subject immune to cold throughout the rest of the Scene. \nThis will prevent them from suffering frost Wounds and allow them to \nignore the effects of Lady Storm’s snowstorm.\n3. Make an object extremely fragile.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"don2.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"30lU6qMUbXIkkkWO","name":"Dark Ego - Snow Queen","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"darkego.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"dark-ego","sequence":0}},"system":{"description":"The tiny fragment of a magic mirror lies in \nyour right eye, relegating the real you to oblivion. But when tears warm your \neyes, or you hear the word that represents your dominion over the cold, Lady \nStorm comes to her senses and woe to those who stand before her.\nWhile you are Lady Storm, you can lower the Soma cost of Snow Sorceress \nby 1 without creating magical accidents. In addition, you can use Winter’s \nKiss at a distance without spending Soma. If you wish, you can summon a \nsnowstorm that will sweep over your location regardless of previous weather \nconditions. Inside the storm, visibility is reduced to about three feet, and all \ninvolved lower their OL by 1 for each action. While the snowstorm rages, you \ncan use the Gift Winter’s Kiss as a free action once per Exchange. This Gift \nends, and the Hunter becomes Miss Snow once more as soon as you suffer 1 \nWound, or at the end of the Scene.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","somaCost":0,"automaticSuccesses":0,"trigger":"Cry over something that genuinely moved you. You hear the word \n“Eternity” spoken by someone who is not aware that it will awaken Lady Storm.","owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"darkego.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"0zvS5szPceG65dNG","name":"A brooch in the shape of a sleigh","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"equipment1.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"equipment","sequence":1}},"system":{"description":"A brooch in the shape of a sleigh","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","quantity":1,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"equipment1.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"kSn852d8RINUFKFI","name":"A small knife with a blade made of ice that never melts","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"equipment2.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"equipment","sequence":2}},"system":{"description":"A small knife with a blade made of ice that never melts","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","quantity":1,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"equipment2.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"L9PgFvZOx6zQuPO1","name":"A large key to a castle whose location you ignore","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"equipment3.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"equipment","sequence":3}},"system":{"description":"A large key to a castle whose location you ignore","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","quantity":1,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"equipment3.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"pdhbYgEgh8DSA4t6","name":"Spellbooks","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"equipment4.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"equipment","sequence":4}},"system":{"description":"Spellbooks","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","quantity":1,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"equipment4.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"7flv7TYkTKgOrXoN","name":"A mirror fragment with a strange magical aura","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"equipment5.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"equipment","sequence":5}},"system":{"description":"A mirror fragment with a strange magical aura","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.","quantity":1,"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"equipment5.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}},{"_id":"Mr93vM5Cx97am8wA","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","contentKey":"source.miss-snow-and-lady-storm","ownerKey":"cazador.miss-snow-and-lady-storm","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 2","owner":"Miss Snow and Lady Storm","source":"Lost Stories","category":"hunter","key":"source.miss-snow-and-lady-storm"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-miss-snow-and-lady-storm","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"2"}},"system":{"details":{"concept":"Lost Stories","origin":"Miss Snow and Lady Storm","role":"Hunter of the Order","notes":"Y ou can spend 1 Soma when you use this Gift to blow a kiss to the target, \nthus avoiding physical contact."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241651,"modifiedTime":1783973241651,"lastModifiedBy":null,"exportSource":null}}
{"_id":"okIxnhNUoqVuVw0H","name":"The Silent Mother","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-the-silent-mother.png","items":[{"_id":"0mVczjIIx7Gi9lhX","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"principal-descriptor","sequence":0}},"system":{"description":"I know my way around high society and have amassed great \nwealth through countless marriages. I am known in the \nunderworld for my exploits. I hate being accused of being a \ncriminal.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","positive":"I know my way around high society and have amassed great wealth through countless marriages. I am known in the underworld for my exploits. I hate being accused of being a criminal.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"descriptor-principal.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"dezYlUKgf3KcthDj","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"gift-descriptor","sequence":1}},"system":{"description":"I am able to understand the potential of young women and know \nhow to guide their steps to develop their true potential. I consider \neach of my protégés a true daughter and would give my life to \nsave them.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","positive":"I am able to understand the potential of young women and know how to guide their steps to develop their true potential. I consider each of my protégés a true daughter and would give my life to save them.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"QPA91FBbyDY4KK5v","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"gift-descriptor","sequence":2}},"system":{"description":"Although I appear helpless, I am a capable spy who knows how to \ndefend herself in dangerous situations. I never miss an opportunity \nto accumulate wealth and resources.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","positive":"Although I appear helpless, I am a capable spy who knows how to defend herself in dangerous situations. I never miss an opportunity to accumulate wealth and resources.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"J7ljTRjf9f1kqbck","name":"Legacy","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"don1.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"gift","sequence":1}},"system":{"description":"Y ou can use all the resources you have accumulated from \nyour many marriages of convenience. Y ou can use each of these effects \nonce per Scenario:\n1. A Family Asset: Y ou can bring a large property into play, such as \na mansion or business. Y ou have free access to the property and its \nresources.\n2. A Family Friend: Y ou can introduce a Minor NPC who has a debt or \npartnership agreement with your family. The Storyteller will sketch the \nNPC, who will be well-disposed towards you.\n3. A Family Treasure: Y ou can bring into play a rare and valuable item \nthat you own as a family heirloom.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"don1.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"bKZF1Jn9j3sJmB8L","name":"My Beloved Daughters","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"don2.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"gift","sequence":2}},"system":{"description":"Two young girls you saved from an \nunfortunate fate follow you on your adventures. Y our adopted \ndaughters are two Minor NPCs with the following profiles:\nOL Medium 5 - (1 Wound)\nDecide on their names and stories, and work with the Storyteller to \ncreate a Descriptor for each of them that describes their abilities. Y our \nadopted daughters cannot have magical abilities or more than a good \neducation in their chosen discipline. Y our daughters will do their best to \nserve you at every opportunity.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"don2.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"sQpKhIfFl436Ij6j","name":"Dark Ego - The Caring Mother","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"darkego.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"dark-ego","sequence":0}},"system":{"description":"Choose a female NPC or Hunter \nand name her your Pupil. Y our Pupil must be young and, in your \nopinion, deserving of your benevolence. Y ou will always know where \nyour Pupil is, and she will gain 1 Additional Success to her actions (or \nincrease her OL by 1 in the case of an NPC) if you are present in the \nScene to comfort her with your words. Y ou get 1 Additional Success if \nyou act against someone who endangers your Pupil. If an NPC or Hunter \nuses a Gift to harm your disciple, you can spend 1 Soma to prevent the \nGift from being activated.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","somaCost":0,"automaticSuccesses":0,"trigger":"Your words inspire a young girl to find her way or protect her \nfrom injustice.","owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"darkego.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"gBdn9dNKV6lYAm32","name":"Noble robes","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment1.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":1}},"system":{"description":"Noble robes","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment1.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"lPo9lQeHjDzleMV8","name":"Family jewelry and wealth","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment2.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":2}},"system":{"description":"Family jewelry and wealth","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment2.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"odS5fxbMaSceXAnG","name":"Two trained pigeons you can use to send messages","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment3.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":3}},"system":{"description":"Two trained pigeons you can use to send messages","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment3.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"FGwnaLPWXJLKp65c","name":"A set of long sewing pins","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment4.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":4}},"system":{"description":"A set of long sewing pins","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment4.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"0W1UXaackiaRp45o","name":"A long cloak and a mask depicting a smiling mother","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment5.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":5}},"system":{"description":"A long cloak and a mask depicting a smiling mother","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment5.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"SpRUkXNsKSoumQiz","name":"A sublimely crafted weapon","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"equipment6.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"equipment","sequence":6}},"system":{"description":"A sublimely crafted weapon","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.","quantity":1,"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"equipment6.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"JrSELbDxzQgsnxnv","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Silent Mother","source":"Lost Stories","category":"hunter","contentKey":"source.the-silent-mother","ownerKey":"cazador.the-silent-mother","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12","owner":"The Silent Mother","source":"Lost Stories","category":"hunter","key":"source.the-silent-mother"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-the-silent-mother","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"12"}},"system":{"details":{"concept":"Lost Stories","origin":"The Silent Mother","role":"Hunter of the Order","notes":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 12.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}}
{"_id":"r85gFqIWgFjp2LPF","name":"Doctor V. Frankenstein","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-exclusives-doctor-v-frankenstein.png","items":[{"_id":"ofa4HTiD2VgirOQp","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-principal.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"principal-descriptor","sequence":0}},"system":{"description":"Gift - Reanimated Corpse: The Creature is immune to electricity and \ncold. Once per Scene, when an ally is about to take 1 Wound, they can \nactivate this Gift to have the Creature intervene in their defense and take \nthe Wound instead. If Victor is the one requesting the use of this Gift, roll \na die: if it comes up even, the Creature will act to save him by applying the \neffect; if it comes up odd, its deep resentment towards its creator will get \nthe better of it and the Creature will not intervene, skipping its possible \nactivation in the Exchange.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","positive":"Gift - Reanimated Corpse: The Creature is immune to electricity and cold. Once per Scene, when an ally is about to take 1 Wound, they can activate this Gift to have the Creature intervene in their defense and take the Wound instead. If Victor is the one requesting the use of this Gift, roll a die: if it comes up even, the Creature will act to save him by applying the effect; if it comes up odd, its deep resentment towards its creator will get the better of it and the Creature will not intervene, skipping its possible activation in the Exchange.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-principal.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"Y1lBWIDkG06PAJeI","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor1-don1.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"gift-descriptor","sequence":1}},"system":{"description":"I am a luminary in physics and medicine and know secrets that the \nbrightest academics can only dream of. I often get lost in my own \nreasoning, which I articulate aloud without realizing it.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","positive":"I am a luminary in physics and medicine and know secrets that the brightest academics can only dream of. I often get lost in my own reasoning, which I articulate aloud without realizing it.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor1-don1.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"lmhvKlXSwdyBGwxX","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor2-don2.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"gift-descriptor","sequence":2}},"system":{"description":"I always bring the Creature with me and know how to make the \nmost of its potential. There are times when the guilt of creating such \na monster brings me back to reality, and in those rare moments, I \ntry to do a good deed to atone for my sins.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","positive":"I always bring the Creature with me and know how to make the most of its potential. There are times when the guilt of creating such a monster brings me back to reality, and in those rare moments, I try to do a good deed to atone for my sins.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor2-don2.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"TmOHneKvHcGPqkzO","name":"Dark Ego Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"descriptor-darkego.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"dark-ego-descriptor","sequence":0}},"system":{"description":"My mad experiments have expanded my knowledge of death and \nthe occult. I can tell the difference between science and magic. I \ngreedily desire anything I deem useful for my research and have no \nqualms about obtaining it.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","positive":"My mad experiments have expanded my knowledge of death and the occult. I can tell the difference between science and magic. I greedily desire anything I deem useful for my research and have no qualms about obtaining it.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"descriptor-darkego.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"bQ3hN8fQd6NHuQwu","name":"Behold my Genius","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don1.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"gift","sequence":1}},"system":{"description":"By spending 1 Soma, you can use one of your \nfuturistic discoveries to generate an electric shock that inflicts 1 Wound. \nThe thunderbolt can strike up to twenty feet away and can change its \ntrajectory to avoid obstacles. Alternatively, you can spend 1 Soma to \ncharge an object with electricity, causing it to discharge when touched and \ninflicting 1 Wound. The object remains charged until the end of the Scene.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"don1.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"Z6TL37xv5ndLWEN4","name":"The Creature","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"don2.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"gift","sequence":2}},"system":{"description":"Y our first creation is an NPC managed by the Storyteller, \nwith the following profile: \nOL Medium 5 - (4 Wounds)\nDescriptor: I am a powerful creature who feels no pain and has the strength \nof four men. My appearance is disgusting because of the many stitches that \nhold the pieces of my body together.\nAgenda: To be considered a person like any other and to find a family to take \nme in / I wish Victor to die, but as my creator, I cannot kill him with my own \nhands, and instead I try to facilitate his passing by acting indirectly.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"don2.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"xEjdCEdWMF2Ud6Qk","name":"Dark Ego - Reanimator","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"darkego.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"dark-ego","sequence":0}},"system":{"description":"Y ou appeal to the power of science to bring \nlife where there is none. Y ou receive 3 Reanimator Tokens. At your touch, \nand by spending 1 Reanimator Token, an inanimate object or corpse will \ncome to life for the duration of the Scene. Decide whether to also spend \n1 Soma to gain control of what you have animated, or to allow this new \ncreature to have free will. The Storyteller will create an NPC profile for \nhumans and animals (including the reanimation of a single part, such as \na hand or leg), or a Threat profile in the case of an inanimate object, such \nas a door or rope. If you are in control, the creation will do whatever you \ntell it to do. If the creation is acting with free will, it will be moved by the \nStoryteller and may even turn against you.","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"trigger":"Dismember or dig up a corpse, ignoring the horror it may cause \nthose watching.","owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"darkego.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"MG6cWIutl3IAojYk","name":"Books on science and medicine","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment1.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":1}},"system":{"description":"Books on science and medicine","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment1.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"7h5pyJw8HvFkB8Gi","name":"A surgeon’s bag","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment2.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":2}},"system":{"description":"A surgeon’s bag","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment2.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"bt8vRmh8SbNOCW4I","name":"Vials and jars with pieces of cadavers preserved in alcohol","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment3.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":3}},"system":{"description":"Vials and jars with pieces of cadavers preserved in alcohol","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment3.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"K9yFUfKCJEQsMozv","name":"Electrodes","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment4.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":4}},"system":{"description":"Electrodes","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment4.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"aBfM9KTdtJggUHc2","name":"A valuable machine that generates electricity","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment5.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":5}},"system":{"description":"A valuable machine that generates electricity","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment5.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"gqse4nuJ50mi3g1l","name":"A surgical gown","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment6.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":6}},"system":{"description":"A surgical gown","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment6.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"73Ky5hZNK8IHTSes","name":"Scalpel and saw","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment7.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":7}},"system":{"description":"Scalpel and saw","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment7.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"QoC2JXTk5l7nUeg8","name":"False documents to gain access to morgues and cemeteries","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment8.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":8}},"system":{"description":"False documents to gain access to morgues and cemeteries","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment8.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"z8cG6x63dLwH4JfF","name":"A handkerchief embroidered with the name of my beloved Elizabeth","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"equipment9.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"equipment","sequence":9}},"system":{"description":"A handkerchief embroidered with the name of my beloved Elizabeth","notes":"See Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.","quantity":1,"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"equipment9.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}},{"_id":"jiQWwOPRtwYtHieu","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","contentKey":"source.doctor-v-frankenstein","ownerKey":"cazador.doctor-v-frankenstein","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories Exclusives</strong></p><p>Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8.</p>","notes":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf, pages 8","owner":"Doctor V. Frankenstein","source":"Lost Stories Exclusives","category":"hunter","key":"source.doctor-v-frankenstein"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-exclusives-doctor-v-frankenstein","pregenCollection":"Lost Stories Exclusives","source":"Broken Tales - Lost Stories - Exclusive Pre-Gen Hunters.pdf","pages":"8"}},"system":{"details":{"concept":"Lost Stories Exclusives","origin":"Doctor V. Frankenstein","role":"Hunter of the Order","notes":"Gift - Reanimated Corpse: The Creature is immune to electricity and \ncold. Once per Scene, when an ally is about to take 1 Wound, they can \nactivate this Gift to have the Creature intervene in their defense and take \nthe Wound instead. If Victor is the one requesting the use of this Gift, roll \na die: if it comes up even, the Creature will act to save him by applying the \neffect; if it comes up odd, its deep resentment towards its creator will get \nthe better of it and the Creature will not intervene, skipping its possible \nactivation in the Exchange."},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241657,"modifiedTime":1783973241657,"lastModifiedBy":null,"exportSource":null}}
{"_id":"s0IibRK53ZJ25ou0","name":"Captain William of Nottingham","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-captain-william-of-nottingham.png","items":[{"_id":"j4Qq0zmVTphScIDK","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"principal-descriptor","sequence":0}},"system":{"description":"I am a good planner and carry all kinds of useful equipment for \nmy work. I hate sudden changes of plans.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","positive":"I am a good planner and carry all kinds of useful equipment for my work. I hate sudden changes of plans.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"descriptor-principal.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"LiO5Fnxpq1aCzuL7","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"gift-descriptor","sequence":1}},"system":{"description":"I am a lawman and I am proud of my office. I have good \nleadership skills and know how to get those in charge to carry out \nan order. I like to be praised for my abilities.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","positive":"I am a lawman and I am proud of my office. I have good leadership skills and know how to get those in charge to carry out an order. I like to be praised for my abilities.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"TStf9yBvxAYnlsY8","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"gift-descriptor","sequence":2}},"system":{"description":"Years of working as a bounty hunter have made me adept at \nhunting down and eliminating villains. When I am one step away \nfrom my goal, I do not consider retreating.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","positive":"Years of working as a bounty hunter have made me adept at hunting down and eliminating villains. When I am one step away from my goal, I do not consider retreating.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"XIHfYY5YuJoSWgj2","name":"Collect Taxes","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"don1.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"gift","sequence":1}},"system":{"description":"At the end of each Scene, you receive 1 Taxes Token \nif you have discovered riches or secrets related to a location or NPC that \nyou can use to your advantage (at the Storyteller’s discretion). Y ou start \neach Scenario with 1 Taxes Token. At any time, you can spend 1 Taxes \nToken to activate one of these effects:\n1. Ask the Storyteller to reveal an NPC’s Gift or Equipment.\n2. Allow an ally to activate a Gift by replacing a special requirement or \nSoma cost.\n3. Confer 1 Additional Success to the action of an allied Hunter.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","somaCost":0,"automaticSuccesses":0,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"don1.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"OsL2e5heNRVFN2Xj","name":"Lawman","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"don2.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"gift","sequence":2}},"system":{"description":"Y ou can spend 1 Soma to assert your authority over \nordinary people. NPCs who recognize local authority will not try to \nharm you unless you act aggressively first. Even in cases of conflict, they \nwill avoid choosing you as a target unless you are the first to threaten \nthem. Y ou gain 1 Additional Success if you try to convince or intimidate \nsomeone who recognizes authority.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","somaCost":0,"automaticSuccesses":0,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"don2.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"lcWPwyvpJRdSPAGg","name":"Dark Ego - Capture the Outlaws","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"darkego.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"dark-ego","sequence":0}},"system":{"description":"Under your leadership, evildoers \nare short-lived. Receive 2 Taxes Tokens. At any time during the Scene, \nyou can spend 1 Taxes Token to activate the following additional effects. \nEach effect can only be activated once per Exchange:\n1. Allow one of your allies to act immediately to carry out one of your \norders, even if they have already acted in the Exchange.\n2. Gain 2 Additional Successes for any action you take to stop (not \neliminate) a criminal or prevent his escape.\n3. Reveal an aspect of an NPC’s private business to your advantage, \nsuch as a connection to another NPC or what they are trying to \nprotect at all costs.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","somaCost":0,"automaticSuccesses":0,"trigger":"Act to capture or render harmless subjects you deem evil.","owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"darkego.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"gfLyHfJ0FZEZsuG8","name":"A short sword","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment1.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":1}},"system":{"description":"A short sword","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment1.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"KfommoUcuu1kkAfk","name":"A black powder pistol","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment2.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":2}},"system":{"description":"A black powder pistol","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment2.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"GJBOAuf1YIzfWbCk","name":"A long cloak of green cloth","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment3.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":3}},"system":{"description":"A long cloak of green cloth","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment3.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"lOMEjVMCFJtWpUWW","name":"A bag full of coins","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment4.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":4}},"system":{"description":"A bag full of coins","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment4.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"f8Q0uKE5KWmSnvGh","name":"Handcuffs of thick metal","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment5.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":5}},"system":{"description":"Handcuffs of thick metal","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment5.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"tt7Eimj16onaKamE","name":"Coats of arms and medals earned in service","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment6.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":6}},"system":{"description":"Coats of arms and medals earned in service","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment6.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"0qUmVitirzgBG1Dh","name":"A fine cross necklace given me by my old flame Marian","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment7.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":7}},"system":{"description":"A fine cross necklace given me by my old flame Marian","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment7.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"PYORs8yfnEn7LvcN","name":"A certificate of merit penned by a prince","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"equipment8.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"equipment","sequence":8}},"system":{"description":"A certificate of merit penned by a prince","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.","quantity":1,"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"equipment8.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}},{"_id":"CmWfnTYyfJxyTH90","name":"Source Sheet","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","contentKey":"source.captain-william-of-nottingham","ownerKey":"cazador.captain-william-of-nottingham","role":"source","sequence":0}},"system":{"description":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.</p>","notes":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22","owner":"Captain William of Nottingham","source":"Lost Stories","category":"hunter","key":"source.captain-william-of-nottingham"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"pregenSlug":"lost-stories-captain-william-of-nottingham","pregenCollection":"Lost Stories","source":"bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf","pages":"22"}},"system":{"details":{"concept":"Lost Stories","origin":"Captain William of Nottingham","role":"Hunter of the Order","notes":"<p><strong>Lost Stories</strong></p><p>bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 22.</p>"},"resources":{"soma":{"value":6,"max":6},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241655,"modifiedTime":1783973241655,"lastModifiedBy":null,"exportSource":null}}
{"_id":"uzsHDab5MqNJ17cK","name":"Pietrik and the Cauldron Fae","type":"hunter","img":"systems/broken-tales/assets/avatars/pregens/lost-stories-pietrik-and-the-cauldron-fae.png","items":[{"_id":"Z4jOeoIwo14c5FOI","name":"Descriptor 1","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"descriptor-principal.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"principal-descriptor","sequence":0}},"system":{"description":"I am a rebel who is used to living on the streets. I know my way \naround the slums and how to deal with the lowlifes. Rules are \nmade to be broken.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","positive":"I am a rebel who is used to living on the streets. I know my way around the slums and how to deal with the lowlifes. Rules are made to be broken.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"descriptor-principal.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"I5BL6gQwKNgHakLi","name":"Descriptor 2","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"descriptor1-don1.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"gift-descriptor","sequence":1}},"system":{"description":"I fear nothing and throw myself into any situation. The \nadrenaline of risk drives me to succeed. I get bored easily in \nsituations where there is no danger.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","positive":"I fear nothing and throw myself into any situation. The adrenaline of risk drives me to succeed. I get bored easily in situations where there is no danger.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"descriptor1-don1.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"FCh9rrchtm457Cyi","name":"Descriptor 3","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"descriptor2-don2.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"gift-descriptor","sequence":2}},"system":{"description":"The Cauldron Fae is always with me, in the form of a small \nfloating light. Her magic is still powerful, and I often summon \nher to wreak havoc or play tricks on humans.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","positive":"The Cauldron Fae is always with me, in the form of a small floating light. Her magic is still powerful, and I often summon her to wreak havoc or play tricks on humans.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"descriptor2-don2.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"QS9nXrlGJAOEp5rR","name":"Lost Childhood","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"don1.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"gift","sequence":1}},"system":{"description":"Despite your young age, you have no qualms about \ntaking action against enemies. Y ou gain 1 Additional Success in all \nactions that require the use of subterfuge. If you attack a target that is \nunaware of your presence, you inflict 1 Additional Wound.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"don1.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"03cqwQwlZD4hln7Z","name":"Fearless","type":"gift","img":"systems/broken-tales/assets/icons/icon-gift.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"don2.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"gift","sequence":2}},"system":{"description":"Y ou are immune to any fear or mind control effects that \nprevent you from acting as you wish. If you suffer 1 Wound from an \nOpponent or Threat, you may regain 1 Soma in your next action and \nmay consider a Failure as an Outcome with a Cost.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"don2.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"jrhciskWJEFbXPph","name":"Dark Ego - The Magic of Disbelief","type":"darkEgo","img":"icons/svg/terror.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"darkego.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"dark-ego","sequence":0}},"system":{"description":"The Cauldron Fae unleashes \nher magic to enable you to perform amazing actions. As an action, \nyou can formulate a magic sentence including the fragment I don’t \nbelieve and make its effect concrete. For example, “I don’t believe in \ngravity” would allow you to fly, while “I don’t believe the Hunters of \nthe Order exist” would allow you to hurt the Hunters in an attempt to \nmake them disappear. If your statement has no offensive effect, spend \n1 Soma to gain the power you summoned for the entire Scene. On \nthe other hand, if you want the spell to affect a target \nother than yourself, spend 1 Soma \nto inflict a Wound or apply the effect without making a Check. Each \ntime you use the Magic of Disbelief, roll a die. On a roll of 5 or 6, the \nStoryteller gains 1 Prank Token. The Storyteller can spend 1 Prank \nToken during a Scene to activate the effect of this Gift (you do not take a \nWound because the Activator was not normally triggered) and have the \nCauldron Fae cast a spell to complicate your life or attempt to damage \nsomething that represents progress and modernity. If the Storyteller has \nno accumulated Prank Tokens, you may choose to ignore all the Soma \ncosts to activate the effects of this Gift, but the Storyteller will gain 1 \nPrank Token.","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","somaCost":0,"automaticSuccesses":0,"trigger":"Without thinking about the possible consequences, throw \nyourself into an action that is impossible for an ordinary person.","owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"darkego.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241652,"modifiedTime":1783973241652,"lastModifiedBy":null,"exportSource":null}},{"_id":"Nt5t7dzFTYHa3DLN","name":"A dueling blade","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"equipment1.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"equipment","sequence":1}},"system":{"description":"A dueling blade","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","quantity":1,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"equipment1.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"YblIYcDJirwaSvqi","name":"A book of fairytales given to me by Gwendolyn, the only person I consider a friend","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"equipment2.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"equipment","sequence":2}},"system":{"description":"A book of fairytales given to me by Gwendolyn, the only person I consider a friend","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","quantity":1,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"equipment2.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"cGpqH0ISzqnEk6Gy","name":"A necklace with a little bell","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":"equipment3.pietrik-and-the-cauldron-fae","ownerKey":"cazador.pietrik-and-the-cauldron-fae","role":"equipment","sequence":3}},"system":{"description":"A necklace with a little bell","notes":"See bt-ls-hunters-sheets-1.2-eng-BASE-SCREEN.pdf, pages 8.","quantity":1,"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","key":"equipment3.pietrik-and-the-cauldron-fae"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1783973241653,"modifiedTime":1783973241653,"lastModifiedBy":null,"exportSource":null}},{"_id":"itqrBSGRWfeoIe5C","name":"A worn pirate flag I keep as a trophy","type":"equipment","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pietrik and the Cauldron Fae","source":"Lost Stories","category":"hunter","contentKey":
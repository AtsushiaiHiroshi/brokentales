":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-hazir-s-guards-163","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":163,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are well-trained in the protection of our \nmaster.\nAgenda: Protect Hazir from all threats / Eliminate the beggar who persecutes our master.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Protect Hazir from all threats / Eliminate the beggar who persecutes our master.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642583,"modifiedTime":1781557642583,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Mf1DhZTEW6pPnftV","name":"The Village Elders 1: Asmo","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"hc20s2YzmAk1QgfY","name":"The Village Elders 1: Asmo - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Village Elders 1: Asmo","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am the leader of the elders, and my word is \nfinal when there is disagreement.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 118.","positive":"I am the leader of the elders, and my word is \nfinal when there is disagreement.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Village Elders 1: Asmo","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640522,"modifiedTime":1781557640522,"lastModifiedBy":null,"exportSource":null}},{"_id":"D3yera7517M0cQFK","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Village Elders 1: Asmo","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am the leader of the elders, and my word is \nfinal when there is disagreement.\nAgenda: To serve Nikola by reporting everything that happens in the village / To keep outside attention away from Rovaniemi and prevent Nikola from being forced to harm the \nvillagers.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 118.","owner":"The Village Elders 1: Asmo","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640522,"modifiedTime":1781557640522,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-the-village-elders-1-asmo-118","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":118,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am the leader of the elders, and my word is \nfinal when there is disagreement.\nAgenda: To serve Nikola by reporting everything that happens in the village / To keep outside attention away from Rovaniemi and prevent Nikola from being forced to harm the \nvillagers.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To serve Nikola by reporting everything that happens in the village / To keep outside attention away from Rovaniemi and prevent Nikola from being forced to harm the \nvillagers.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640522,"modifiedTime":1781557640522,"lastModifiedBy":null,"exportSource":null}}
{"_id":"NHa7KURLH2MrZzTW","name":"Conquers Death for Love","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"DPRZR6rJcAfryZ44","name":"Conquers Death for Love - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Conquers Death for Love","source":"Isolde the Singer of Lost Love","category":"threat"}},"system":{"description":"<p>I am a knight devoted to my beloved Isolde \nand have returned from the dead to protect her.</p>","notes":"Isolde the Singer of Lost Love - bt-ls-book-1-ENG-SCREEN.pdf, page 172.","positive":"I am a knight devoted to my beloved Isolde \nand have returned from the dead to protect her.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Conquers Death for Love","source":"Isolde the Singer of Lost Love","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643132,"modifiedTime":1781557643132,"lastModifiedBy":null,"exportSource":null}},{"_id":"hRn8C5I5Z8hXyvvV","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Conquers Death for Love","source":"Isolde the Singer of Lost Love","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a knight devoted to my beloved Isolde \nand have returned from the dead to protect her. \nAgenda: Defend Isolde from those who would harm her.\nGift - Immortal Love: Tristan is immune to all Wounds \nas long as Isolde has at least 1 Wound. The only way to \neliminate the Knight is to reduce Isolde to 0 Wounds, causing Tristan’s immediate destruction. When Tristan attacks \na target that has wounded Isolde, he increases his OL by 1 \nand inflicts 2 Wounds. \n•\nHow to handle Isolde the Singer of \nLost Love\nWhen Isolde enters the Scene, the Storyteller decides or \nrolls a die to see which NPC she possesses. Using this advantage, Isolde will deliberately try to create problems, using any hurt feelings caused by the actions of the NPCs or \nHunters involved in the Encounter. At the end of the Encounter, Isolde will evaluate how the Hunters acted based \non two parameters:\n ◆ If the Hunters take feelings into consideration and help \nthose in need even at the expense of their personal \ngoals, Isolde will not report them to the One Who Plots \nin the Shadows. \n ◆ If the Hunters did not care about the feelings of others, Isolde will punish them by reporting information \nabout them to The One Who Plots in the Shadows, \nwhich the Storyteller can use in the final confrontation \nof the Campaign or to better prepare a future Assassin \n(page 249 of the Broken Tales Core Book). Isolde receives Betrayed Love Tokens equal to half the number \nof Hunters directly involved (rounded down). She can \nuse the Tokens in the confrontation with the Hunters \nwhen she activates the Gift - Punish Those Who Despise Love. \nHunters can recognize Isolde’s presence by certain details \nthat the spirit includes when she possesses an NPC or appears as herself. She should have a certain way of speaking \nor an attitude that will be characteristic of any possessed \nNPC, regardless of their background or social status. When \nthe Hunters ask questions about the strange behavior, Isolde will either play dumb or try to shift the focus to the \nproblems she is creating for the Hunters to solve. \nIf the Hunters decide to corner the NPC because they realize something is wrong, Isolde will appear suddenly to activate her Gift - Punish Those Who Despise Love. \nNote: Introducing Isolde during an Encounter may require \na small amount of planning on the part of the Storyteller; \nwe have included a series of tables that can provide useful \nhooks for Isolde’s management.</p>","notes":"Isolde the Singer of Lost Love - bt-ls-book-1-ENG-SCREEN.pdf, page 172.","owner":"Conquers Death for Love","source":"Isolde the Singer of Lost Love","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643132,"modifiedTime":1781557643132,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-isolde-the-singer-of-lost-love-conquers-death-for-love-172","collection":"Lost Stories","adventureSlug":"isolde-the-singer-of-lost-love","adventureTitle":"Isolde the Singer of Lost Love","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":172,"role":"Minor NPC"}},"system":{"details":{"concept":"Isolde the Singer of Lost Love","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a knight devoted to my beloved Isolde \nand have returned from the dead to protect her. \nAgenda: Defend Isolde from those who would harm her.\nGift - Immortal Love: Tristan is immune to all Wounds \nas long as Isolde has at least 1 Wound. The only way to \neliminate the Knight is to reduce Isolde to 0 Wounds, causing Tristan’s immediate destruction. When Tristan attacks \na target that has wounded Isolde, he increases his OL by 1 \nand inflicts 2 Wounds. \n•\nHow to handle Isolde the Singer of \nLost Love\nWhen Isolde enters the Scene, the Storyteller decides or \nrolls a die to see which NPC she possesses. Using this advantage, Isolde will deliberately try to create problems, using any hurt feelings caused by the actions of the NPCs or \nHunters involved in the Encounter. At the end of the Encounter, Isolde will evaluate how the Hunters acted based \non two parameters:\n ◆ If the Hunters take feelings into consideration and help \nthose in need even at the expense of their personal \ngoals, Isolde will not report them to the One Who Plots \nin the Shadows. \n ◆ If the Hunters did not care about the feelings of others, Isolde will punish them by reporting information \nabout them to The One Who Plots in the Shadows, \nwhich the Storyteller can use in the final confrontation \nof the Campaign or to better prepare a future Assassin \n(page 249 of the Broken Tales Core Book). Isolde receives Betrayed Love Tokens equal to half the number \nof Hunters directly involved (rounded down). She can \nuse the Tokens in the confrontation with the Hunters \nwhen she activates the Gift - Punish Those Who Despise Love. \nHunters can recognize Isolde’s presence by certain details \nthat the spirit includes when she possesses an NPC or appears as herself. She should have a certain way of speaking \nor an attitude that will be characteristic of any possessed \nNPC, regardless of their background or social status. When \nthe Hunters ask questions about the strange behavior, Isolde will either play dumb or try to shift the focus to the \nproblems she is creating for the Hunters to solve. \nIf the Hunters decide to corner the NPC because they realize something is wrong, Isolde will appear suddenly to activate her Gift - Punish Those Who Despise Love. \nNote: Introducing Isolde during an Encounter may require \na small amount of planning on the part of the Storyteller; \nwe have included a series of tables that can provide useful \nhooks for Isolde’s management.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Defend Isolde from those who would harm her.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643132,"modifiedTime":1781557643132,"lastModifiedBy":null,"exportSource":null}}
{"_id":"NMAauDUqMInvu8jC","name":"The Thieves","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"4AmSHJ5IXXVHAix1","name":"The Thieves - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>We are looters, skilled with scimitar and sling. \nOur numbers are our strength.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","positive":"We are looters, skilled with scimitar and sling. \nOur numbers are our strength.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}},{"_id":"oKCIUucLCrhIFZ5w","name":"Gift - Band of Thieves","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>A Thief increases their OL by 1 \nas long as the total number of band members is greater than \nthe total number of enemies. \nThe Oasis</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","somaCost":0,"automaticSuccesses":0,"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}},{"_id":"Rcy46Bg2RBqZKZsm","name":"Gift - The Lair","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>While fighting inside the Oasis, Thieves \ncan benefit from the improvements they have made to the \nplace. Once per Exchange, one of these effects will be activated:</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","somaCost":0,"automaticSuccesses":0,"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}},{"_id":"pb5Oz41MXmmwo36J","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are looters, skilled with scimitar and sling. \nOur numbers are our strength.\nAgenda: Protect our lair and discover the password to enter, \nwhich only our late leader knew.\nGift - Band of Thieves: A Thief increases their OL by 1 \nas long as the total number of band members is greater than \nthe total number of enemies. \nThe Oasis \nDescriptor: A large, lush oasis that the Thieves have transformed into the perfect hideout. \nGift - The Lair: While fighting inside the Oasis, Thieves \ncan benefit from the improvements they have made to the \nplace. Once per Exchange, one of these effects will be activated:</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","owner":"The Thieves","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-thieves-162","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":162,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are looters, skilled with scimitar and sling. \nOur numbers are our strength.\nAgenda: Protect our lair and discover the password to enter, \nwhich only our late leader knew.\nGift - Band of Thieves: A Thief increases their OL by 1 \nas long as the total number of band members is greater than \nthe total number of enemies. \nThe Oasis \nDescriptor: A large, lush oasis that the Thieves have transformed into the perfect hideout. \nGift - The Lair: While fighting inside the Oasis, Thieves \ncan benefit from the improvements they have made to the \nplace. Once per Exchange, one of these effects will be activated:</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Protect our lair and discover the password to enter, \nwhich only our late leader knew.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}}
{"_id":"OoVt4RfL76CcCH7J","name":"Fairies (The King's Awakening)","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"5Ao82gvjPMkf8ql2","name":"Fairies - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Fairies (The King's Awakening)","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>We are fairies and we love company and good \nstories. We like humans, even though they tend to age too fast \nby our standards.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 196.","positive":"We are fairies and we love company and good \nstories. We like humans, even though they tend to age too fast \nby our standards.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Fairies (The King's Awakening)","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644332,"modifiedTime":1781557644332,"lastModifiedBy":null,"exportSource":null}},{"_id":"1Ry5Fs4FP4aFD1ry","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Fairies (The King's Awakening)","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Minor NPCs (1 Wound)\nDescriptor: We are fairies and we love company and good \nstories. We like humans, even though they tend to age too fast \nby our standards. \nAgenda: Entertain nice people for as long as possible. \nGift - A Midsummer Night’s Dream: Talking to Fairies for a long time can be fatal for a human, as time passes \nfaster in their presence. After a minute of conversation, the \nsubject can make a Defense Check to see if they are getting \nold. If successful, the subject can end the conversation. If \nunsuccessful, the subject loses 2 Soma, and if the subject is \nalready at 0 Soma, the subject loses 1 Wound. Succeeding \nwith a Cost is possible, but the easiest way to interrupt the \neffect of the Gift is to feel pain, so the Cost will always be \n1 Wound. A new Check can be made after each minute of \nconversation. An outside party may attempt to break the effect of this Gift with words (Position Check) or by inflicting \n1 Wound (Automatic).\nFairy information:\n ◆ They come from the great lake where the house once \nstood, the home of the Lady who cared for all the magical creatures on the island. The Lady then decided \nto leave, fed up with the many brave young men who \ncame to the lake, insistent on gaining her blessing.\n ◆ The Fairies have always stayed to guard the Lake, but \non the day the Hunters arrived, a grumpy old man who \nclearly looked like a Sorcerer appeared at the lake accompanied by a huge knight in armor as black as night. \nThe old man frightened off the Fairies, who, peering \nfrom a distance, clearly saw the two of them walking \nalong the shores of the Lake, searching for something.\n ◆ The island contains many illusions that prevent ordinary mortals from discovering certain truths. The Fairies possess a Fairy Crystal that allows those who look \nthrough it to see the illusions. They are willing to give \nup the Crystal, but only in exchange for something of \nequal value. If the Hunters do not know what to propose, the Fairies will say that a beautiful treasure is \nguarded by a Knight in the Forest to the east.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 196.","owner":"Fairies (The King's Awakening)","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644332,"modifiedTime":1781557644332,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-fairies-196","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":196,"role":"Minor NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPCs (1 Wound)\nDescriptor: We are fairies and we love company and good \nstories. We like humans, even though they tend to age too fast \nby our standards. \nAgenda: Entertain nice people for as long as possible. \nGift - A Midsummer Night’s Dream: Talking to Fairies for a long time can be fatal for a human, as time passes \nfaster in their presence. After a minute of conversation, the \nsubject can make a Defense Check to see if they are getting \nold. If successful, the subject can end the conversation. If \nunsuccessful, the subject loses 2 Soma, and if the subject is \nalready at 0 Soma, the subject loses 1 Wound. Succeeding \nwith a Cost is possible, but the easiest way to interrupt the \neffect of the Gift is to feel pain, so the Cost will always be \n1 Wound. A new Check can be made after each minute of \nconversation. An outside party may attempt to break the effect of this Gift with words (Position Check) or by inflicting \n1 Wound (Automatic).\nFairy information:\n ◆ They come from the great lake where the house once \nstood, the home of the Lady who cared for all the magical creatures on the island. The Lady then decided \nto leave, fed up with the many brave young men who \ncame to the lake, insistent on gaining her blessing.\n ◆ The Fairies have always stayed to guard the Lake, but \non the day the Hunters arrived, a grumpy old man who \nclearly looked like a Sorcerer appeared at the lake accompanied by a huge knight in armor as black as night. \nThe old man frightened off the Fairies, who, peering \nfrom a distance, clearly saw the two of them walking \nalong the shores of the Lake, searching for something.\n ◆ The island contains many illusions that prevent ordinary mortals from discovering certain truths. The Fairies possess a Fairy Crystal that allows those who look \nthrough it to see the illusions. They are willing to give \nup the Crystal, but only in exchange for something of \nequal value. If the Hunters do not know what to propose, the Fairies will say that a beautiful treasure is \nguarded by a Knight in the Forest to the east.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Entertain nice people for as long as possible.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644332,"modifiedTime":1781557644332,"lastModifiedBy":null,"exportSource":null}}
{"_id":"QMRqZrZG0fuwdBiq","name":"Restless Spirit","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"t2xCr9VOHgh0FV8m","name":"Restless Spirit - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>I am the spirit of a person who died under \nunpleasant circumstances. I hate life and only want to \nharm the living with my powers.</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 68.","positive":"I am the spirit of a person who died under \nunpleasant circumstances. I hate life and only want to \nharm the living with my powers.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}},{"_id":"O0uxUxh28vjbCdIP","name":"Gift - Spiritic Power","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>The Restless Spirit can only \nbe permanently Wounded by magic. Wounds inflicted \nby other means may disperse the Spirit in the current \nScene, but it may return in another Scene with Wounds \ninflicted by mundane methods restored. The spirit can \nact 2 times during an Exchange, but not consecutively. \nAlthough intangible, the spirit can use its ghostly powers to push or grab people and objects.\n6: The Baron of the mansion: The Spirit is very distracted, \nand to keep his attention focused, it is necessary to over -\ncome the Head in the Clouds Threat. \nThreat - Head in the Clouds</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 68.","somaCost":0,"automaticSuccesses":0,"owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}},{"_id":"VHY28EDE1TVZRzEB","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am the spirit of a person who died under \nunpleasant circumstances. I hate life and only want to \nharm the living with my powers.\nGift - Spiritic Power: The Restless Spirit can only \nbe permanently Wounded by magic. Wounds inflicted \nby other means may disperse the Spirit in the current \nScene, but it may return in another Scene with Wounds \ninflicted by mundane methods restored. The spirit can \nact 2 times during an Exchange, but not consecutively. \nAlthough intangible, the spirit can use its ghostly powers to push or grab people and objects.\n6: The Baron of the mansion: The Spirit is very distracted, \nand to keep his attention focused, it is necessary to over -\ncome the Head in the Clouds Threat. \nThreat - Head in the Clouds</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 68.","owner":"Restless Spirit","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-rome-city-of-the-order-restless-spirit-68","collection":"Lost Stories","adventureSlug":"rome-city-of-the-order","adventureTitle":"Rome, City of the Order","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":68,"role":"Minor NPC"}},"system":{"details":{"concept":"Rome, City of the Order","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am the spirit of a person who died under \nunpleasant circumstances. I hate life and only want to \nharm the living with my powers.\nGift - Spiritic Power: The Restless Spirit can only \nbe permanently Wounded by magic. Wounds inflicted \nby other means may disperse the Spirit in the current \nScene, but it may return in another Scene with Wounds \ninflicted by mundane methods restored. The spirit can \nact 2 times during an Exchange, but not consecutively. \nAlthough intangible, the spirit can use its ghostly powers to push or grab people and objects.\n6: The Baron of the mansion: The Spirit is very distracted, \nand to keep his attention focused, it is necessary to over -\ncome the Head in the Clouds Threat. \nThreat - Head in the Clouds</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}}
{"_id":"QRMoJUQwFHOGBjsf","name":"Rikke the Nomad","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"6V7JzdVL854azQyU","name":"Rikke the Nomad - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Rikke the Nomad","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a northern nomad and have always tried \nto lead my companions on the right path. I am used to the \nhard life of the forest and know how to move and hunt well.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 216.","positive":"I am a northern nomad and have always tried \nto lead my companions on the right path. I am used to the \nhard life of the forest and know how to move and hunt well.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Rikke the Nomad","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645651,"modifiedTime":1781557645651,"lastModifiedBy":null,"exportSource":null}},{"_id":"WqgGXRbfBXy0ecdx","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Rikke the Nomad","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a northern nomad and have always tried \nto lead my companions on the right path. I am used to the \nhard life of the forest and know how to move and hunt well.\nAgenda: To make my nomadic family prosperous. \nShard Descriptor: I am a nomad from the north, \ntrying to accumulate as much wealth as possible in order to \nmove to a more hospitable climate. I hate the hard life in these \nlatitudes and to survive I exploit my faithful companions. \nShard Agenda: Gather as much wealth as I can \nthrough banditry and then run far away, leaving my entire \nclan to their fate. \nGift - Power of the Shard: The Shard of the Mirror of the \nOther Self reverses the Descriptor and Agenda of the person \nit injured. The holder increases their OL by 1 if they act in accordance with the altered part of their Descriptor or Agenda. \n3</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 216.","owner":"Rikke the Nomad","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645651,"modifiedTime":1781557645651,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-rikke-the-nomad-216","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":216,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a northern nomad and have always tried \nto lead my companions on the right path. I am used to the \nhard life of the forest and know how to move and hunt well.\nAgenda: To make my nomadic family prosperous. \nShard Descriptor: I am a nomad from the north, \ntrying to accumulate as much wealth as possible in order to \nmove to a more hospitable climate. I hate the hard life in these \nlatitudes and to survive I exploit my faithful companions. \nShard Agenda: Gather as much wealth as I can \nthrough banditry and then run far away, leaving my entire \nclan to their fate. \nGift - Power of the Shard: The Shard of the Mirror of the \nOther Self reverses the Descriptor and Agenda of the person \nit injured. The holder increases their OL by 1 if they act in accordance with the altered part of their Descriptor or Agenda. \n3</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To make my nomadic family prosperous. \nShard Descriptor: I am a nomad from the north, \ntrying to accumulate as much wealth as possible in order to \nmove to a more hospitable climate. I hate the hard life in these \nlatitudes and to survive I exploit my faithful companions. \nShard Agenda: Gather as much wealth as I can \nthrough banditry and then run far away, leaving my entire \nclan to their fate.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645651,"modifiedTime":1781557645651,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Qmx0mCECyz9piL8t","name":"City Guards","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"XJtZ4mmQYRKJBaXZ","name":"City Guards - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"City Guards","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>We are skilled soldiers defending the city.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","positive":"We are skilled soldiers defending the city.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"City Guards","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}},{"_id":"MniOX5K5ziL6VJXD","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"City Guards","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are skilled soldiers defending the city. \nAgenda: We obey Aladdin’s orders because we fear his \nwrath, but we also want to stop his madness. \nJasmina the Brave</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","owner":"City Guards","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-city-guards-160","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":160,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are skilled soldiers defending the city. \nAgenda: We obey Aladdin’s orders because we fear his \nwrath, but we also want to stop his madness. \nJasmina the Brave</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"We obey Aladdin’s orders because we fear his \nwrath, but we also want to stop his madness. \nJasmina the Brave","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}
{"_id":"R8rbit29JCWlGupr","name":"Columns of Eternal Sleep","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"ivRi42zV3cVTu8u7","name":"Columns of Eternal Sleep - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>A column of magical ice capable of absorbing \nliving things and enveloping them in a deadly frost.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 222.","positive":"A column of magical ice capable of absorbing \nliving things and enveloping them in a deadly frost.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645979,"modifiedTime":1781557645979,"lastModifiedBy":null,"exportSource":null}},{"_id":"OxC07sakoCfXHC5p","name":"Gift - Glacial Embrace","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>A target that fails a Check when \nthe column tries to absorb them is wrapped in ice and takes \n1 Wound. During each action, the encased subject can attempt to free themselves by making a Position Check, suffering 1 Wound if they fail. When they run out of Wounds, \nthe target is completely absorbed by the column. An NPC \nautomatically suffers 1 Wound with each of its actions until it has consumed all of its Wounds. At the Storyteller’s \ndiscretion, a particularly skilled NPC may choose to free \nthemselves with one of their actions. \nENCOUNTER ROOM – Me-morial Church</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 222.","somaCost":0,"automaticSuccesses":0,"owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645979,"modifiedTime":1781557645979,"lastModifiedBy":null,"exportSource":null}},{"_id":"wmyYU8xMrwNNj4ST","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>Descriptor: A column of magical ice capable of absorbing \nliving things and enveloping them in a deadly frost.\nGift - Glacial Embrace: A target that fails a Check when \nthe column tries to absorb them is wrapped in ice and takes \n1 Wound. During each action, the encased subject can attempt to free themselves by making a Position Check, suffering 1 Wound if they fail. When they run out of Wounds, \nthe target is completely absorbed by the column. An NPC \nautomatically suffers 1 Wound with each of its actions until it has consumed all of its Wounds. At the Storyteller’s \ndiscretion, a particularly skilled NPC may choose to free \nthemselves with one of their actions. \nENCOUNTER ROOM – Me-morial Church\nDescriptor: A large Gothic church made entirely of ice. \nSmall snowflakes fall from the large vault in the ceiling and \nfloat gently to the ground. \nInformation: The snowflakes are imbued with Lady \nStorm’s power and are capable of erasing the memory of \nthose they touch. If a subject does not find a way to protect \nthemselves from contact, they will suffer the effect of the \nThreat - Snow of Memory. In the main altar is a large shrine \nwith an object inside: this is a Treasure of the Order, which \nthe Storyteller must choose at will from those presented \nfrom page 19. It takes two minutes to sprint through the \nChurch.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 222.","owner":"Columns of Eternal Sleep","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645979,"modifiedTime":1781557645979,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-columns-of-eternal-sleep-222","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":222,"role":"Threat"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A column of magical ice capable of absorbing \nliving things and enveloping them in a deadly frost.\nGift - Glacial Embrace: A target that fails a Check when \nthe column tries to absorb them is wrapped in ice and takes \n1 Wound. During each action, the encased subject can attempt to free themselves by making a Position Check, suffering 1 Wound if they fail. When they run out of Wounds, \nthe target is completely absorbed by the column. An NPC \nautomatically suffers 1 Wound with each of its actions until it has consumed all of its Wounds. At the Storyteller’s \ndiscretion, a particularly skilled NPC may choose to free \nthemselves with one of their actions. \nENCOUNTER ROOM – Me-morial Church\nDescriptor: A large Gothic church made entirely of ice. \nSmall snowflakes fall from the large vault in the ceiling and \nfloat gently to the ground. \nInformation: The snowflakes are imbued with Lady \nStorm’s power and are capable of erasing the memory of \nthose they touch. If a subject does not find a way to protect \nthemselves from contact, they will suffer the effect of the \nThreat - Snow of Memory. In the main altar is a large shrine \nwith an object inside: this is a Treasure of the Order, which \nthe Storyteller must choose at will from those presented \nfrom page 19. It takes two minutes to sprint through the \nChurch.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645979,"modifiedTime":1781557645979,"lastModifiedBy":null,"exportSource":null}}
{"_id":"RpyYQ46DbpXXGaT0","name":"Eyes of Aladdin","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"RkevbrbcWPtt77SJ","name":"Eyes of Aladdin - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Magic eyes that keep watch on the whole city.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 161.","positive":"Magic eyes that keep watch on the whole city.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642536,"modifiedTime":1781557642536,"lastModifiedBy":null,"exportSource":null}},{"_id":"TrlGL92cVXkzuR1C","name":"Gift - Big Brother","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>At the beginning of each Scene, a \nstranger in the city must make a Defense Check against this \nThreat. Roll 1 die and apply the result to all subjects who \nfailed.\n1-2: Aladdin learns 1 Gift of the observed subject. During \na confrontation with Aladdin, the learned Gift is automatically considered blocked by the third effect of the Gift - \nWishing Lamp. \n3-4: Aladdin turns an unsuspecting passerby into a Monster to attack the foreigners. \n5-6: A lightning bolt springs from the eye, dealing 1 \nWound to the target. A Defense Check can prevent this effect.\n4B The Forty Thieves\nThe story that led us here...\nThe ship lands on a large, mostly deserted island with only \none town. In the harbor, the Hunters meet Baba, a poor man \nbegging for help in rescuing his brother, who has been kidnapped by a band of terrible Thieves. They live in an oasis \nnear the city, but no one has ever been able to pinpoint the \nexact location of their lair. Baba knows the magic word to \naccess the hideout, having heard his brother speak of it. He \nwill lead the Hunters to the oasis, promising them a share of \nthe Thieves’ treasure as a reward. \nPlace: A large oasis in the desert, full of palm trees and \nwaterholes.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 161.","somaCost":0,"automaticSuccesses":0,"owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642536,"modifiedTime":1781557642536,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZUf9G1mNXrwcCmvR","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Descriptor: Magic eyes that keep watch on the whole city. \nGift - Big Brother: At the beginning of each Scene, a \nstranger in the city must make a Defense Check against this \nThreat. Roll 1 die and apply the result to all subjects who \nfailed.\n1-2: Aladdin learns 1 Gift of the observed subject. During \na confrontation with Aladdin, the learned Gift is automatically considered blocked by the third effect of the Gift - \nWishing Lamp. \n3-4: Aladdin turns an unsuspecting passerby into a Monster to attack the foreigners. \n5-6: A lightning bolt springs from the eye, dealing 1 \nWound to the target. A Defense Check can prevent this effect.\n4B The Forty Thieves\nThe story that led us here...\nThe ship lands on a large, mostly deserted island with only \none town. In the harbor, the Hunters meet Baba, a poor man \nbegging for help in rescuing his brother, who has been kidnapped by a band of terrible Thieves. They live in an oasis \nnear the city, but no one has ever been able to pinpoint the \nexact location of their lair. Baba knows the magic word to \naccess the hideout, having heard his brother speak of it. He \nwill lead the Hunters to the oasis, promising them a share of \nthe Thieves’ treasure as a reward. \nPlace: A large oasis in the desert, full of palm trees and \nwaterholes. \nInformation: In fact, Baba has already killed most of the \nThieves with the help of Dirana, a skilled slave girl in his \nservice. However, the woman is trapped in the gang’s secret \nlair, and Baba plans to free her and recover the treasure. His \ngoal is to get the Hunters to fight the remaining ten Thieves \nand lock himself in their lair, waiting for the survivors of \nthe battle to leave. Baba will not tell anyone how to open the \nlair, saying that he cannot fully trust the Hunters without a \ndemonstration of their good faith. \nChallenges: Confront the ten remaining Thieves, preventing Baba from entering the secret lair alone and closing \nthe door behind him. Dirana is a fearsome fighter and, once \nfreed, will face the Hunters to defend her master.\nHow to get the Tarì: If Baba fails to lock himself in the \ncave, he will offer the coin to the Hunters for their services, \nbegging them to let him live. \nBaba the Poor Conman</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 161.","owner":"Eyes of Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642536,"modifiedTime":1781557642536,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-eyes-of-aladdin-161","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":161,"role":"Threat"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: Magic eyes that keep watch on the whole city. \nGift - Big Brother: At the beginning of each Scene, a \nstranger in the city must make a Defense Check against this \nThreat. Roll 1 die and apply the result to all subjects who \nfailed.\n1-2: Aladdin learns 1 Gift of the observed subject. During \na confrontation with Aladdin, the learned Gift is automatically considered blocked by the third effect of the Gift - \nWishing Lamp. \n3-4: Aladdin turns an unsuspecting passerby into a Monster to attack the foreigners. \n5-6: A lightning bolt springs from the eye, dealing 1 \nWound to the target. A Defense Check can prevent this effect.\n4B The Forty Thieves\nThe story that led us here...\nThe ship lands on a large, mostly deserted island with only \none town. In the harbor, the Hunters meet Baba, a poor man \nbegging for help in rescuing his brother, who has been kidnapped by a band of terrible Thieves. They live in an oasis \nnear the city, but no one has ever been able to pinpoint the \nexact location of their lair. Baba knows the magic word to \naccess the hideout, having heard his brother speak of it. He \nwill lead the Hunters to the oasis, promising them a share of \nthe Thieves’ treasure as a reward. \nPlace: A large oasis in the desert, full of palm trees and \nwaterholes. \nInformation: In fact, Baba has already killed most of the \nThieves with the help of Dirana, a skilled slave girl in his \nservice. However, the woman is trapped in the gang’s secret \nlair, and Baba plans to free her and recover the treasure. His \ngoal is to get the Hunters to fight the remaining ten Thieves \nand lock himself in their lair, waiting for the survivors of \nthe battle to leave. Baba will not tell anyone how to open the \nlair, saying that he cannot fully trust the Hunters without a \ndemonstration of their good faith. \nChallenges: Confront the ten remaining Thieves, preventing Baba from entering the secret lair alone and closing \nthe door behind him. Dirana is a fearsome fighter and, once \nfreed, will face the Hunters to defend her master.\nHow to get the Tarì: If Baba fails to lock himself in the \ncave, he will offer the coin to the Hunters for their services, \nbegging them to let him live. \nBaba the Poor Conman</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642536,"modifiedTime":1781557642536,"lastModifiedBy":null,"exportSource":null}}
{"_id":"RyOjMUZNEqGzcy8A","name":"The Scarred Knight","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"HHKGaPqJhsbOuhtq","name":"The Scarred Knight - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Scarred Knight","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am a former knight of the Round Table, dishonorably banished by my king for falling in love with his queen. \nMy fighting skills are unparalleled, and my face is completely \nscarred as punishment for my sins.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 185.","positive":"I am a former knight of the Round Table, dishonorably banished by my king for falling in love with his queen. \nMy fighting skills are unparalleled, and my face is completely \nscarred as punishment for my sins.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Scarred Knight","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}},{"_id":"0bhzWgU4h9s62JKS","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Scarred Knight","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a former knight of the Round Table, dishonorably banished by my king for falling in love with his queen. \nMy fighting skills are unparalleled, and my face is completely \nscarred as punishment for my sins.\nAgenda: To find my beloved Guinevere and escape Avalon \nwith her. \nInformation: The Scarred Knight is wandering in search \nof his beloved Guinevere and will make himself available to \nspeak to the Hunters. The man will say that his beloved is \ndisguised as a common Villager, but can be recognized by the \nfeather-shaped brooch he gave her as a token of his love. The \nScarred Knight will not reveal his face or name, but he promises incredible riches to Hunters who help him. If a Hunter \nhas a Descriptor related to madness or understanding the behavior of others, they will clearly understand that the Scarred \nKnight is insane, and an endless obsession burns in his eyes. \nIf the Hunters eliminate the Scarred Knight, he will not appear in Zone 11 - Town of Stow (page 197).\n Merlin’s Shadow</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 185.","owner":"The Scarred Knight","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-the-scarred-knight-185","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":185,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a former knight of the Round Table, dishonorably banished by my king for falling in love with his queen. \nMy fighting skills are unparalleled, and my face is completely \nscarred as punishment for my sins.\nAgenda: To find my beloved Guinevere and escape Avalon \nwith her. \nInformation: The Scarred Knight is wandering in search \nof his beloved Guinevere and will make himself available to \nspeak to the Hunters. The man will say that his beloved is \ndisguised as a common Villager, but can be recognized by the \nfeather-shaped brooch he gave her as a token of his love. The \nScarred Knight will not reveal his face or name, but he promises incredible riches to Hunters who help him. If a Hunter \nhas a Descriptor related to madness or understanding the behavior of others, they will clearly understand that the Scarred \nKnight is insane, and an endless obsession burns in his eyes. \nIf the Hunters eliminate the Scarred Knight, he will not appear in Zone 11 - Town of Stow (page 197).\n Merlin’s Shadow</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"To find my beloved Guinevere and escape Avalon \nwith her.","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}}
{"_id":"SCg5nazk8rKy1MT1","name":"Lene the Old Mobster","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"MJoG8Fgzfx9xZfFQ","name":"Lene the Old Mobster - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lene the Old Mobster","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am the ruthless queen of Bergen’s under -\nworld, and I have no qualms about conducting my shady \nbusiness. Everyone in the city fears me, and I use my reputation to intimidate those foolish enough to turn against me.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 209.","positive":"I am the ruthless queen of Bergen’s under -\nworld, and I have no qualms about conducting my shady \nbusiness. Everyone in the city fears me, and I use my reputation to intimidate those foolish enough to turn against me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Lene the Old Mobster","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}},{"_id":"5apBtZ6hblsQf6Bg","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lene the Old Mobster","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am the ruthless queen of Bergen’s under -\nworld, and I have no qualms about conducting my shady \nbusiness. Everyone in the city fears me, and I use my reputation to intimidate those foolish enough to turn against me. \nAgenda: Making money by taking advantage of people’s \ndesperation, taking what they have to offer without really \nleading them to Gerda and Kay. \nInformation: When the Hunters confront Lene, the old \nwoman will reveal that Gerda and Kay are staying at the \nsmall White Hospital, a medical facility that can be reached \nby sailing north along the river. Lene will give the Hunters \na pass that the Black Feathers will recognize as valid for \nboarding their boat to make the journey.\nLene will try hard to hide the fact that she is Gerda’s mother, fearing that this information will get her into even more \ntrouble than her daughter’s scheme. When this connection \nis made and Lene is cornered, she will reveal some infor -\nmation about her daughter to the Hunters. At this point, \nthe Storyteller can decide what to reveal about Gerda by \nconsulting her profile on page 223.\nLene’s Cutthroat</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 209.","owner":"Lene the Old Mobster","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-lene-the-old-mobster-209","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":209,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am the ruthless queen of Bergen’s under -\nworld, and I have no qualms about conducting my shady \nbusiness. Everyone in the city fears me, and I use my reputation to intimidate those foolish enough to turn against me. \nAgenda: Making money by taking advantage of people’s \ndesperation, taking what they have to offer without really \nleading them to Gerda and Kay. \nInformation: When the Hunters confront Lene, the old \nwoman will reveal that Gerda and Kay are staying at the \nsmall White Hospital, a medical facility that can be reached \nby sailing north along the river. Lene will give the Hunters \na pass that the Black Feathers will recognize as valid for \nboarding their boat to make the journey.\nLene will try hard to hide the fact that she is Gerda’s mother, fearing that this information will get her into even more \ntrouble than her daughter’s scheme. When this connection \nis made and Lene is cornered, she will reveal some infor -\nmation about her daughter to the Hunters. At this point, \nthe Storyteller can decide what to reveal about Gerda by \nconsulting her profile on page 223.\nLene’s Cutthroat</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Making money by taking advantage of people’s \ndesperation, taking what they have to offer without really \nleading them to Gerda and Kay.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}}
{"_id":"U1RISqZxe1YweXN6","name":"Lost Trails","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"Km0Lu82FWSDy94me","name":"Lost Trails - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lost Trails","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>It is not easy to follow the drag tracks in the \nforest and keep alert for predators. \nIn case of failure, the Hunters will be caught off guard by a \nherd of Nikola’s Reindeer. \nThe Badalisk’s Lair\nDescriptor: A large natural cave that emits a strong stench \nof death and decay.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","positive":"It is not easy to follow the drag tracks in the \nforest and keep alert for predators. \nIn case of failure, the Hunters will be caught off guard by a \nherd of Nikola’s Reindeer. \nThe Badalisk’s Lair\nDescriptor: A large natural cave that emits a strong stench \nof death and decay.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Lost Trails","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}},{"_id":"xNRAtMG6EOPuAhv9","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lost Trails","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>Descriptor: It is not easy to follow the drag tracks in the \nforest and keep alert for predators. \nIn case of failure, the Hunters will be caught off guard by a \nherd of Nikola’s Reindeer. \nThe Badalisk’s Lair\nDescriptor: A large natural cave that emits a strong stench \nof death and decay. \nInformation: The tracks end at the mouth of the gorge, \nwhere there is no snow on the rock: this indicates that a \nlarge creature often moves to the mouth. Many human remains and various objects can be found inside the cave. The \ndeeper you go, the darker it gets.\nThreat – The Sleeping Badalisk</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","owner":"Lost Trails","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-lost-trails-122","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":122,"role":"Threat"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: It is not easy to follow the drag tracks in the \nforest and keep alert for predators. \nIn case of failure, the Hunters will be caught off guard by a \nherd of Nikola’s Reindeer. \nThe Badalisk’s Lair\nDescriptor: A large natural cave that emits a strong stench \nof death and decay. \nInformation: The tracks end at the mouth of the gorge, \nwhere there is no snow on the rock: this indicates that a \nlarge creature often moves to the mouth. Many human remains and various objects can be found inside the cave. The \ndeeper you go, the darker it gets.\nThreat – The Sleeping Badalisk</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}
{"_id":"UI6QX2afJvM7LDAn","name":"Kråke","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"pUI2iwzT026kCyUa","name":"Kråke - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Kråke","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a skilled assassin, and I can corner any \nopponent with my saber. My swordsmanship is such that I \ncan deflect any weapon.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 210.","positive":"I am a skilled assassin, and I can corner any \nopponent with my saber. My swordsmanship is such that I \ncan deflect any weapon.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Kråke","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645318,"modifiedTime":1781557645318,"lastModifiedBy":null,"exportSource":null}},{"_id":"fKHhNLCpjfmjn28b","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Kråke","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a skilled assassin, and I can corner any \nopponent with my saber. My swordsmanship is such that I \ncan deflect any weapon. \nAgenda: Escort those who have paid the correct amount to \nthe White Hospital / Eliminate any potential threat to Gerda \nand Kay’s business. \nGift - The Rook: Once per Scene, Kråke can transform \ninto a rook and escape by flying away. If she makes a sur -\nprise attack, Kråke inflicts 1 Additional Wound. \n3</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 210.","owner":"Kråke","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645318,"modifiedTime":1781557645318,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-kr-ke-210","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":210,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a skilled assassin, and I can corner any \nopponent with my saber. My swordsmanship is such that I \ncan deflect any weapon. \nAgenda: Escort those who have paid the correct amount to \nthe White Hospital / Eliminate any potential threat to Gerda \nand Kay’s business. \nGift - The Rook: Once per Scene, Kråke can transform \ninto a rook and escape by flying away. If she makes a sur -\nprise attack, Kråke inflicts 1 Additional Wound. \n3</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Escort those who have paid the correct amount to \nthe White Hospital / Eliminate any potential threat to Gerda \nand Kay’s business.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645318,"modifiedTime":1781557645318,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Ud8oGwfslmjTt19K","name":"Guardians of the Tomb","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"CIzfOkXgMxDWiCr4","name":"Guardians of the Tomb - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Guardians of the Tomb","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>We are an order of fighting Guardians, and \nour vow of loyalty comes before all else. Only the taste of human flesh can distract us from our duty.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 156.","positive":"We are an order of fighting Guardians, and \nour vow of loyalty comes before all else. Only the taste of human flesh can distract us from our duty.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Guardians of the Tomb","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642395,"modifiedTime":1781557642395,"lastModifiedBy":null,"exportSource":null}},{"_id":"izro5DlJrSOFklKF","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Guardians of the Tomb","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are an order of fighting Guardians, and \nour vow of loyalty comes before all else. Only the taste of human flesh can distract us from our duty.\nAgenda: Defend the tomb from intruders. \n6A The Crystal Cliffs\nThe story that led us here...\nOverwhelmed by a strong current, the ship is pushed toward \na large group of rocks that Sinbad recognizes as very dangerous. The crystal that makes up the rocks is fragile, but also \nextremely sharp, and touching them would damage the ship’s \nhull. Beneath the crystal layer, the “rocks” are made up of all \nsorts of precious stones, and in each of them lies a real treasure. Even though the main goal is to get out unharmed, there \nmight be a Tarì among all the riches. \nPlace: A large group of crystal rocks reflecting the sunlight.\nInformation: It’s not easy to shatter the crystal without \ndangerous shards flying everywhere. Sinbad can keep control of the ship, but it will be up to the Hunters to clear the \nway. \nChallenges: Destroy the crystal rocks that block the path \nand recover valuable items from the inner rocks. At least 4 \nrocks must be cleared to cross this part of the sea. \nHow to get the Tarì: If the Hunters find at least 5 valuables, the Tarì will also be in the sixth rock.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 156.","owner":"Guardians of the Tomb","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642395,"modifiedTime":1781557642395,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-guardians-of-the-tomb-156","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":156,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are an order of fighting Guardians, and \nour vow of loyalty comes before all else. Only the taste of human flesh can distract us from our duty.\nAgenda: Defend the tomb from intruders. \n6A The Crystal Cliffs\nThe story that led us here...\nOverwhelmed by a strong current, the ship is pushed toward \na large group of rocks that Sinbad recognizes as very dangerous. The crystal that makes up the rocks is fragile, but also \nextremely sharp, and touching them would damage the ship’s \nhull. Beneath the crystal layer, the “rocks” are made up of all \nsorts of precious stones, and in each of them lies a real treasure. Even though the main goal is to get out unharmed, there \nmight be a Tarì among all the riches. \nPlace: A large group of crystal rocks reflecting the sunlight.\nInformation: It’s not easy to shatter the crystal without \ndangerous shards flying everywhere. Sinbad can keep control of the ship, but it will be up to the Hunters to clear the \nway. \nChallenges: Destroy the crystal rocks that block the path \nand recover valuable items from the inner rocks. At least 4 \nrocks must be cleared to cross this part of the sea. \nHow to get the Tarì: If the Hunters find at least 5 valuables, the Tarì will also be in the sixth rock.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Defend the tomb from intruders. \n6A The Crystal Cliffs\nThe story that led us here...\nOverwhelmed by a strong current, the ship is pushed toward \na large group of rocks that Sinbad recognizes as very dangerous. The crystal that makes up the rocks is fragile, but also \nextremely sharp, and touching them would damage the ship’s \nhull. Beneath the crystal layer, the “rocks” are made up of all \nsorts of precious stones, and in each of them lies a real treasure. Even though the main goal is to get out unharmed, there \nmight be a Tarì among all the riches. \nPlace: A large group of crystal rocks reflecting the sunlight.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642395,"modifiedTime":1781557642395,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Un45IQfWZv7lRhhc","name":"Pernille The Lapland Woman","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"C15HlmJqA3GWJTKa","name":"Pernille The Lapland Woman - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pernille The Lapland Woman","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a fearsome ice witch who learned the art \nof magic from the famous Lady Storm.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 217.","positive":"I am a fearsome ice witch who learned the art \nof magic from the famous Lady Storm.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pernille The Lapland Woman","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645672,"modifiedTime":1781557645672,"lastModifiedBy":null,"exportSource":null}},{"_id":"WDyjuAlLZehSu415","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pernille The Lapland Woman","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a fearsome ice witch who learned the art \nof magic from the famous Lady Storm.\nAgenda: Earn as much as possible without risking my life.\nGift - Ice Magic: Pernille can manipulate frost to create \nice at a range of sixty feet. When she acts, she can choose \none of the following effects:\n1. Ice Rain: The sharp fragments can hit up to 3 targets, \ncausing 1 Wound.\n4</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 217.","owner":"Pernille The Lapland Woman","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645672,"modifiedTime":1781557645672,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-pernille-the-lapland-woman-217","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":217,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a fearsome ice witch who learned the art \nof magic from the famous Lady Storm.\nAgenda: Earn as much as possible without risking my life.\nGift - Ice Magic: Pernille can manipulate frost to create \nice at a range of sixty feet. When she acts, she can choose \none of the following effects:\n1. Ice Rain: The sharp fragments can hit up to 3 targets, \ncausing 1 Wound.\n4</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Earn as much as possible without risking my life.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645672,"modifiedTime":1781557645672,"lastModifiedBy":null,"exportSource":null}}
{"_id":"V3aej9PnKXxpjfNG","name":"Treasury Door","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"jYM9HHfUdciNio6c","name":"Treasury Door - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Treasury Door","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>A huge metal door reinforced to resist any \nburglary attempt. The combination to open it is 05031762, \nAlena’s date of birth.\nRobbers</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 140.","positive":"A huge metal door reinforced to resist any \nburglary attempt. The combination to open it is 05031762, \nAlena’s date of birth.\nRobbers","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Treasury Door","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641635,"modifiedTime":1781557641635,"lastModifiedBy":null,"exportSource":null}},{"_id":"S2GUTMydSNTEYF2D","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Treasury Door","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>Descriptor: A huge metal door reinforced to resist any \nburglary attempt. The combination to open it is 05031762, \nAlena’s date of birth.\nRobbers</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 140.","owner":"Treasury Door","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641635,"modifiedTime":1781557641635,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-treasury-door-140","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":140,"role":"Threat"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A huge metal door reinforced to resist any \nburglary attempt. The combination to open it is 05031762, \nAlena’s date of birth.\nRobbers</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641635,"modifiedTime":1781557641635,"lastModifiedBy":null,"exportSource":null}}
{"_id":"VMg6iY66YQc2yWP5","name":"The Sleeping Badalisk","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"66vvUnkL46jYPyDJ","name":"The Sleeping Badalisk - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Sleeping Badalisk","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>The Badalisk sleeps most of the time, but if you \ndisturb it, it will wake up ready to devour anything.\nNote: This Threat is activated when Hunters make a loud \nnoise, turn on a light, or come close enough for the Badalisk to smell them. If the Badalisk does not awaken, it can be \nexamined closely while it is dormant. If the Badalisk suffers \n1 Wound, it will wake immediately.\nThe Badalisk</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","positive":"The Badalisk sleeps most of the time, but if you \ndisturb it, it will wake up ready to devour anything.\nNote: This Threat is activated when Hunters make a loud \nnoise, turn on a light, or come close enough for the Badalisk to smell them. If the Badalisk does not awaken, it can be \nexamined closely while it is dormant. If the Badalisk suffers \n1 Wound, it will wake immediately.\nThe Badalisk","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Sleeping Badalisk","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}},{"_id":"OxSPCxVUAvNIPyDI","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Sleeping Badalisk","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>Descriptor: The Badalisk sleeps most of the time, but if you \ndisturb it, it will wake up ready to devour anything.\nNote: This Threat is activated when Hunters make a loud \nnoise, turn on a light, or come close enough for the Badalisk to smell them. If the Badalisk does not awaken, it can be \nexamined closely while it is dormant. If the Badalisk suffers \n1 Wound, it will wake immediately.\nThe Badalisk</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","owner":"The Sleeping Badalisk","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-the-sleeping-badalisk-122","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":122,"role":"Threat"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: The Badalisk sleeps most of the time, but if you \ndisturb it, it will wake up ready to devour anything.\nNote: This Threat is activated when Hunters make a loud \nnoise, turn on a light, or come close enough for the Badalisk to smell them. If the Badalisk does not awaken, it can be \nexamined closely while it is dormant. If the Badalisk suffers \n1 Wound, it will wake immediately.\nThe Badalisk</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}
{"_id":"VajAANlL1MTiZXJP","name":"The Gang of Bats","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"OFydzNpa4kO4SHER","name":"The Gang of Bats - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of Bats","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>We are street urchins, used to stealing to survive. \nWith Pepe at our head, we are not afraid of anything.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 105.","positive":"We are street urchins, used to stealing to survive. \nWith Pepe at our head, we are not afraid of anything.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Gang of Bats","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}},{"_id":"Ta0H1ELXhYRxlAGI","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Gang of Bats","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are street urchins, used to stealing to survive. \nWith Pepe at our head, we are not afraid of anything. \nAgenda: Help Pepe make the Gang prosper / Help Pepe overcome \nthe trauma of his family’s death. \nGift - United Gang: Each member of the Gang possesses a trait \nthat is identified by an addition to their Descriptor. \nBenedicto: I am the oldest in the Gang, and my strength is feared \neven by adults.\nCarmina: I am agile, fast, and a good climber. \nFelix: I am the smallest of the Gang and can squeeze into any hole. \nInez: I am the smartest of the Gang and have read many books.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 105.","owner":"The Gang of Bats","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-mothers-heart-the-gang-of-bats-105","collection":"Lost Stories","adventureSlug":"a-mothers-heart","adventureTitle":"A Mother's Heart","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":105,"role":"Minor NPC"}},"system":{"details":{"concept":"A Mother's Heart","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are street urchins, used to stealing to survive. \nWith Pepe at our head, we are not afraid of anything. \nAgenda: Help Pepe make the Gang prosper / Help Pepe overcome \nthe trauma of his family’s death. \nGift - United Gang: Each member of the Gang possesses a trait \nthat is identified by an addition to their Descriptor. \nBenedicto: I am the oldest in the Gang, and my strength is feared \neven by adults.\nCarmina: I am agile, fast, and a good climber. \nFelix: I am the smallest of the Gang and can squeeze into any hole. \nInez: I am the smartest of the Gang and have read many books.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Help Pepe make the Gang prosper / Help Pepe overcome \nthe trauma of his family’s death.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}}
{"_id":"VdGkQADJIQEVOhl2","name":"Haunted Door","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"KVvb6zmx1Y66yp5N","name":"Haunted Door - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Haunted Door","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>A creaking old door imbued with all of Merlin’s \nmagical power.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 191.","positive":"A creaking old door imbued with all of Merlin’s \nmagical power.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Haunted Door","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644115,"modifiedTime":1781557644115,"lastModifiedBy":null,"exportSource":null}},{"_id":"7rvolSqtLezExtNU","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Haunted Door","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Descriptor: A creaking old door imbued with all of Merlin’s \nmagical power.\nGift - Away with the Harassers: Attempting to open \nthe door without the Tower Key triggers the magical effects \nbelow. If the Defense Check fails, the Storyteller rolls a die \nto determine the consequences. \n1-2: Loses all remaining Soma.\n3-4: Suffers 2 Wounds. \n5-6: Ends with the whole group in another Zone. \nInside the Tower, the Hunters will find all manner of magical devilry, as well as clear evidence in books and scrolls \nthat the place belongs to a Sorcerer named Merlin. With \ntime, the Hunters can uncover Merlin’s diary and, at the \nStoryteller’s discretion, a Treasure of the Order.\nThe diary is mostly written in an incomprehensible language, but there are notes written in red ink that are in \ncommon English.\nNote 1: An overly righteous and beloved king is more dangerous than the worst of tyrants, for when raising a hand against \nhim an entire people will rise to shield him.\nNote 2: Virtue is like a weed, it grows despite all efforts to \npull it up.\nNote 3: It may not be handy, but the bottom of a lake is always a good place to hide. \nNote 4: White beach, safe harbor.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 191.","owner":"Haunted Door","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644115,"modifiedTime":1781557644115,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-haunted-door-191","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":191,"role":"Threat"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A creaking old door imbued with all of Merlin’s \nmagical power.\nGift - Away with the Harassers: Attempting to open \nthe door without the Tower Key triggers the magical effects \nbelow. If the Defense Check fails, the Storyteller rolls a die \nto determine the consequences. \n1-2: Loses all remaining Soma.\n3-4: Suffers 2 Wounds. \n5-6: Ends with the whole group in another Zone. \nInside the Tower, the Hunters will find all manner of magical devilry, as well as clear evidence in books and scrolls \nthat the place belongs to a Sorcerer named Merlin. With \ntime, the Hunters can uncover Merlin’s diary and, at the \nStoryteller’s discretion, a Treasure of the Order.\nThe diary is mostly written in an incomprehensible language, but there are notes written in red ink that are in \ncommon English.\nNote 1: An overly righteous and beloved king is more dangerous than the worst of tyrants, for when raising a hand against \nhim an entire people will rise to shield him.\nNote 2: Virtue is like a weed, it grows despite all efforts to \npull it up.\nNote 3: It may not be handy, but the bottom of a lake is always a good place to hide. \nNote 4: White beach, safe harbor.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644115,"modifiedTime":1781557644115,"lastModifiedBy":null,"exportSource":null}}
{"_id":"XF9VWOu2Ny4ccXyt","name":"Lost Children","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"ccw6RZ8SEZ0TGGlM","name":"Lost Children - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lost Children","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>We are restless spirits spawned by Blanca’s \nmadness. We hate living things and try to take them with us \nto the waters of the Segura River to drown them, just as we \nwere.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 106.","positive":"We are restless spirits spawned by Blanca’s \nmadness. We hate living things and try to take them with us \nto the waters of the Segura River to drown them, just as we \nwere.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Lost Children","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639946,"modifiedTime":1781557639946,"lastModifiedBy":null,"exportSource":null}},{"_id":"KQnW2QMgapDShpPU","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lost Children","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are restless spirits spawned by Blanca’s \nmadness. We hate living things and try to take them with us \nto the waters of the Segura River to drown them, just as we \nwere. \nAgenda: Choose a target and drag it to the Segura River to \ndrown it. \nGift - Suffering Spirit: As an action, a Lost Child will \nalways attempt to snatch a target. In the event of a Defense \nCheck Failure, apply the result based on where the action \ntakes place.\nWithin 100 feet of the Segura River: The Lost \nChild jumps into the river, taking the target with it. \nThe Lost Child suffers 1 Wound while the target is in \nthe depths of the River, see Threat - The Segura River \non page 106.\nAnywhere else: The Lost Child envelops the target</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 106.","owner":"Lost Children","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639946,"modifiedTime":1781557639946,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-mothers-heart-lost-children-106","collection":"Lost Stories","adventureSlug":"a-mothers-heart","adventureTitle":"A Mother's Heart","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":106,"role":"Minor NPC"}},"system":{"details":{"concept":"A Mother's Heart","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are restless spirits spawned by Blanca’s \nmadness. We hate living things and try to take them with us \nto the waters of the Segura River to drown them, just as we \nwere. \nAgenda: Choose a target and drag it to the Segura River to \ndrown it. \nGift - Suffering Spirit: As an action, a Lost Child will \nalways attempt to snatch a target. In the event of a Defense \nCheck Failure, apply the result based on where the action \ntakes place.\nWithin 100 feet of the Segura River: The Lost \nChild jumps into the river, taking the target with it. \nThe Lost Child suffers 1 Wound while the target is in \nthe depths of the River, see Threat - The Segura River \non page 106.\nAnywhere else: The Lost Child envelops the target</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Choose a target and drag it to the Segura River to \ndrown it.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639946,"modifiedTime":1781557639946,"lastModifiedBy":null,"exportSource":null}}
{"_id":"XXHLTaJfcZY1ZB5Z","name":"6: Soila","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"Mn9Mj9uPW7tS60NG","name":"6: Soila - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"6: Soila","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a teacher and I am responsible for the \neducation of the children in the village.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 120.","positive":"I am a teacher and I am responsible for the \neducation of the children in the village.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"6: Soila","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640571,"modifiedTime":1781557640571,"lastModifiedBy":null,"exportSource":null}},{"_id":"p8dfv6DdmNSyLfnH","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"6: Soila","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a teacher and I am responsible for the \neducation of the children in the village. \nAgenda: Keeping Rovaniemi families together. \nInformation: Soila will say that Nikola’s behavior was always strange. For example, he always came to the village \nafter sunset and never entered anyone’s house without a \nproper formal invitation. More than once, Soila has seen \nhim lose his temper over the issue. But the Patron’s eccentric behavior is nothing compared to all the good he has \ndone for the Village. Soila knows all the families who live \nin the Village and is responsible for welcoming newcomers. \nShe will tell you that Tommi and Jutta are two good people, but too reserved to adapt to the rules of the community. Soila has even offered to help them pay the pledge, but \nTommi is too proud to go into debt.\nThe Forest around \nRovaniemi\nDescriptor: A dense forest, always covered by a thick blanket of snow. It is easy to find tracks in the snow.\nInformation: It is possible to reach Nikola’s estate from \nthe forest in a six-hour walk. Every three hours, the following Encounters are possible. The Storyteller can choose \nwhich or roll a die. \n1-2: The Tracks\n3-4: Nikola’s Reindeer\n5-6: Remains of the Merchant Wagon\nThe Tracks\nThe Hunters see the tracks of a single person who veered \noff the path and got lost in the forest. They were left by the \nfirst Hunter to arrive in Rovaniemi and lead to the Hunting \nLodge. See page 120.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 120.","owner":"6: Soila","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640571,"modifiedTime":1781557640571,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-6-soila-120","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":120,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a teacher and I am responsible for the \neducation of the children in the village. \nAgenda: Keeping Rovaniemi families together. \nInformation: Soila will say that Nikola’s behavior was always strange. For example, he always came to the village \nafter sunset and never entered anyone’s house without a \nproper formal invitation. More than once, Soila has seen \nhim lose his temper over the issue. But the Patron’s eccentric behavior is nothing compared to all the good he has \ndone for the Village. Soila knows all the families who live \nin the Village and is responsible for welcoming newcomers. \nShe will tell you that Tommi and Jutta are two good people, but too reserved to adapt to the rules of the community. Soila has even offered to help them pay the pledge, but \nTommi is too proud to go into debt.\nThe Forest around \nRovaniemi\nDescriptor: A dense forest, always covered by a thick blanket of snow. It is easy to find tracks in the snow.\nInformation: It is possible to reach Nikola’s estate from \nthe forest in a six-hour walk. Every three hours, the following Encounters are possible. The Storyteller can choose \nwhich or roll a die. \n1-2: The Tracks\n3-4: Nikola’s Reindeer\n5-6: Remains of the Merchant Wagon\nThe Tracks\nThe Hunters see the tracks of a single person who veered \noff the path and got lost in the forest. They were left by the \nfirst Hunter to arrive in Rovaniemi and lead to the Hunting \nLodge. See page 120.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Keeping Rovaniemi families together.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640571,"modifiedTime":1781557640571,"lastModifiedBy":null,"exportSource":null}}
{"_id":"XaRaWCGIjxoWksbk","name":"Illusory Panorama","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"M1eYSlkgEkzV6qzv","name":"Illusory Panorama - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Illusory Panorama","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>A false image that adapts to weather conditions. Small, repetitive details are the only sign that something is wrong, such as a flock of seagulls flying following a \ncyclic trajectory and clouds that seem stuck in the same position.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 200.","positive":"A false image that adapts to weather conditions. Small, repetitive details are the only sign that something is wrong, such as a flock of seagulls flying following a \ncyclic trajectory and clouds that seem stuck in the same position.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Illusory Panorama","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644552,"modifiedTime":1781557644552,"lastModifiedBy":null,"exportSource":null}},{"_id":"fJxHgQpbvyhWtkQX","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Illusory Panorama","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Descriptor: A false image that adapts to weather conditions. Small, repetitive details are the only sign that something is wrong, such as a flock of seagulls flying following a \ncyclic trajectory and clouds that seem stuck in the same position.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 200.","owner":"Illusory Panorama","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644552,"modifiedTime":1781557644552,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-illusory-panorama-200","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":200,"role":"Threat"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A false image that adapts to weather conditions. Small, repetitive details are the only sign that something is wrong, such as a flock of seagulls flying following a \ncyclic trajectory and clouds that seem stuck in the same position.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644552,"modifiedTime":1781557644552,"lastModifiedBy":null,"exportSource":null}}
{"_id":"XnmPVkAv7MEDq8Gx","name":"The Executioner","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"vlouZErpm7KZdpi7","name":"The Executioner - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Executioner","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a ruthless enforcer, and with one stroke of \nmy scimitar I can cut a man in two.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 166.","positive":"I am a ruthless enforcer, and with one stroke of \nmy scimitar I can cut a man in two.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Executioner","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}},{"_id":"aJHDnA9m2MEFCxpo","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Executioner","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a ruthless enforcer, and with one stroke of \nmy scimitar I can cut a man in two. \nGift - Art of Death: Wounds inflicted by the Executioner \nare not easily healed and will remain for the next Leg unless \nthe Hunter can heal them with an Interlude, Gifts, or by \nusing the Gift of Sinbad - The Sailing Ship. \nEpilogue of the Leg: Whatever the outcome, Sherazade \nis now in the hands of the Hunters. She can be used as a \nHunter for the next few Legs if the Players wish.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 166.","owner":"The Executioner","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-executioner-166","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":166,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a ruthless enforcer, and with one stroke of \nmy scimitar I can cut a man in two. \nGift - Art of Death: Wounds inflicted by the Executioner \nare not easily healed and will remain for the next Leg unless \nthe Hunter can heal them with an Interlude, Gifts, or by \nusing the Gift of Sinbad - The Sailing Ship. \nEpilogue of the Leg: Whatever the outcome, Sherazade \nis now in the hands of the Hunters. She can be used as a \nHunter for the next few Legs if the Players wish.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}}
{"_id":"ZCOZ7g0JaUPbdclj","name":"Merlin’s Shadow","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"Uc3NCGfoNs6m9Nzq","name":"Merlin’s Shadow - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am the shadow of the mighty sorcerer Merlin, \nand with my touch, I can freeze anything. I constantly receive \nvisions of what my former master is doing.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 185.","positive":"I am the shadow of the mighty sorcerer Merlin, \nand with my touch, I can freeze anything. I constantly receive \nvisions of what my former master is doing.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}},{"_id":"NceHfdjyKGJJECiO","name":"Gift - Shadow Body","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>In semi- or total darkness, Merlin’s</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 185.","somaCost":0,"automaticSuccesses":0,"owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}},{"_id":"jZ6nLHvlt7awdDla","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (2 Wounds)\nDescriptor: I am the shadow of the mighty sorcerer Merlin, \nand with my touch, I can freeze anything. I constantly receive \nvisions of what my former master is doing. \nAgenda: Kill the precious Hunters Merlin has sent as a way \nof taking revenge on him for leaving me alone to guard Avalon. \nGift - Shadow Body: In semi- or total darkness, Merlin’s</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 185.","owner":"Merlin’s Shadow","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-merlin-s-shadow-185","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":185,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (2 Wounds)\nDescriptor: I am the shadow of the mighty sorcerer Merlin, \nand with my touch, I can freeze anything. I constantly receive \nvisions of what my former master is doing. \nAgenda: Kill the precious Hunters Merlin has sent as a way \nof taking revenge on him for leaving me alone to guard Avalon. \nGift - Shadow Body: In semi- or total darkness, Merlin’s</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Kill the precious Hunters Merlin has sent as a way \nof taking revenge on him for leaving me alone to guard Avalon.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643869,"modifiedTime":1781557643869,"lastModifiedBy":null,"exportSource":null}}
{"_id":"ZnXhtG3dL3EPHadN","name":"Villa Wagner’s Guard","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"VlsEecGahLj3FNW7","name":"Villa Wagner’s Guard - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>We are loyal and well-trained for our duties as \nguardians.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 139.","positive":"We are loyal and well-trained for our duties as \nguardians.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641605,"modifiedTime":1781557641605,"lastModifiedBy":null,"exportSource":null}},{"_id":"FqJ496uFcadq199F","name":"Gift - Guard Corps","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>During an action, increase their OL \nby 1 if they are defending Villa Wagner from a threat or \nperceived threat.\nAlena Wagner</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 139.","somaCost":0,"automaticSuccesses":0,"owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}},{"_id":"13rYFHwjgUDJzyV8","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are loyal and well-trained for our duties as \nguardians. \nGift - Guard Corps: During an action, increase their OL \nby 1 if they are defending Villa Wagner from a threat or \nperceived threat.\nAlena Wagner</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 139.","owner":"Villa Wagner’s Guard","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-villa-wagner-s-guard-139","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":139,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are loyal and well-trained for our duties as \nguardians. \nGift - Guard Corps: During an action, increase their OL \nby 1 if they are defending Villa Wagner from a threat or \nperceived threat.\nAlena Wagner</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}}
{"_id":"Zw1LjGuofeWS9t67","name":"The Segura River","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"NPXtt5vUdyut0Im6","name":"The Segura River - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Segura River","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>Strong currents and icy waters make the Segura River dangerous even for experienced swimmers. \nThe Monastery\nDescriptor: An old monastery that once housed a group \nof monks. Now only a few rooms and the large courtyard are \nusable.\nMorning: From the Monastery garden comes the cackle \nof children playing. With them is Sister Esperanza, a nun \nwho helps Father Neron keep the little marked ones safe \nfrom Blanca’s sight. There are a total of six children in the \nMonastery (all reported missing from the River Market). \nWhen questioned, Sister Esperanza will not hesitate to \nstand up for Father Neron. The nun will say that the priest \nwanders around the Market in the morning, while in the afternoon he worries about finding the children’s families to \ntell them that their little ones are safe under the protection \nof the Church. Father Neron makes donations to the children’s families to ensure their cooperation, with the promise of a reunion on the first day of December. \nAfternoon: Father Neron is present as he prepares donations for the families of the children who live in the Monastery. Sister Esperanza takes care of the children.\nEvening: Father Neron is the small library of the Monastery, studying books on exorcism. Sister Esperanza sleeps \nin the underground rooms with the children.\nSister Esperanza</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 107.","positive":"Strong currents and icy waters make the Segura River dangerous even for experienced swimmers. \nThe Monastery\nDescriptor: An old monastery that once housed a group \nof monks. Now only a few rooms and the large courtyard are \nusable.\nMorning: From the Monastery garden comes the cackle \nof children playing. With them is Sister Esperanza, a nun \nwho helps Father Neron keep the little marked ones safe \nfrom Blanca’s sight. There are a total of six children in the \nMonastery (all reported missing from the River Market). \nWhen questioned, Sister Esperanza will not hesitate to \nstand up for Father Neron. The nun will say that the priest \nwanders around the Market in the morning, while in the afternoon he worries about finding the children’s families to \ntell them that their little ones are safe under the protection \nof the Church. Father Neron makes donations to the children’s families to ensure their cooperation, with the promise of a reunion on the first day of December. \nAfternoon: Father Neron is present as he prepares donations for the families of the children who live in the Monastery. Sister Esperanza takes care of the children.\nEvening: Father Neron is the small library of the Monastery, studying books on exorcism. Sister Esperanza sleeps \nin the underground rooms with the children.\nSister Esperanza","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Segura River","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640056,"modifiedTime":1781557640056,"lastModifiedBy":null,"exportSource":null}},{"_id":"f5vshlw2eilVZWrv","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Segura River","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>Descriptor: Strong currents and icy waters make the Segura River dangerous even for experienced swimmers. \nThe Monastery\nDescriptor: An old monastery that once housed a group \nof monks. Now only a few rooms and the large courtyard are \nusable.\nMorning: From the Monastery garden comes the cackle \nof children playing. With them is Sister Esperanza, a nun \nwho helps Father Neron keep the little marked ones safe \nfrom Blanca’s sight. There are a total of six children in the \nMonastery (all reported missing from the River Market). \nWhen questioned, Sister Esperanza will not hesitate to \nstand up for Father Neron. The nun will say that the priest \nwanders around the Market in the morning, while in the afternoon he worries about finding the children’s families to \ntell them that their little ones are safe under the protection \nof the Church. Father Neron makes donations to the children’s families to ensure their cooperation, with the promise of a reunion on the first day of December. \nAfternoon: Father Neron is present as he prepares donations for the families of the children who live in the Monastery. Sister Esperanza takes care of the children.\nEvening: Father Neron is the small library of the Monastery, studying books on exorcism. Sister Esperanza sleeps \nin the underground rooms with the children.\nSister Esperanza</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 107.","owner":"The Segura River","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640056,"modifiedTime":1781557640056,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-mothers-heart-the-segura-river-107","collection":"Lost Stories","adventureSlug":"a-mothers-heart","adventureTitle":"A Mother's Heart","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":107,"role":"Threat"}},"system":{"details":{"concept":"A Mother's Heart","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: Strong currents and icy waters make the Segura River dangerous even for experienced swimmers. \nThe Monastery\nDescriptor: An old monastery that once housed a group \nof monks. Now only a few rooms and the large courtyard are \nusable.\nMorning: From the Monastery garden comes the cackle \nof children playing. With them is Sister Esperanza, a nun \nwho helps Father Neron keep the little marked ones safe \nfrom Blanca’s sight. There are a total of six children in the \nMonastery (all reported missing from the River Market). \nWhen questioned, Sister Esperanza will not hesitate to \nstand up for Father Neron. The nun will say that the priest \nwanders around the Market in the morning, while in the afternoon he worries about finding the children’s families to \ntell them that their little ones are safe under the protection \nof the Church. Father Neron makes donations to the children’s families to ensure their cooperation, with the promise of a reunion on the first day of December. \nAfternoon: Father Neron is present as he prepares donations for the families of the children who live in the Monastery. Sister Esperanza takes care of the children.\nEvening: Father Neron is the small library of the Monastery, studying books on exorcism. Sister Esperanza sleeps \nin the underground rooms with the children.\nSister Esperanza</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640056,"modifiedTime":1781557640056,"lastModifiedBy":null,"exportSource":null}}
{"_id":"ZwkK0tfly4CzaNhV","name":"Troll Craftsman","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"NZuZqPd8rEU3CcLI","name":"Troll Craftsman - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Troll Craftsman","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a skilled craftsman and have served Lady \nStorm for decades, creating stunning ice mirrors for her. I can \nmanipulate the reflected images as if they were real.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 223.","positive":"I am a skilled craftsman and have served Lady \nStorm for decades, creating stunning ice mirrors for her. I can \nmanipulate the reflected images as if they were real.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Troll Craftsman","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646130,"modifiedTime":1781557646130,"lastModifiedBy":null,"exportSource":null}},{"_id":"64bgWDBhuQL4Xetm","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Troll Craftsman","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Minor NPC (4 Wounds)\nDescriptor: I am a skilled craftsman and have served Lady \nStorm for decades, creating stunning ice mirrors for her. I can \nmanipulate the reflected images as if they were real. \nAgenda: Rebuilding the Mirror of the Other Self for my \nLady Storm. \nSpecial Agenda (Prince Trollo the Innocent): I have \nalways wanted an apprentice to pass my art on to, and he \nseems perfect. Whether he wants to or not. \nGift - The Mirrored Reality: Although blinded, the \nTroll can see the world around it through the mirrors scattered throughout the room, thanks to the glare of the shards \nin his eyes. The Troll can act against a target by striking at \na reflected image without the target being able to make a \nDefense Check to avoid it.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 223.","owner":"Troll Craftsman","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646130,"modifiedTime":1781557646130,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-troll-craftsman-223","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":223,"role":"Minor NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (4 Wounds)\nDescriptor: I am a skilled craftsman and have served Lady \nStorm for decades, creating stunning ice mirrors for her. I can \nmanipulate the reflected images as if they were real. \nAgenda: Rebuilding the Mirror of the Other Self for my \nLady Storm. \nSpecial Agenda (Prince Trollo the Innocent): I have \nalways wanted an apprentice to pass my art on to, and he \nseems perfect. Whether he wants to or not. \nGift - The Mirrored Reality: Although blinded, the \nTroll can see the world around it through the mirrors scattered throughout the room, thanks to the glare of the shards \nin his eyes. The Troll can act against a target by striking at \na reflected image without the target being able to make a \nDefense Check to avoid it.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":4},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Rebuilding the Mirror of the Other Self for my \nLady Storm.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646130,"modifiedTime":1781557646130,"lastModifiedBy":null,"exportSource":null}}
{"_id":"a0cPa2cdbWYRBeIu","name":"Britta the Beheaded Witch","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"mAm6azoyBhYQj2AH","name":"Britta the Beheaded Witch - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Britta the Beheaded Witch","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>I am a skilled witch who only desires a quiet \nlife. Since I no longer have a head, I cannot speak or utter \nmagic formulas.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 142.","positive":"I am a skilled witch who only desires a quiet \nlife. Since I no longer have a head, I cannot speak or utter \nmagic formulas.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Britta the Beheaded Witch","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641698,"modifiedTime":1781557641698,"lastModifiedBy":null,"exportSource":null}},{"_id":"dRDrhLrZfyrGJOkN","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Britta the Beheaded Witch","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Main NPC (2 Wounds)\nDescriptor: I am a skilled witch who only desires a quiet \nlife. Since I no longer have a head, I cannot speak or utter \nmagic formulas. \nAgenda: To find my head that Bastian threw in the river. \nInformation: Britta’s body will revive when two of her \nthree magical items are placed on her. In this state, Britta \nwill not be able to speak, but she will be able to write, informing the Hunters that she knows where her head is and \nwill go to retrieve it. In the meantime, Britta will ask the \nHunters to retrieve the third object to complete her resur -\nrection. \nBritta the Witch</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 142.","owner":"Britta the Beheaded Witch","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641698,"modifiedTime":1781557641698,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-britta-the-beheaded-witch-142","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":142,"role":"Main NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (2 Wounds)\nDescriptor: I am a skilled witch who only desires a quiet \nlife. Since I no longer have a head, I cannot speak or utter \nmagic formulas. \nAgenda: To find my head that Bastian threw in the river. \nInformation: Britta’s body will revive when two of her \nthree magical items are placed on her. In this state, Britta \nwill not be able to speak, but she will be able to write, informing the Hunters that she knows where her head is and \nwill go to retrieve it. In the meantime, Britta will ask the \nHunters to retrieve the third object to complete her resur -\nrection. \nBritta the Witch</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To find my head that Bastian threw in the river.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641698,"modifiedTime":1781557641698,"lastModifiedBy":null,"exportSource":null}}
{"_id":"aM2KkGTF3GaQLM0y","name":"Armsmen of the City","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"kvmKaWJFkyHOva8h","name":"Armsmen of the City - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Armsmen of the City","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>We are swordsmen and have gained experience during the war. We carry out the orders of those who pay \nus without making too much trouble.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","positive":"We are swordsmen and have gained experience during the war. We carry out the orders of those who pay \nus without making too much trouble.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Armsmen of the City","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}},{"_id":"AZz9mimrUmKGLNTA","name":"Gift - Companions in Arms","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Armsmen of the City","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>During an action, they \nincrease their OL by 1 if at least one other Armsman is present. \nCutthroat</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","somaCost":0,"automaticSuccesses":0,"owner":"Armsmen of the City","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}},{"_id":"o0Y6PbS0Wrh6cdUu","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Armsmen of the City","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are swordsmen and have gained experience during the war. We carry out the orders of those who pay \nus without making too much trouble. \nGift - Companions in Arms: During an action, they \nincrease their OL by 1 if at least one other Armsman is present. \nCutthroat</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","owner":"Armsmen of the City","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-armsmen-of-the-city-136","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":136,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are swordsmen and have gained experience during the war. We carry out the orders of those who pay \nus without making too much trouble. \nGift - Companions in Arms: During an action, they \nincrease their OL by 1 if at least one other Armsman is present. \nCutthroat</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}}
{"_id":"aPI4ynNXcWYNte2M","name":"Arthur","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"cLtgc0R5sTMNhoDj","name":"Arthur - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Arthur","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am the king of Camelot, and my word is law. \nThanks to the power of the Grail, my body is immortal and I \npossess abilities far beyond those of ordinary men.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 195.","positive":"I am the king of Camelot, and my word is law. \nThanks to the power of the Grail, my body is immortal and I \npossess abilities far beyond those of ordinary men.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Arthur","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644317,"modifiedTime":1781557644317,"lastModifiedBy":null,"exportSource":null}},{"_id":"kIDRvZJzmuOMZV15","name":"Gift - The True Power of the Grail","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Arthur","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Arthur is immortal, which means that any Wounds inflicted on him will \nheal immediately. Arthur can act up to 3 times in an Exchange, but not back to back.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 195.","somaCost":0,"automaticSuccesses":0,"owner":"Arthur","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644317,"modifiedTime":1781557644317,"lastModifiedBy":null,"exportSource":null}},{"_id":"NBs6AiqR8C9oEY8n","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Arthur","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (6 Wounds)\nDescriptor: I am the king of Camelot, and my word is law. \nThanks to the power of the Grail, my body is immortal and I \npossess abilities far beyond those of ordinary men.\nAgenda: Bring back my bride, Guinevere, to rule all of Europe by my side / Prepare the army for battle and make all my \nsubjects immortal warriors. \nGift - The True Power of the Grail: Arthur is immortal, which means that any Wounds inflicted on him will \nheal immediately. Arthur can act up to 3 times in an Exchange, but not back to back.\nGift - Merlin’s Curse: Deprived of the Virtues by Merlin’s magic, Arthur has become a mad and powerful being \nwho has abandoned his humanity. Activating the power of \nthe Virtues awakens the king’s true soul, making him more \nhuman. Each Virtue consumed in front of Arthur will have \nthe following effect:\nLove: Lower his OL by 2.\nInnocence: Lower the number of Wounds by 3. \nFaith: He loses his immortality and, if brought to 0 \nWounds, is permanently killed. \nCourage: Acts only 1 time per Exchange. \nWisdom: He regains his wits and realizes that what he is \ndoing is wrong. Arthur’s Agenda changes to: Lead my kingdom to peace by finding a place in this new world.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 195.","owner":"Arthur","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644317,"modifiedTime":1781557644317,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-arthur-195","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":195,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (6 Wounds)\nDescriptor: I am the king of Camelot, and my word is law. \nThanks to the power of the Grail, my body is immortal and I \npossess abilities far beyond those of ordinary men.\nAgenda: Bring back my bride, Guinevere, to rule all of Europe by my side / Prepare the army for battle and make all my \nsubjects immortal warriors. \nGift - The True Power of the Grail: Arthur is immortal, which means that any Wounds inflicted on him will \nheal immediately. Arthur can act up to 3 times in an Exchange, but not back to back.\nGift - Merlin’s Curse: Deprived of the Virtues by Merlin’s magic, Arthur has become a mad and powerful being \nwho has abandoned his humanity. Activating the power of \nthe Virtues awakens the king’s true soul, making him more \nhuman. Each Virtue consumed in front of Arthur will have \nthe following effect:\nLove: Lower his OL by 2.\nInnocence: Lower the number of Wounds by 3. \nFaith: He loses his immortality and, if brought to 0 \nWounds, is permanently killed. \nCourage: Acts only 1 time per Exchange. \nWisdom: He regains his wits and realizes that what he is \ndoing is wrong. Arthur’s Agenda changes to: Lead my kingdom to peace by finding a place in this new world.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"Bring back my bride, Guinevere, to rule all of Europe by my side / Prepare the army for battle and make all my \nsubjects immortal warriors.","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644317,"modifiedTime":1781557644317,"lastModifiedBy":null,"exportSource":null}}
{"_id":"aR6I02MpVk8UJXzQ","name":"Magic Greenhouse","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"MZOgb65J6imQgUN0","name":"Magic Greenhouse - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Magic Greenhouse","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>A greenhouse filled with strange plants imbued with Flora’s magical powers.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 207.","positive":"A greenhouse filled with strange plants imbued with Flora’s magical powers.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Magic Greenhouse","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}},{"_id":"6Vbtc1tmP2vxGNjk","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Magic Greenhouse","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>Descriptor: A greenhouse filled with strange plants imbued with Flora’s magical powers. \nGift - Wild Plants: The Greenhouse plants will identify \nanyone other than Flora as a threat. The plants rely on smell \nto detect intruders, so they can be fooled. If a person enters \nthe Greenhouse, roll 1 die:\n1-2: A carnivorous plant attempts to bite the target to inflict 1 Wound. \n3-4: A colored pollen covers the target, which takes 1 \nPenalty on all actions while in the Greenhouse. A Defense \nCheck is needed to avoid the pollen.\n5-6: A large flower emits a sharp hissing sound that stuns \nthe target and causes them to lose 1 Soma (1 Wound, in the \ncase of an NPC).</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 207.","owner":"Magic Greenhouse","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-magic-greenhouse-207","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":207,"role":"Threat"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A greenhouse filled with strange plants imbued with Flora’s magical powers. \nGift - Wild Plants: The Greenhouse plants will identify \nanyone other than Flora as a threat. The plants rely on smell \nto detect intruders, so they can be fooled. If a person enters \nthe Greenhouse, roll 1 die:\n1-2: A carnivorous plant attempts to bite the target to inflict 1 Wound. \n3-4: A colored pollen covers the target, which takes 1 \nPenalty on all actions while in the Greenhouse. A Defense \nCheck is needed to avoid the pollen.\n5-6: A large flower emits a sharp hissing sound that stuns \nthe target and causes them to lose 1 Soma (1 Wound, in the \ncase of an NPC).</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}}
{"_id":"aaaVIu94EdM3iz5t","name":"Twrch Trwyth","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"hnq47bRD9TjpCpGq","name":"Twrch Trwyth - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Twrch Trwyth","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am a strong and fast boar, I know every corner of the island and all the secret paths.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 183.","positive":"I am a strong and fast boar, I know every corner of the island and all the secret paths.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Twrch Trwyth","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}},{"_id":"5loQRqPyg9RuNQOE","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Twrch Trwyth","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a strong and fast boar, I know every corner of the island and all the secret paths.\nAgenda: Find food without getting caught.\nGift - Magic Boar: Whenever the Twrch Trwyth avoids \nan action by someone who is hunting him, he gets 1 Escape Token. As an action, and by spending 2 Escape Tokens, the Twrch Trwyth can leave the Scene without anyone being able to stop it. Even when dead, the body of the \nTwrch Trwyth continues to give off an inviting scent and \nglow with an intense magical light. Processing the Twrch \nTrwyth’s flesh can yield 1 Delightful Flesh token. Whoever \nconsumes it will recover 1 Wound and 2 Soma.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 183.","owner":"Twrch Trwyth","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-twrch-trwyth-183","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":183,"role":"Minor NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a strong and fast boar, I know every corner of the island and all the secret paths.\nAgenda: Find food without getting caught.\nGift - Magic Boar: Whenever the Twrch Trwyth avoids \nan action by someone who is hunting him, he gets 1 Escape Token. As an action, and by spending 2 Escape Tokens, the Twrch Trwyth can leave the Scene without anyone being able to stop it. Even when dead, the body of the \nTwrch Trwyth continues to give off an inviting scent and \nglow with an intense magical light. Processing the Twrch \nTrwyth’s flesh can yield 1 Delightful Flesh token. Whoever \nconsumes it will recover 1 Wound and 2 Soma.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Find food without getting caught.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}}
{"_id":"bDjj0aC0XxxDrLgB","name":"Nikola’ Servants","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"UBafEpp0MeFHAEhb","name":"Nikola’ Servants - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>We live and work only to serve our master Nikola. We are skilled in handicrafts and in using the toy factory to eliminate any intruders.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 124.","positive":"We live and work only to serve our master Nikola. We are skilled in handicrafts and in using the toy factory to eliminate any intruders.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640649,"modifiedTime":1781557640649,"lastModifiedBy":null,"exportSource":null}},{"_id":"wibfPL4oZRQiddmt","name":"Gift - Enslaved to Nikola","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>While Nikola’s charm is active, \na Servant is immune to all mind control effects and cannot be manipulated by social interaction. Nikola’s charm is \nconsidered dark magic performed by a supernatural being.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 124.","somaCost":0,"automaticSuccesses":0,"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640649,"modifiedTime":1781557640649,"lastModifiedBy":null,"exportSource":null}},{"_id":"AiEhA1efHl4EHmhW","name":"Gift - Toymakers","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>As long as they are inside the factory, \na Servant receives the following effects.\n1. They increase their OL by 1 when acting to eliminate or \ncapture an intruder.\n2. They can move around the factory using hooks, toys \non wheels, and more without anyone being able to stop \nthem.\nNikola’s Mansion</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 124.","somaCost":0,"automaticSuccesses":0,"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640649,"modifiedTime":1781557640649,"lastModifiedBy":null,"exportSource":null}},{"_id":"koEOPto5Q7W7Rk3x","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We live and work only to serve our master Nikola. We are skilled in handicrafts and in using the toy factory to eliminate any intruders. \nAgenda: Produce high-quality toys and then ship them to \npoor children / Eliminate any intruder who is not a resident \nof Rovaniemi.\nGift - Enslaved to Nikola: While Nikola’s charm is active, \na Servant is immune to all mind control effects and cannot be manipulated by social interaction. Nikola’s charm is \nconsidered dark magic performed by a supernatural being. \nGift - Toymakers: As long as they are inside the factory, \na Servant receives the following effects.\n1. They increase their OL by 1 when acting to eliminate or \ncapture an intruder.\n2. They can move around the factory using hooks, toys \non wheels, and more without anyone being able to stop \nthem.\nNikola’s Mansion\nDescriptor: A small mansion, richly furnished and filled \nwith all sorts of occult heirlooms.\nInformation: The situation at the Mansion is different if \nthe Hunters arrive by day or by night.\nNight: Nikola is present and can fully use his powers. With \nhim are the 3 Helpers. \nDay: Nikola is resting in the crypt and will only wake up \nif he hears a racket at its entrance. The Helpers are present \nand active.\nA large painting in the main hall shows Nikola when he was \nstill a Wallachian nobleman. The painting is dated 1602. \nBelow the painting is a lever that, when pulled, opens the \ntrapdoor to Nikola’s crypt.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 124.","owner":"Nikola’ Servants","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640649,"modifiedTime":1781557640649,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-nikola-servants-124","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":124,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We live and work only to serve our master Nikola. We are skilled in handicrafts and in using the toy factory to eliminate any intruders. \nAgenda: Produce high-quality toys and then ship them to \npoor children / Eliminate any intruder who is not a resident \nof Rovaniemi.\nGift - Enslaved to Nikola: While Nikola’s charm is active, \na Servant is immune to all mind control effects and cannot be manipulated by social interaction. Nikola’s charm is \nconsidered dark magic performed by a supernatural being. \nGift - Toymakers: As long as they are inside the factory, \na Servant receives the following effects.\n1. They increase their OL by 1 when acting to eliminate or \ncapture an intruder.\n2. They can move around the factory using hooks, toys \non wheels, and more without anyone being able to stop \nthem.\nNikola’s Mansion\nDescriptor: A small mansion, richly furnished and filled \nwith all sorts of occult heirlooms.\nInformation: The situation at the Mansion is different if \nthe Hunters arrive by day or by night.\nNight: Nikola is present and can fully use his powers. With \nhim are the 3 Helpers. \nDay: Nikola is resting in the crypt and will only wake up \nif he hears a racket at its entrance. The Helpers are present \nand active.\nA large painting in the main hall shows Nikola when he was \nstill a Wallachian nobleman. The painting is dated 1602. \nBelow the painting is a lever that, when pulled, opens the \ntrapdoor to Nikola’s crypt.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Produce high-quality toys and then ship them to \npoor children / Eliminate any intruder who is not a resident \nof Rovaniemi.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640649,"modifiedTime":1781557640649,"lastModifiedBy":null,"exportSource":null}}
{"_id":"cdfqE4FCJrnaggRo","name":"Saxon Marauders","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"5sb4meHFne58B18H","name":"Saxon Marauders - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Saxon Marauders","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>We are fierce marauders who have come to \nAvalon to conquer the island. We are experts in group combat and support each other.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 181.","positive":"We are fierce marauders who have come to \nAvalon to conquer the island. We are experts in group combat and support each other.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Saxon Marauders","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643710,"modifiedTime":1781557643710,"lastModifiedBy":null,"exportSource":null}},{"_id":"YLXKUVPwwdDqCQQt","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Saxon Marauders","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are fierce marauders who have come to \nAvalon to conquer the island. We are experts in group combat and support each other. \nAgenda: Attack and capture anyone we meet along the way.\nGift - Marauders: When attacking an enemy, Marauders \nincrease their OL by 1 if they have numerical superiority.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 181.","owner":"Saxon Marauders","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643710,"modifiedTime":1781557643710,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-saxon-marauders-181","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":181,"role":"Minor NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are fierce marauders who have come to \nAvalon to conquer the island. We are experts in group combat and support each other. \nAgenda: Attack and capture anyone we meet along the way.\nGift - Marauders: When attacking an enemy, Marauders \nincrease their OL by 1 if they have numerical superiority.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Attack and capture anyone we meet along the way.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643710,"modifiedTime":1781557643710,"lastModifiedBy":null,"exportSource":null}}
{"_id":"daI8hCrdh9u3oA5l","name":"Intricate Maze","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"yWu2UinzpGPlxDx0","name":"Intricate Maze - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Intricate Maze","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>The great forest of Camelot is a tangle of vegetation perpetually shrouded in mist.\nIn case of Failure, the Storyteller decides which Zone the \nHunters will land in.\nThe Magic Glade\nDescriptor: A small clearing within a circle formed by ancient oaks. Inside, one can clearly feel the magic hovering in \nthe air, tickling the skin.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 192.","positive":"The great forest of Camelot is a tangle of vegetation perpetually shrouded in mist.\nIn case of Failure, the Storyteller decides which Zone the \nHunters will land in.\nThe Magic Glade\nDescriptor: A small clearing within a circle formed by ancient oaks. Inside, one can clearly feel the magic hovering in \nthe air, tickling the skin.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Intricate Maze","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644146,"modifiedTime":1781557644146,"lastModifiedBy":null,"exportSource":null}},{"_id":"Bjeuj31vunonWAGV","name":"Gift - Place of Peace and Magic","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Intricate Maze","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>The Magic Glade is \na place of peace and serenity. Those who rest in it for a few \nminutes recover 1 Soma. The same subject cannot benefit from this effect more than once per Scene. Invoking an \nInterlude within the Magic Glade does not generate an advancement in Merlin’s Agenda. \nThe Green Garden</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 192.","somaCost":0,"automaticSuccesses":0,"owner":"Intricate Maze","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644146,"modifiedTime":1781557644146,"lastModifiedBy":null,"exportSource":null}},{"_id":"ezPGlZD3gPUJUplC","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Intricate Maze","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Descriptor: The great forest of Camelot is a tangle of vegetation perpetually shrouded in mist.\nIn case of Failure, the Storyteller decides which Zone the \nHunters will land in.\nThe Magic Glade\nDescriptor: A small clearing within a circle formed by ancient oaks. Inside, one can clearly feel the magic hovering in \nthe air, tickling the skin.\nGift - Place of Peace and Magic: The Magic Glade is \na place of peace and serenity. Those who rest in it for a few \nminutes recover 1 Soma. The same subject cannot benefit from this effect more than once per Scene. Invoking an \nInterlude within the Magic Glade does not generate an advancement in Merlin’s Agenda. \nThe Green Garden\nDescriptor: A lush field of flowers, in the center of which \nstands a small stone altar engraved with pagan symbols. \nInformation: As soon as a subject enters the flowery \nfield, a figure covered in ancient armor and foliage stands \nthreateningly. The Green Knight will never leave the flower \nfield, remaining to defend the altar. The only way to avoid \nthe wrath of the Green Knight is to show respect to the ancient gods. By eliminating the Green Knight, the Hunters \ncan get their hands on the Treasure of the Order, the Ax of \nRetribution (page 192). \nThe Green Knight</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 192.","owner":"Intricate Maze","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644146,"modifiedTime":1781557644146,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-intricate-maze-192","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":192,"role":"Threat"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: The great forest of Camelot is a tangle of vegetation perpetually shrouded in mist.\nIn case of Failure, the Storyteller decides which Zone the \nHunters will land in.\nThe Magic Glade\nDescriptor: A small clearing within a circle formed by ancient oaks. Inside, one can clearly feel the magic hovering in \nthe air, tickling the skin.\nGift - Place of Peace and Magic: The Magic Glade is \na place of peace and serenity. Those who rest in it for a few \nminutes recover 1 Soma. The same subject cannot benefit from this effect more than once per Scene. Invoking an \nInterlude within the Magic Glade does not generate an advancement in Merlin’s Agenda. \nThe Green Garden\nDescriptor: A lush field of flowers, in the center of which \nstands a small stone altar engraved with pagan symbols. \nInformation: As soon as a subject enters the flowery \nfield, a figure covered in ancient armor and foliage stands \nthreateningly. The Green Knight will never leave the flower \nfield, remaining to defend the altar. The only way to avoid \nthe wrath of the Green Knight is to show respect to the ancient gods. By eliminating the Green Knight, the Hunters \ncan get their hands on the Treasure of the Order, the Ax of \nRetribution (page 192). \nThe Green Knight</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644146,"modifiedTime":1781557644146,"lastModifiedBy":null,"exportSource":null}}
{"_id":"eqQimfuVXQ5rhHbM","name":"The dregs of society, always ready to serve the King of Crime","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"2VYMCtPQKIBsIMno","name":"The dregs of society, always ready to serve the King of Crime - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>I am a lowlife who lives off theft and extortion. \nI draw strength from my fellow gang members and am not \nstupid enough to go at it alone.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","positive":"I am a lowlife who lives off theft and extortion. \nI draw strength from my fellow gang members and am not \nstupid enough to go at it alone.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639210,"modifiedTime":1781557639210,"lastModifiedBy":null,"exportSource":null}},{"_id":"7AZo9IInYRYUCLOV","name":"Gift - Band","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>Those who possess this Gift increase their \nOpposition Level by 1 when acting against a target with the \nsupport of one or more companions.\nSicario\nRuthless assassin in the pay of the King of Crime.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","somaCost":0,"automaticSuccesses":0,"owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639210,"modifiedTime":1781557639210,"lastModifiedBy":null,"exportSource":null}},{"_id":"sdRSoIBRCOGcLou5","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a lowlife who lives off theft and extortion. \nI draw strength from my fellow gang members and am not \nstupid enough to go at it alone. \nAgenda: Carry out the boss’s orders without asking too \nmany questions. \nGift - Band: Those who possess this Gift increase their \nOpposition Level by 1 when acting against a target with the \nsupport of one or more companions.\nSicario\nRuthless assassin in the pay of the King of Crime.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","owner":"The dregs of society, always ready to serve the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639210,"modifiedTime":1781557639210,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nemesis-the-dregs-of-society-always-ready-to-serve-the-king-of-crime-90","collection":"Lost Stories","adventureSlug":"nemesis","adventureTitle":"Nemesis","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":90,"role":"Minor NPC"}},"system":{"details":{"concept":"Nemesis","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a lowlife who lives off theft and extortion. \nI draw strength from my fellow gang members and am not \nstupid enough to go at it alone. \nAgenda: Carry out the boss’s orders without asking too \nmany questions. \nGift - Band: Those who possess this Gift increase their \nOpposition Level by 1 when acting against a target with the \nsupport of one or more companions.\nSicario\nRuthless assassin in the pay of the King of Crime.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Carry out the boss’s orders without asking too \nmany questions.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639210,"modifiedTime":1781557639210,"lastModifiedBy":null,"exportSource":null}}
{"_id":"fu7okVnWjuVMr9nJ","name":"Ruthless assassin in the pay of the King of Crime","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"wAI3vYczpMhHUpN0","name":"Ruthless assassin in the pay of the King of Crime - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>I am a capable killer and always act in cold \nblood.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","positive":"I am a capable killer and always act in cold \nblood.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639226,"modifiedTime":1781557639226,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZPZEqkRgPF98Dtsh","name":"Gift - Assassin","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>Those who possess this Gift increase \ntheir Opposition Level by 1 when acting from the shadows \nor in low light. When the NPC makes an attack that catches \nthe target by surprise, they inflict 1 Additional Wound. \nThe Raven Clan \nInspired by the Seven Ravens [Opponent)\nOnce upon a time, there was a family in which only sons \nwere born. The father and mother longed for a daughter \nand prayed for a long time to receive this grace. When the \nbaby girl finally arrived, the family’s enthusiasm quickly faded. The newborn was extremely weak and the doctor made \nit clear that she would not be saved without a miracle. The \nfather then sent the seven sons in search of a powerful witch \nwho lived not far from the village. When they arrived at the \nwitch’s house, the seven brothers were given a jar of magic \nwater that could give strength and vitality. The seven began \nto argue over who should carry the jar, as they all wanted to \nreceive compliments from their father. In the struggle, the jar \nfell to the ground and shattered into a thousand pieces, scattering the precious water. When they returned home, there \nwas nothing to do for their little sister. The father, in despair, \ncursed his children for fighting over the jar like greedy ravens \nover a piece of meat. The witch heard the man’s grief and, \nas punishment, turned the seven brothers into seven ravens, \nforever condemned to a life as watchers, never to be shown \naffection again.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","somaCost":0,"automaticSuccesses":0,"owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639226,"modifiedTime":1781557639226,"lastModifiedBy":null,"exportSource":null}},{"_id":"XVExalT5M8drKa5j","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"}},"system":{"description":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a capable killer and always act in cold \nblood. \nAgenda: Eliminate the Boss’ designated targets by striking \nfrom the shadows. \nGift - Assassin: Those who possess this Gift increase \ntheir Opposition Level by 1 when acting from the shadows \nor in low light. When the NPC makes an attack that catches \nthe target by surprise, they inflict 1 Additional Wound. \nThe Raven Clan \nInspired by the Seven Ravens [Opponent)\nOnce upon a time, there was a family in which only sons \nwere born. The father and mother longed for a daughter \nand prayed for a long time to receive this grace. When the \nbaby girl finally arrived, the family’s enthusiasm quickly faded. The newborn was extremely weak and the doctor made \nit clear that she would not be saved without a miracle. The \nfather then sent the seven sons in search of a powerful witch \nwho lived not far from the village. When they arrived at the \nwitch’s house, the seven brothers were given a jar of magic \nwater that could give strength and vitality. The seven began \nto argue over who should carry the jar, as they all wanted to \nreceive compliments from their father. In the struggle, the jar \nfell to the ground and shattered into a thousand pieces, scattering the precious water. When they returned home, there \nwas nothing to do for their little sister. The father, in despair, \ncursed his children for fighting over the jar like greedy ravens \nover a piece of meat. The witch heard the man’s grief and, \nas punishment, turned the seven brothers into seven ravens, \nforever condemned to a life as watchers, never to be shown \naffection again.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 90.","owner":"Ruthless assassin in the pay of the King of Crime","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639226,"modifiedTime":1781557639226,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nemesis-ruthless-assassin-in-the-pay-of-the-king-of-crime-90","collection":"Lost Stories","adventureSlug":"nemesis","adventureTitle":"Nemesis","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":90,"role":"Minor NPC"}},"system":{"details":{"concept":"Nemesis","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a capable killer and always act in cold \nblood. \nAgenda: Eliminate the Boss’ designated targets by striking \nfrom the shadows. \nGift - Assassin: Those who possess this Gift increase \ntheir Opposition Level by 1 when acting from the shadows \nor in low light. When the NPC makes an attack that catches \nthe target by surprise, they inflict 1 Additional Wound. \nThe Raven Clan \nInspired by the Seven Ravens [Opponent)\nOnce upon a time, there was a family in which only sons \nwere born. The father and mother longed for a daughter \nand prayed for a long time to receive this grace. When the \nbaby girl finally arrived, the family’s enthusiasm quickly faded. The newborn was extremely weak and the doctor made \nit clear that she would not be saved without a miracle. The \nfather then sent the seven sons in search of a powerful witch \nwho lived not far from the village. When they arrived at the \nwitch’s house, the seven brothers were given a jar of magic \nwater that could give strength and vitality. The seven began \nto argue over who should carry the jar, as they all wanted to \nreceive compliments from their father. In the struggle, the jar \nfell to the ground and shattered into a thousand pieces, scattering the precious water. When they returned home, there \nwas nothing to do for their little sister. The father, in despair, \ncursed his children for fighting over the jar like greedy ravens \nover a piece of meat. The witch heard the man’s grief and, \nas punishment, turned the seven brothers into seven ravens, \nforever condemned to a life as watchers, never to be shown \naffection again.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Eliminate the Boss’ designated targets by striking \nfrom the shadows.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639226,"modifiedTime":1781557639226,"lastModifiedBy":null,"exportSource":null}}
{"_id":"gFlKWo0MgxAqPZKa","name":"The Mother’s Heart","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"zts69yqPEZHqPgwU","name":"The Mother’s Heart - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Mother’s Heart","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>An agglomeration of floating garbage, pulsating like a rotting heart.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 108.","positive":"An agglomeration of floating garbage, pulsating like a rotting heart.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Mother’s Heart","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640070,"modifiedTime":1781557640070,"lastModifiedBy":null,"exportSource":null}},{"_id":"OW2WLUmIkCP1xuyG","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Mother’s Heart","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>- Minor NPC (6 Wounds)\nDescriptor: An agglomeration of floating garbage, pulsating like a rotting heart. \nGift - A Mother’s Fury: As soon as the Heart suffers \n1 Wound, Blanca will appear to defend it. The call of the \nHeart cannot be prevented in any way.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 108.","owner":"The Mother’s Heart","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640070,"modifiedTime":1781557640070,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-mothers-heart-the-mother-s-heart-108","collection":"Lost Stories","adventureSlug":"a-mothers-heart","adventureTitle":"A Mother's Heart","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":108,"role":"Minor NPC"}},"system":{"details":{"concept":"A Mother's Heart","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (6 Wounds)\nDescriptor: An agglomeration of floating garbage, pulsating like a rotting heart. \nGift - A Mother’s Fury: As soon as the Heart suffers \n1 Wound, Blanca will appear to defend it. The call of the \nHeart cannot be prevented in any way.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640070,"modifiedTime":1781557640070,"lastModifiedBy":null,"exportSource":null}}
{"_id":"gVk9uPyi546y0Nou","name":"Monsters Summoned by Aladdin","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"pEEkr1K8iq6diev6","name":"Monsters Summoned by Aladdin - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Monsters Summoned by Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>We are mindless monsters, using claws and \ntentacles to snatch prey.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","positive":"We are mindless monsters, using claws and \ntentacles to snatch prey.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Monsters Summoned by Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}},{"_id":"67ZFHVVEd641HxYh","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Monsters Summoned by Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC \n(2 Wounds - 4 Monsters)\nDescriptor: We are mindless monsters, using claws and \ntentacles to snatch prey.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","owner":"Monsters Summoned by Aladdin","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-monsters-summoned-by-aladdin-160","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":160,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC \n(2 Wounds - 4 Monsters)\nDescriptor: We are mindless monsters, using claws and \ntentacles to snatch prey.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}
{"_id":"gpLvPYdmihnTEIYA","name":"Nikola Lupei","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"6wvizxqQPqc3nds2","name":"Nikola Lupei - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a powerful vampire with a \ngood heart, and I just want to live in peace \nand quiet. The power I draw from blood \nmakes my body strong and fast.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 125.","positive":"I am a powerful vampire with a \ngood heart, and I just want to live in peace \nand quiet. The power I draw from blood \nmakes my body strong and fast.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640759,"modifiedTime":1781557640759,"lastModifiedBy":null,"exportSource":null}},{"_id":"kkeopnENB2o7E7Xv","name":"Gift - Power of the Vampire","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>The curse that plagues Nikola’s \nblood gives him great powers, but \nalso some weaknesses.\nPowers: Each can be used by Nikola once per Scene.\n1: Recover 1 Wound.\n2: Turn into mist.\n3: Enslave a subject with his gaze. Perform a Defense \nCheck against Nikola’s OL to resist. An enslaved subject \nshares what they see and hear with Nikola and will do \nwhatever the vampire commands. Nikola does not have to \nbe present to command the slave, but the subject must be \nawake and alert. Enslavement ends when the subject suffers 1 Wound.\nWeaknesses: Nikola cannot enter a place he has never been unless first invited by the person who lives there. \nWhen exposed to sunlight, Nikola loses 1 Wound per \nminute. Nikola can only be permanently eliminated if the \nlast of his Wounds is inflicted by a magical or consecrated \nweapon.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 125.","somaCost":0,"automaticSuccesses":0,"owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640759,"modifiedTime":1781557640759,"lastModifiedBy":null,"exportSource":null}},{"_id":"OzonhyHocNXSXxHW","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a powerful vampire with a \ngood heart, and I just want to live in peace \nand quiet. The power I draw from blood \nmakes my body strong and fast. \nAgenda: Find a way to get rid of the \nBadalisk without harming the people \nof Rovaniemi / Keep my secret and my \nlife in Rovaniemi. \nGift - Power of the Vampire: \nThe curse that plagues Nikola’s \nblood gives him great powers, but \nalso some weaknesses.\nPowers: Each can be used by Nikola once per Scene.\n1: Recover 1 Wound.\n2: Turn into mist.\n3: Enslave a subject with his gaze. Perform a Defense \nCheck against Nikola’s OL to resist. An enslaved subject \nshares what they see and hear with Nikola and will do \nwhatever the vampire commands. Nikola does not have to \nbe present to command the slave, but the subject must be \nawake and alert. Enslavement ends when the subject suffers 1 Wound.\nWeaknesses: Nikola cannot enter a place he has never been unless first invited by the person who lives there. \nWhen exposed to sunlight, Nikola loses 1 Wound per \nminute. Nikola can only be permanently eliminated if the \nlast of his Wounds is inflicted by a magical or consecrated \nweapon.\nGift - Occult Scholar: Nikola knows many rituals and \npossesses arcane objects to cast spells. He used these pow-</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 125.","owner":"Nikola Lupei","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640759,"modifiedTime":1781557640759,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-nikola-lupei-125","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":125,"role":"Main NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a powerful vampire with a \ngood heart, and I just want to live in peace \nand quiet. The power I draw from blood \nmakes my body strong and fast. \nAgenda: Find a way to get rid of the \nBadalisk without harming the people \nof Rovaniemi / Keep my secret and my \nlife in Rovaniemi. \nGift - Power of the Vampire: \nThe curse that plagues Nikola’s \nblood gives him great powers, but \nalso some weaknesses.\nPowers: Each can be used by Nikola once per Scene.\n1: Recover 1 Wound.\n2: Turn into mist.\n3: Enslave a subject with his gaze. Perform a Defense \nCheck against Nikola’s OL to resist. An enslaved subject \nshares what they see and hear with Nikola and will do \nwhatever the vampire commands. Nikola does not have to \nbe present to command the slave, but the subject must be \nawake and alert. Enslavement ends when the subject suffers 1 Wound.\nWeaknesses: Nikola cannot enter a place he has never been unless first invited by the person who lives there. \nWhen exposed to sunlight, Nikola loses 1 Wound per \nminute. Nikola can only be permanently eliminated if the \nlast of his Wounds is inflicted by a magical or consecrated \nweapon.\nGift - Occult Scholar: Nikola knows many rituals and \npossesses arcane objects to cast spells. He used these pow-</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Find a way to get rid of the \nBadalisk without harming the people \nof Rovaniemi / Keep my secret and my \nlife in Rovaniemi.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640759,"modifiedTime":1781557640759,"lastModifiedBy":null,"exportSource":null}}
{"_id":"h5wu3BJRfPbh0zVW","name":"Sir Dagonet the Madman","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"ru6jTOJk3M0RP167","name":"Sir Dagonet the Madman - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am a crazy, violent knight and I will not hesitate to use my sword to get what I want. No one can afford \nto ignore me.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","positive":"I am a crazy, violent knight and I will not hesitate to use my sword to get what I want. No one can afford \nto ignore me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}},{"_id":"kfOhwor5pr6KKFac","name":"Gift - Don’t Underestimate the Buffoon","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Dagonet is \na true master of foul play. During a battle, Dagonet can attempt a low blow in addition to his action and choose one \nof the following effects:\n1. Blade in the Boot: Dagonet draws it after attacking a \ntarget and inflicts 1 Additional Wound. Only a Hunter with \na dueling ability Descriptor can make a Defense Check to \navoid it.\n2. Sand in the Eyes: Activated before a Dagonet attack, \nthe target cannot use any of their Gifts during the Exchange.\n3. Find a Shield: When Dagonet is attacked, he can avoid \n1 Wound by having another closeby target hit instead. \nDagonet cannot use the same effect on the same target \nmore than once during the Scenario.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","somaCost":0,"automaticSuccesses":0,"owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}},{"_id":"SECmS9TqwAHdxuoU","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a crazy, violent knight and I will not hesitate to use my sword to get what I want. No one can afford \nto ignore me. \nAgenda: Eliminate any possible threat to my king / Find \nGuinevere, but instead of leading her back to Arthur, I plan \nto kill her and pass off her death as a tragic accident. \nGift - Don’t Underestimate the Buffoon: Dagonet is \na true master of foul play. During a battle, Dagonet can attempt a low blow in addition to his action and choose one \nof the following effects:\n1. Blade in the Boot: Dagonet draws it after attacking a \ntarget and inflicts 1 Additional Wound. Only a Hunter with \na dueling ability Descriptor can make a Defense Check to \navoid it.\n2. Sand in the Eyes: Activated before a Dagonet attack, \nthe target cannot use any of their Gifts during the Exchange.\n3. Find a Shield: When Dagonet is attacked, he can avoid \n1 Wound by having another closeby target hit instead. \nDagonet cannot use the same effect on the same target \nmore than once during the Scenario.\nInformation: Dagonet is a lunatic and will never reveal \nwhat he knows, even if he is defeated or tortured. However, \nbeing a true madman, it is possible to make him talk by \nprovoking him during combat. Dagonet is on a mission for \nArthur to find Guinevere, who has escaped from the castle. \nThe king has a soft spot for his queen and will not start the \nwar until she returns to his side. Dagonet also knows the \nwhereabouts of Percival, whom he now considers useless \nto the cause. He has even tried to kill him, but one way or \nanother, the knight always comes back to life (Zone 12 - \nCliff, page 197).\nThe Red Knight</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","owner":"Sir Dagonet the Madman","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-sir-dagonet-the-madman-184","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":184,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a crazy, violent knight and I will not hesitate to use my sword to get what I want. No one can afford \nto ignore me. \nAgenda: Eliminate any possible threat to my king / Find \nGuinevere, but instead of leading her back to Arthur, I plan \nto kill her and pass off her death as a tragic accident. \nGift - Don’t Underestimate the Buffoon: Dagonet is \na true master of foul play. During a battle, Dagonet can attempt a low blow in addition to his action and choose one \nof the following effects:\n1. Blade in the Boot: Dagonet draws it after attacking a \ntarget and inflicts 1 Additional Wound. Only a Hunter with \na dueling ability Descriptor can make a Defense Check to \navoid it.\n2. Sand in the Eyes: Activated before a Dagonet attack, \nthe target cannot use any of their Gifts during the Exchange.\n3. Find a Shield: When Dagonet is attacked, he can avoid \n1 Wound by having another closeby target hit instead. \nDagonet cannot use the same effect on the same target \nmore than once during the Scenario.\nInformation: Dagonet is a lunatic and will never reveal \nwhat he knows, even if he is defeated or tortured. However, \nbeing a true madman, it is possible to make him talk by \nprovoking him during combat. Dagonet is on a mission for \nArthur to find Guinevere, who has escaped from the castle. \nThe king has a soft spot for his queen and will not start the \nwar until she returns to his side. Dagonet also knows the \nwhereabouts of Percival, whom he now considers useless \nto the cause. He has even tried to kill him, but one way or \nanother, the knight always comes back to life (Zone 12 - \nCliff, page 197).\nThe Red Knight</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Eliminate any possible threat to my king / Find \nGuinevere, but instead of leading her back to Arthur, I plan \nto kill her and pass off her death as a tragic accident.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}}
{"_id":"i2ex3sEid5jautBg","name":"Restless Knights","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"U5c0xyL2kSmyyQOr","name":"Restless Knights - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Restless Knights","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>We are the souls of restless knights, resurrected \nat the behest of our king. Our decaying bodies advance ceaselessly, waiting to march to war.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 183.","positive":"We are the souls of restless knights, resurrected \nat the behest of our king. Our decaying bodies advance ceaselessly, waiting to march to war.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Restless Knights","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}},{"_id":"aZyVW0yJPhrCH9s4","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Restless Knights","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are the souls of restless knights, resurrected \nat the behest of our king. Our decaying bodies advance ceaselessly, waiting to march to war. \nAgenda: Kill all humans we come across to strengthen the \nranks of our king’s army. \nInformation: When encountered, the Storyteller rolls \n2d6 to determine the number of Restless Knights. Their \nhorde attacks all living creatures, making no distinction between Hunters and NPCs. If the horde is not destroyed, it \nmoves one Zone by attacking those it encounters. The Storyteller secretly decides which Zone the horde has moved \nto and does not make the Encounter roll when the Hunters arrive there. Any other damage done by the Peaceless \nKnights is at the discretion of the Storyteller.\nTwrch Trwyth</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 183.","owner":"Restless Knights","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-restless-knights-183","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":183,"role":"Minor NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are the souls of restless knights, resurrected \nat the behest of our king. Our decaying bodies advance ceaselessly, waiting to march to war. \nAgenda: Kill all humans we come across to strengthen the \nranks of our king’s army. \nInformation: When encountered, the Storyteller rolls \n2d6 to determine the number of Restless Knights. Their \nhorde attacks all living creatures, making no distinction between Hunters and NPCs. If the horde is not destroyed, it \nmoves one Zone by attacking those it encounters. The Storyteller secretly decides which Zone the horde has moved \nto and does not make the Encounter roll when the Hunters arrive there. Any other damage done by the Peaceless \nKnights is at the discretion of the Storyteller.\nTwrch Trwyth</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Kill all humans we come across to strengthen the \nranks of our king’s army.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643784,"modifiedTime":1781557643784,"lastModifiedBy":null,"exportSource":null}}
{"_id":"jT42NkONmpCcDEUN","name":"Tommi and Jutta","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"81qSurHAyVNskm0m","name":"Tommi and Jutta - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Tommi and Jutta","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>We are two young prospectors, made tough by \na life of hardship and strong by the love that unites us.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 118.","positive":"We are two young prospectors, made tough by \na life of hardship and strong by the love that unites us.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Tommi and Jutta","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640506,"modifiedTime":1781557640506,"lastModifiedBy":null,"exportSource":null}},{"_id":"uDgf8TfmXzsiNVvA","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Tommi and Jutta","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPCs (1 Wound)\nDescriptor: We are two young prospectors, made tough by \na life of hardship and strong by the love that unites us.\nAgenda: To save our son Lari from that absurd pledge.\nThe Village of Rovaniemi\nDescriptor: A small town of prospectors where everyone \nknows everyone else.\nInformation: The streets and the small square are littered \nwith gold panning equipment, carts, and baskets for sorting. The numerous wrought-iron plaques remind everyone \nthat these are all donations from Nikola Lupei. The villagers \nare shy towards the Hunters, avoiding any contact. \nRovaniemi Town Hall\nDescriptor: One of the few brick houses in the village. The \nimposing wrought iron door has a large plaque engraved with \nwords of gratitude for the town’s benefactor, Nikola Lupei.\nWhenever the Hunters visit the Town Hall, they will find 2 \nVillage Elders. The Storyteller can decide which ones they \nare, or roll a die to determine. The following information \ncan be obtained from all elders:\n ◆ A week ago, a Hunter from the Order arrived, asked \na few questions, then left for Nikola’s estate and was \nnever seen again. \n ◆ Nikola rarely comes to the Village now and seems to be \nvery busy. The villagers never go to him spontaneously, \nbut wait for him to show up.\nIt is possible to meet all the elders, but it takes time: for \nevery hour the Hunters spend in the Village, they can meet \none elder. \nThe Village Elders \n1: Asmo</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 118.","owner":"Tommi and Jutta","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640522,"modifiedTime":1781557640522,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-tommi-and-jutta-118","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":118,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPCs (1 Wound)\nDescriptor: We are two young prospectors, made tough by \na life of hardship and strong by the love that unites us.\nAgenda: To save our son Lari from that absurd pledge.\nThe Village of Rovaniemi\nDescriptor: A small town of prospectors where everyone \nknows everyone else.\nInformation: The streets and the small square are littered \nwith gold panning equipment, carts, and baskets for sorting. The numerous wrought-iron plaques remind everyone \nthat these are all donations from Nikola Lupei. The villagers \nare shy towards the Hunters, avoiding any contact. \nRovaniemi Town Hall\nDescriptor: One of the few brick houses in the village. The \nimposing wrought iron door has a large plaque engraved with \nwords of gratitude for the town’s benefactor, Nikola Lupei.\nWhenever the Hunters visit the Town Hall, they will find 2 \nVillage Elders. The Storyteller can decide which ones they \nare, or roll a die to determine. The following information \ncan be obtained from all elders:\n ◆ A week ago, a Hunter from the Order arrived, asked \na few questions, then left for Nikola’s estate and was \nnever seen again. \n ◆ Nikola rarely comes to the Village now and seems to be \nvery busy. The villagers never go to him spontaneously, \nbut wait for him to show up.\nIt is possible to meet all the elders, but it takes time: for \nevery hour the Hunters spend in the Village, they can meet \none elder. \nThe Village Elders \n1: Asmo</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"To save our son Lari from that absurd pledge.\nThe Village of Rovaniemi\nDescriptor: A small town of prospectors where everyone \nknows everyone else.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640522,"modifiedTime":1781557640522,"lastModifiedBy":null,"exportSource":null}}
{"_id":"kM2hGmHJnUN5LENC","name":"Reinsdyr the Guide","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"quMTsNTmirpo5oyf","name":"Reinsdyr the Guide - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Reinsdyr the Guide","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a very experienced guide and know all \nthe secrets of survival in the north. I can take down any enemy with ax and pistol without making too much of a fuss.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 215.","positive":"I am a very experienced guide and know all \nthe secrets of survival in the north. I can take down any enemy with ax and pistol without making too much of a fuss.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Reinsdyr the Guide","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645510,"modifiedTime":1781557645510,"lastModifiedBy":null,"exportSource":null}},{"_id":"QBS02HiO70soZWkx","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Reinsdyr the Guide","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a very experienced guide and know all \nthe secrets of survival in the north. I can take down any enemy with ax and pistol without making too much of a fuss. \nAgenda: Escort wealthy Frozen Madness victims to Pernille’s \nhouse and share the proceeds of the robberies with Rikke.\nGift – Die Hard: Reinsdyr is resilient and a difficult opponent even for Hunters. The guide can act twice during \nan Exchange, using his ax to hit an enemy in melee combat \nand his gun to hit a target at a distance. When he suffers \n1 Wound, Reinsdyr can immediately make an additional \nattack against the one who wounded him.\nEnd of Scene: With or without Reinsdyr, the Hunters \nmust go to Pernille’s house, go to SCENE THREE - The \nJourney.\n2b</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 215.","owner":"Reinsdyr the Guide","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645510,"modifiedTime":1781557645510,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-reinsdyr-the-guide-215","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":215,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a very experienced guide and know all \nthe secrets of survival in the north. I can take down any enemy with ax and pistol without making too much of a fuss. \nAgenda: Escort wealthy Frozen Madness victims to Pernille’s \nhouse and share the proceeds of the robberies with Rikke.\nGift – Die Hard: Reinsdyr is resilient and a difficult opponent even for Hunters. The guide can act twice during \nan Exchange, using his ax to hit an enemy in melee combat \nand his gun to hit a target at a distance. When he suffers \n1 Wound, Reinsdyr can immediately make an additional \nattack against the one who wounded him.\nEnd of Scene: With or without Reinsdyr, the Hunters \nmust go to Pernille’s house, go to SCENE THREE - The \nJourney.\n2b</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Escort wealthy Frozen Madness victims to Pernille’s \nhouse and share the proceeds of the robberies with Rikke.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645510,"modifiedTime":1781557645510,"lastModifiedBy":null,"exportSource":null}}
{"_id":"l83D0OgDURPWmq9W","name":"Ulrich Rotten Eye","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"DKexB79VB52AO5i6","name":"Ulrich Rotten Eye - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>I am a former criminal with experience in the \nuse of poisons. I opened my gambling den looking for a less \ndangerous life, but I don’t back down when there’s money to \nbe made.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","positive":"I am a former criminal with experience in the \nuse of poisons. I opened my gambling den looking for a less \ndangerous life, but I don’t back down when there’s money to \nbe made.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}},{"_id":"ge0a8MnXGXlVmoLE","name":"Gift - Poisoned Dagger","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>Ulrich’s weapon is imbued with \na powerful poison. The poison first enters play when the \nweapon inflicts 1 Wound, causing 1 Penalty to the target’s \nactions. The effect lasts until the victim takes an antidote or \nhas an Interlude. \nThreat - Poisoned Drink</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","somaCost":0,"automaticSuccesses":0,"owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}},{"_id":"lIVs4EZbGIdBKcSr","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a former criminal with experience in the \nuse of poisons. I opened my gambling den looking for a less \ndangerous life, but I don’t back down when there’s money to \nbe made.\nGift - Poisoned Dagger: Ulrich’s weapon is imbued with \na powerful poison. The poison first enters play when the \nweapon inflicts 1 Wound, causing 1 Penalty to the target’s \nactions. The effect lasts until the victim takes an antidote or \nhas an Interlude. \nThreat - Poisoned Drink</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","owner":"Ulrich Rotten Eye","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-ulrich-rotten-eye-138","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":138,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a former criminal with experience in the \nuse of poisons. I opened my gambling den looking for a less \ndangerous life, but I don’t back down when there’s money to \nbe made.\nGift - Poisoned Dagger: Ulrich’s weapon is imbued with \na powerful poison. The poison first enters play when the \nweapon inflicts 1 Wound, causing 1 Penalty to the target’s \nactions. The effect lasts until the victim takes an antidote or \nhas an Interlude. \nThreat - Poisoned Drink</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}}
{"_id":"o8tf2dgFQ5XWzFZa","name":"Bastian Soldat","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"suIOIhHPoNf87bxT","name":"Bastian Soldat - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Bastian Soldat","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>I am a deserter with no qualities other than a \ngreat desire to live a good life with minimal effort. My only \nvirtue is that I have incredible nerve.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 134.","positive":"I am a deserter with no qualities other than a \ngreat desire to live a good life with minimal effort. My only \nvirtue is that I have incredible nerve.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Bastian Soldat","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641302,"modifiedTime":1781557641302,"lastModifiedBy":null,"exportSource":null}},{"_id":"h9YJKJmpA5QZi9qB","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Bastian Soldat","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a deserter with no qualities other than a \ngreat desire to live a good life with minimal effort. My only \nvirtue is that I have incredible nerve.\nAgenda: Emptying the coffers of the Wagner family in order \nto pretend to be rich in Alena’s eyes and convince her to run \naway with me to Copenhagen. \nGift - Magic Tinderbox: Thanks to this powerful magical object, Bastian can go back in time whenever the situation would prevent him from completing his Agenda. This \nmagical effect cannot be stopped except by the magic word \nthat only Britta knows. Each time Bastian rewinds time, the \nStoryteller secretly accumulates 1 Reset Token. Each token</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 134.","owner":"Bastian Soldat","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641302,"modifiedTime":1781557641302,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-bastian-soldat-134","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":134,"role":"Main NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a deserter with no qualities other than a \ngreat desire to live a good life with minimal effort. My only \nvirtue is that I have incredible nerve.\nAgenda: Emptying the coffers of the Wagner family in order \nto pretend to be rich in Alena’s eyes and convince her to run \naway with me to Copenhagen. \nGift - Magic Tinderbox: Thanks to this powerful magical object, Bastian can go back in time whenever the situation would prevent him from completing his Agenda. This \nmagical effect cannot be stopped except by the magic word \nthat only Britta knows. Each time Bastian rewinds time, the \nStoryteller secretly accumulates 1 Reset Token. Each token</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Emptying the coffers of the Wagner family in order \nto pretend to be rich in Alena’s eyes and convince her to run \naway with me to Copenhagen.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641302,"modifiedTime":1781557641302,"lastModifiedBy":null,"exportSource":null}}
{"_id":"oWLUbcyu5IIEjLAE","name":"Magic Menhirs","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"4MqvVuXSybMltovs","name":"Magic Menhirs - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Magic Menhirs","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>A circle of ancient stones laid at the dawn of \ntime.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 197.","positive":"A circle of ancient stones laid at the dawn of \ntime.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Magic Menhirs","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644370,"modifiedTime":1781557644370,"lastModifiedBy":null,"exportSource":null}},{"_id":"Iy5Bqfi4Y4hSNYGQ","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Magic Menhirs","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Descriptor: A circle of ancient stones laid at the dawn of \ntime. \nGift - Magical Journey: Activating the power of the \nstones is easy, but getting exactly where you want to go is \nmuch less so. The journey requires a Position Check: with a \nsingle roll, the person activating the power can take all objects within the Circle with them. Depending on the result \nof the Check, different effects are achieved.\nFailure: Successful journey but the wrong destination. \nThe Storyteller chooses the arrival Zone from among those \nadjacent to the original destination. \nOutcome with a Cost: Successful journey but with some \ninterference. Each subject loses 1 Equipment decided by \nthe Storyteller. The missing Equipment has been transported in a Zone adjacent to the one of arrival.\nStandard Outcome: Successful trip, no problems. \nOutcome with an Increment: Complimentary panoramic view. Before arriving, travelers can observe the \ndestination while lingering safely in the astral dimension \nthey have traveled through. The Storyteller will reveal some \ninformation about the Zone.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 197.","owner":"Magic Menhirs","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644370,"modifiedTime":1781557644370,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-magic-menhirs-197","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":197,"role":"Threat"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A circle of ancient stones laid at the dawn of \ntime. \nGift - Magical Journey: Activating the power of the \nstones is easy, but getting exactly where you want to go is \nmuch less so. The journey requires a Position Check: with a \nsingle roll, the person activating the power can take all objects within the Circle with them. Depending on the result \nof the Check, different effects are achieved.\nFailure: Successful journey but the wrong destination. \nThe Storyteller chooses the arrival Zone from among those \nadjacent to the original destination. \nOutcome with a Cost: Successful journey but with some \ninterference. Each subject loses 1 Equipment decided by \nthe Storyteller. The missing Equipment has been transported in a Zone adjacent to the one of arrival.\nStandard Outcome: Successful trip, no problems. \nOutcome with an Increment: Complimentary panoramic view. Before arriving, travelers can observe the \ndestination while lingering safely in the astral dimension \nthey have traveled through. The Storyteller will reveal some \ninformation about the Zone.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644370,"modifiedTime":1781557644370,"lastModifiedBy":null,"exportSource":null}}
{"_id":"oyXjpDzqoYsRuf0H","name":"Crystal Rock","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"Va2ChMEt5x3ujEDx","name":"Crystal Rock - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a fragile, sharp agglomeration of crystal. \nThe wrong vibration can make me explode. \nNote: The Storyteller rolls 1 die or chooses from the list to \ncomplete the Threat Descriptor. \n1: A flock of seagulls nested among the rocks. \n2: Part of me juts underwater dangerously. \n3: My crystal is harder than normal. \n4: I am, in reality, a floating block moving without control.\n5: My crystal reflects sunlight much more intensely than nor -\nmal. I blind those who approach.\n6: I am filled with subtle overgrowths extending in every direction.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 157.","positive":"I am a fragile, sharp agglomeration of crystal. \nThe wrong vibration can make me explode. \nNote: The Storyteller rolls 1 die or chooses from the list to \ncomplete the Threat Descriptor. \n1: A flock of seagulls nested among the rocks. \n2: Part of me juts underwater dangerously. \n3: My crystal is harder than normal. \n4: I am, in reality, a floating block moving without control.\n5: My crystal reflects sunlight much more intensely than nor -\nmal. I blind those who approach.\n6: I am filled with subtle overgrowths extending in every direction.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642426,"modifiedTime":1781557642426,"lastModifiedBy":null,"exportSource":null}},{"_id":"bGPNFFOxeRhvo8gh","name":"Gift - Sensitive to Vibration","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>If a crystal is destroyed \nwithout obtaining a positive Outcome on a Check, the ship \nreceives 1 Damage Token. The person who caused the explosion gets 1 Wound and loses 1 Soma. If there are 2 or more \nDamage Tokens on the ship at the end of the Leg, Sinbad will \nnot be able to use his Gift - The Sailing Ship, regardless of \nwhether he is bored or not, and will go directly to the next \nLeg. \n“B” Legs (Second, Fifth, and Seventh)\nRoll 1 die to determine the Leg. Increase the result by 1 if you \nobtain a Leg you have already faced. Alternatively, choose directly which Leg you prefer to play.\n1B Raging Rocs\nNote: This Leg can only be played after Leg 3A - The Roc. If \nthe Hunters have not yet faced it, consider this a 1A roll.\nThe story that led us here...\nTwo huge winged figures appear in the sky, identical to the large \nbird that tried to nest on the ship. The creatures have huge boulders in their talons and seem intent on dropping them on the \ndeck. Sinbad begs the Hunters to save the ship before he cautiously flees below deck. \nPlace: Sinbad’s ship in the middle of the sea.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 157.","somaCost":0,"automaticSuccesses":0,"owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642426,"modifiedTime":1781557642426,"lastModifiedBy":null,"exportSource":null}},{"_id":"TdUir45E7oJ2Hzuo","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Descriptor: I am a fragile, sharp agglomeration of crystal. \nThe wrong vibration can make me explode. \nNote: The Storyteller rolls 1 die or chooses from the list to \ncomplete the Threat Descriptor. \n1: A flock of seagulls nested among the rocks. \n2: Part of me juts underwater dangerously. \n3: My crystal is harder than normal. \n4: I am, in reality, a floating block moving without control.\n5: My crystal reflects sunlight much more intensely than nor -\nmal. I blind those who approach.\n6: I am filled with subtle overgrowths extending in every direction.\nGift - Sensitive to Vibration: If a crystal is destroyed \nwithout obtaining a positive Outcome on a Check, the ship \nreceives 1 Damage Token. The person who caused the explosion gets 1 Wound and loses 1 Soma. If there are 2 or more \nDamage Tokens on the ship at the end of the Leg, Sinbad will \nnot be able to use his Gift - The Sailing Ship, regardless of \nwhether he is bored or not, and will go directly to the next \nLeg. \n“B” Legs (Second, Fifth, and Seventh)\nRoll 1 die to determine the Leg. Increase the result by 1 if you \nobtain a Leg you have already faced. Alternatively, choose directly which Leg you prefer to play.\n1B Raging Rocs\nNote: This Leg can only be played after Leg 3A - The Roc. If \nthe Hunters have not yet faced it, consider this a 1A roll.\nThe story that led us here...\nTwo huge winged figures appear in the sky, identical to the large \nbird that tried to nest on the ship. The creatures have huge boulders in their talons and seem intent on dropping them on the \ndeck. Sinbad begs the Hunters to save the ship before he cautiously flees below deck. \nPlace: Sinbad’s ship in the middle of the sea. \nInformation: Sinbad has hidden a Roc egg that he secretly \nretrieved from the nest the last time around. The old sailor is \ntoo greedy to return it, and intends to use the Hunters to get \nrid of the two Rocs. \nChallenges: Deflect the fall of the 4 boulders the Rocs intend to drop on the ship and convince Sinbad to return the \negg.\nHow to get the Tarì: When the egg is returned, one of the \nRocs will drop the coin on the deck of the ship. \nRoc\nSee Dark Presence on page 13.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 157.","owner":"Crystal Rock","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642426,"modifiedTime":1781557642426,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-crystal-rock-157","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":157,"role":"Threat"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: I am a fragile, sharp agglomeration of crystal. \nThe wrong vibration can make me explode. \nNote: The Storyteller rolls 1 die or chooses from the list to \ncomplete the Threat Descriptor. \n1: A flock of seagulls nested among the rocks. \n2: Part of me juts underwater dangerously. \n3: My crystal is harder than normal. \n4: I am, in reality, a floating block moving without control.\n5: My crystal reflects sunlight much more intensely than nor -\nmal. I blind those who approach.\n6: I am filled with subtle overgrowths extending in every direction.\nGift - Sensitive to Vibration: If a crystal is destroyed \nwithout obtaining a positive Outcome on a Check, the ship \nreceives 1 Damage Token. The person who caused the explosion gets 1 Wound and loses 1 Soma. If there are 2 or more \nDamage Tokens on the ship at the end of the Leg, Sinbad will \nnot be able to use his Gift - The Sailing Ship, regardless of \nwhether he is bored or not, and will go directly to the next \nLeg. \n“B” Legs (Second, Fifth, and Seventh)\nRoll 1 die to determine the Leg. Increase the result by 1 if you \nobtain a Leg you have already faced. Alternatively, choose directly which Leg you prefer to play.\n1B Raging Rocs\nNote: This Leg can only be played after Leg 3A - The Roc. If \nthe Hunters have not yet faced it, consider this a 1A roll.\nThe story that led us here...\nTwo huge winged figures appear in the sky, identical to the large \nbird that tried to nest on the ship. The creatures have huge boulders in their talons and seem intent on dropping them on the \ndeck. Sinbad begs the Hunters to save the ship before he cautiously flees below deck. \nPlace: Sinbad’s ship in the middle of the sea. \nInformation: Sinbad has hidden a Roc egg that he secretly \nretrieved from the nest the last time around. The old sailor is \ntoo greedy to return it, and intends to use the Hunters to get \nrid of the two Rocs. \nChallenges: Deflect the fall of the 4 boulders the Rocs intend to drop on the ship and convince Sinbad to return the \negg.\nHow to get the Tarì: When the egg is returned, one of the \nRocs will drop the coin on the deck of the ship. \nRoc\nSee Dark Presence on page 13.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642426,"modifiedTime":1781557642426,"lastModifiedBy":null,"exportSource":null}}
{"_id":"p69rVus9bbNmcSzs","name":"2: Elna","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"OOTD94taDGWuNY8Y","name":"2: Elna - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"2: Elna","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a good weaver and know many legends \nof the area.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","positive":"I am a good weaver and know many legends \nof the area.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"2: Elna","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640549,"modifiedTime":1781557640549,"lastModifiedBy":null,"exportSource":null}},{"_id":"huMvDxTKd46NCTQj","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"2: Elna","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a good weaver and know many legends \nof the area.\nAgenda: I want my daughter Jaana to come home, but \nwithout openly siding against Nikola Lupei.\nInformation: Elna’s family is among those who did not \ninitially pay the pledge, and her daughter Jaana has disappeared. The old woman will tell you that her daughter is \nwell and has settled in Nikola’s mansion, where she works \nas a toy factory worker. When questioned about the night \nof the disappearance, Elna will say that no one noticed anything and that there were no signs of forced entry. Talking \nto Elna, it will become clear that she misses her daughter \nvery much. \n3: Mikko</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","owner":"2: Elna","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640549,"modifiedTime":1781557640549,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-2-elna-119","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":119,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a good weaver and know many legends \nof the area.\nAgenda: I want my daughter Jaana to come home, but \nwithout openly siding against Nikola Lupei.\nInformation: Elna’s family is among those who did not \ninitially pay the pledge, and her daughter Jaana has disappeared. The old woman will tell you that her daughter is \nwell and has settled in Nikola’s mansion, where she works \nas a toy factory worker. When questioned about the night \nof the disappearance, Elna will say that no one noticed anything and that there were no signs of forced entry. Talking \nto Elna, it will become clear that she misses her daughter \nvery much. \n3: Mikko</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"I want my daughter Jaana to come home, but \nwithout openly siding against Nikola Lupei.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640549,"modifiedTime":1781557640549,"lastModifiedBy":null,"exportSource":null}}
{"_id":"pF0qJYpDhPtMt1JL","name":"Lene’s Cutthroat","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"vezMUVekVImCVyVi","name":"Lene’s Cutthroat - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lene’s Cutthroat","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>We are ruthless scoundrels and protect our territory from any intruder.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 209.","positive":"We are ruthless scoundrels and protect our territory from any intruder.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Lene’s Cutthroat","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}},{"_id":"RFsIvcZ2iDSoozcO","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Lene’s Cutthroat","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Minor NPC \n(1 Wound - 12 Gang Members)\nDescriptor: We are ruthless scoundrels and protect our territory from any intruder.\nGift - Neighborhood Gang: A Cutthroat increases their \nOL by 1 when they act to wound or capture a target they \nconsider an intruder on their territory. \nEnd of Scene: The Hunters decide to meet the Black \nFeathers. Go to the THIRD SCENE - The Ambush of the \nBlack Feathers. If they decide to meet Flora instead, go to \nSECOND SCENE OPTION A - Flora’s Greenhouse.\n2b</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 209.","owner":"Lene’s Cutthroat","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-lene-s-cutthroat-209","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":209,"role":"Minor NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC \n(1 Wound - 12 Gang Members)\nDescriptor: We are ruthless scoundrels and protect our territory from any intruder.\nGift - Neighborhood Gang: A Cutthroat increases their \nOL by 1 when they act to wound or capture a target they \nconsider an intruder on their territory. \nEnd of Scene: The Hunters decide to meet the Black \nFeathers. Go to the THIRD SCENE - The Ambush of the \nBlack Feathers. If they decide to meet Flora instead, go to \nSECOND SCENE OPTION A - Flora’s Greenhouse.\n2b</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645177,"modifiedTime":1781557645177,"lastModifiedBy":null,"exportSource":null}}
{"_id":"pi9Lq1h4SeB6m7UP","name":"The Badalisk","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"6woIiWzSfzfWxcD0","name":"The Badalisk - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a huge dirty red sack encrusted with the \nbloody remains of past meals. I have a large mouth with \nwhich I devour my prey in one gulp.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","positive":"I am a huge dirty red sack encrusted with the \nbloody remains of past meals. I have a large mouth with \nwhich I devour my prey in one gulp.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}},{"_id":"qUJcVl3EUQZctM9W","name":"Gift - Huge Mouth","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>When the Badalisk attacks a target \nand the target fails their Defense Check, the Badalisk can \nchoose between two effects:\n1. Inflicts 1 additional Wound with its bite. The target can \nalso be thrown a distance of thirty feet or have one of its \npieces of equipment swallowed by the Badalisk.\n2. Swallow the target so that they end up in its giant belly. \nThis effect can also be activated when the target gains an \nOutcome with a Cost on a Defense Check, but in this \ncase, they will only lose one piece of equipment as it is \nswallowed by the giant maw.\nA subject trapped inside the Badalisk can use their action to \nactively attempt to escape. Depending on their ability, this \nwill be resolved as follows:</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","somaCost":0,"automaticSuccesses":0,"owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}},{"_id":"9JLoS5FeoeaSAPmr","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a huge dirty red sack encrusted with the \nbloody remains of past meals. I have a large mouth with \nwhich I devour my prey in one gulp. \nAgenda: Eating whatever comes my way to satiate my endless hunger. \nGift - Huge Mouth: When the Badalisk attacks a target \nand the target fails their Defense Check, the Badalisk can \nchoose between two effects:\n1. Inflicts 1 additional Wound with its bite. The target can \nalso be thrown a distance of thirty feet or have one of its \npieces of equipment swallowed by the Badalisk.\n2. Swallow the target so that they end up in its giant belly. \nThis effect can also be activated when the target gains an \nOutcome with a Cost on a Defense Check, but in this \ncase, they will only lose one piece of equipment as it is \nswallowed by the giant maw.\nA subject trapped inside the Badalisk can use their action to \nactively attempt to escape. Depending on their ability, this \nwill be resolved as follows:</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 122.","owner":"The Badalisk","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-the-badalisk-122","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":122,"role":"Main NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a huge dirty red sack encrusted with the \nbloody remains of past meals. I have a large mouth with \nwhich I devour my prey in one gulp. \nAgenda: Eating whatever comes my way to satiate my endless hunger. \nGift - Huge Mouth: When the Badalisk attacks a target \nand the target fails their Defense Check, the Badalisk can \nchoose between two effects:\n1. Inflicts 1 additional Wound with its bite. The target can \nalso be thrown a distance of thirty feet or have one of its \npieces of equipment swallowed by the Badalisk.\n2. Swallow the target so that they end up in its giant belly. \nThis effect can also be activated when the target gains an \nOutcome with a Cost on a Defense Check, but in this \ncase, they will only lose one piece of equipment as it is \nswallowed by the giant maw.\nA subject trapped inside the Badalisk can use their action to \nactively attempt to escape. Depending on their ability, this \nwill be resolved as follows:</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"Eating whatever comes my way to satiate my endless hunger.","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640618,"modifiedTime":1781557640618,"lastModifiedBy":null,"exportSource":null}}
{"_id":"pvQm5fhsSAFm9qZ4","name":"Subjects of great skill who serve the Wise Fairy to uphold justice","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"2fywsOORUOPyFCeg","name":"Subjects of great skill who serve the Wise Fairy to uphold justice - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Subjects of great skill who serve the Wise Fairy to uphold justice","source":"Nemesis","category":"threat"}},"system":{"description":"<p>I am a hero, always ready to fight for the Wise \nFairy. I have a one-sided view of the truth and only believe \nwhat my lady says.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 93.","positive":"I am a hero, always ready to fight for the Wise \nFairy. I have a one-sided view of the truth and only believe \nwhat my lady says.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Subjects of great skill who serve the Wise Fairy to uphold justice","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639362,"modifiedTime":1781557639362,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZMjZQ0d9nMCIW8Tf","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Subjects of great skill who serve the Wise Fairy to uphold justice","source":"Nemesis","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a hero, always ready to fight for the Wise \nFairy. I have a one-sided view of the truth and only believe \nwhat my lady says. \nAgenda: Fulfilling every wish of the Wise Fairy. \nGift - Heroic Soul: The NPC will even ignore death to \nsatisfy the Wise Fairy. When they suffer their final Wound, \nthey can act one last time before leaving the battle. When \nthey enter the Scene, they can use a power granted by the \nWand of Creation, complete with a Descriptor created by \nthe Storyteller.</p>","notes":"Nemesis - bt-ls-book-1-ENG-SCREEN.pdf, page 93.","owner":"Subjects of great skill who serve the Wise Fairy to uphold justice","source":"Nemesis","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639362,"modifiedTime":1781557639362,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nemesis-subjects-of-great-skill-who-serve-the-wise-fairy-to-uphold-justice-93","collection":"Lost Stories","adventureSlug":"nemesis","adventureTitle":"Nemesis","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":93,"role":"Minor NPC"}},"system":{"details":{"concept":"Nemesis","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a hero, always ready to fight for the Wise \nFairy. I have a one-sided view of the truth and only believe \nwhat my lady says. \nAgenda: Fulfilling every wish of the Wise Fairy. \nGift - Heroic Soul: The NPC will even ignore death to \nsatisfy the Wise Fairy. When they suffer their final Wound, \nthey can act one last time before leaving the battle. When \nthey enter the Scene, they can use a power granted by the \nWand of Creation, complete with a Descriptor created by \nthe Storyteller.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Fulfilling every wish of the Wise Fairy.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639362,"modifiedTime":1781557639362,"lastModifiedBy":null,"exportSource":null}}
{"_id":"pySHxt3kDSkvDH8T","name":"Poisoned Drink","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"VBvXRKEiKsFMj39P","name":"Poisoned Drink - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Poisoned Drink","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>A fine, tasteless, odorless poison that can be \nadded to any beverage.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","positive":"A fine, tasteless, odorless poison that can be \nadded to any beverage.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Poisoned Drink","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}},{"_id":"qBgJQ6ZHI2HVrlt8","name":"Gift - Poison","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Poisoned Drink","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>Those who ingest the Poisoned Drink suffer 1 Wound and receive 1 Penalty until they take an antidote or rest in an Interlude. \nVilla Wagner</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","somaCost":0,"automaticSuccesses":0,"owner":"Poisoned Drink","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}},{"_id":"g5OtVJvUPkRtvdBa","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Poisoned Drink","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>Descriptor: A fine, tasteless, odorless poison that can be \nadded to any beverage. \nGift - Poison: Those who ingest the Poisoned Drink suffer 1 Wound and receive 1 Penalty until they take an antidote or rest in an Interlude. \nVilla Wagner\nDescriptor: An imposing mansion surrounded by gardens, \nponds, and mazes of hedges. \nInformation: It’s impossible to enter the Villa without an \ninvitation from the Wagner family, but there are no fences \nand, except for a few gardeners, it is easy to wander inconspicuously around the large gardens. Alena is often found \non the large balcony of her room on the second floor, reading a good book and sipping tea. Alena will tell you that \nBastian often brings her very good and expensive cakes that \nhe buys at the famous Golden Plate Tavern. The young woman is unclear about who Bastian really is, but it will be obvious that she is attracted to the funny little man and finds \nhis awkward attempts to court her tender.\nIf Bastian is present: He will be under Alena’s balcony \nreciting some love poetry. As soon as he sees the Hunters, \nhe will try to escape by slipping into one of the hedge mazes.\nIf the Black Cat is present: It can be seen on the balcony being petted by Alena. The Cat pretends to purr in \naffection as she clearly tries to snatch a pendant from the \nyoung woman’s neck.\nFirst Reset: If this is the first time he encounters the \nHunters in this Place, Bastian will try to escape. However, \nif the Hunters have already met him here, Bastian will not \nappear again.\nSecond Reset: Same as the First Reset, except that a \ngroup of guards (2 per Hunter) will enter the Scene when \nthe Hunters approach Alena. The leader of the guards will \nsay that by Lord Wagner’s order, no one can enter the garden of the Villa. If the Hunters can get the captain to talk</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 138.","owner":"Poisoned Drink","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-poisoned-drink-138","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":138,"role":"Threat"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A fine, tasteless, odorless poison that can be \nadded to any beverage. \nGift - Poison: Those who ingest the Poisoned Drink suffer 1 Wound and receive 1 Penalty until they take an antidote or rest in an Interlude. \nVilla Wagner\nDescriptor: An imposing mansion surrounded by gardens, \nponds, and mazes of hedges. \nInformation: It’s impossible to enter the Villa without an \ninvitation from the Wagner family, but there are no fences \nand, except for a few gardeners, it is easy to wander inconspicuously around the large gardens. Alena is often found \non the large balcony of her room on the second floor, reading a good book and sipping tea. Alena will tell you that \nBastian often brings her very good and expensive cakes that \nhe buys at the famous Golden Plate Tavern. The young woman is unclear about who Bastian really is, but it will be obvious that she is attracted to the funny little man and finds \nhis awkward attempts to court her tender.\nIf Bastian is present: He will be under Alena’s balcony \nreciting some love poetry. As soon as he sees the Hunters, \nhe will try to escape by slipping into one of the hedge mazes.\nIf the Black Cat is present: It can be seen on the balcony being petted by Alena. The Cat pretends to purr in \naffection as she clearly tries to snatch a pendant from the \nyoung woman’s neck.\nFirst Reset: If this is the first time he encounters the \nHunters in this Place, Bastian will try to escape. However, \nif the Hunters have already met him here, Bastian will not \nappear again.\nSecond Reset: Same as the First Reset, except that a \ngroup of guards (2 per Hunter) will enter the Scene when \nthe Hunters approach Alena. The leader of the guards will \nsay that by Lord Wagner’s order, no one can enter the garden of the Villa. If the Hunters can get the captain to talk</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641569,"modifiedTime":1781557641569,"lastModifiedBy":null,"exportSource":null}}
{"_id":"q8hSV9JrLJ6VvD74","name":"Snow of Memory","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"ppMmtHlWyy9NhYBW","name":"Snow of Memory - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>Tiny snowflakes that can freeze a person’s \nmemories forever until they forget everything.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 223.","positive":"Tiny snowflakes that can freeze a person’s \nmemories forever until they forget everything.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646114,"modifiedTime":1781557646114,"lastModifiedBy":null,"exportSource":null}},{"_id":"hUtEj55i5SheCfkl","name":"Gift - Ice Oblivion","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>For each minute a subject is under \nthe snowfall, it is touched by a number of flakes equal to \nthe result of a die roll. The result determines the effect to be \napplied. If the subject does nothing to protect themselves \nfrom the snow, they cannot make a Defense Check against \nthe Threat. The Storyteller must evaluate, based on protective measures and the subject’s clothing, whether they are \nmore exposed to snowflakes (roll 2 dice and choose the \nhigher value) or are more sheltered (roll 2 dice and choose \nthe lower value). \n1-2: A severe headache accompanies a cherished memory \nthat slowly fades, leaving the target with the perception of \nan event lost forever. The target loses 2 Soma. An NPC reduces their OL by 1 for the remainder of the Scenario.\n3-4: The face of a loved one appears fleetingly in the tar -\nget’s mind before disappearing, leaving them with the feeling of having lost the memory of a loved one. The target \nloses the use of one of their Descriptors (except the Dark \nEgo) until the end of the Scenario. An NPC loses their only \nDescriptor and replaces it with this one: I’ve lost my memory and have no idea where I am. \n5-6: The target hears a phrase whispered so quietly it is \nunintelligible, leaving them with the perception that a part \nof themselves is lost forever. The target loses the use of one \nGift for the rest of the Scenario (except Dark Ego). An NPC \nwho has no Gifts to lose reduces their OL by one category. If</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 223.","somaCost":0,"automaticSuccesses":0,"owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646114,"modifiedTime":1781557646114,"lastModifiedBy":null,"exportSource":null}},{"_id":"V9aJY05GLgkOoih7","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>Descriptor: Tiny snowflakes that can freeze a person’s \nmemories forever until they forget everything. \nGift - Ice Oblivion: For each minute a subject is under \nthe snowfall, it is touched by a number of flakes equal to \nthe result of a die roll. The result determines the effect to be \napplied. If the subject does nothing to protect themselves \nfrom the snow, they cannot make a Defense Check against \nthe Threat. The Storyteller must evaluate, based on protective measures and the subject’s clothing, whether they are \nmore exposed to snowflakes (roll 2 dice and choose the \nhigher value) or are more sheltered (roll 2 dice and choose \nthe lower value). \n1-2: A severe headache accompanies a cherished memory \nthat slowly fades, leaving the target with the perception of \nan event lost forever. The target loses 2 Soma. An NPC reduces their OL by 1 for the remainder of the Scenario.\n3-4: The face of a loved one appears fleetingly in the tar -\nget’s mind before disappearing, leaving them with the feeling of having lost the memory of a loved one. The target \nloses the use of one of their Descriptors (except the Dark \nEgo) until the end of the Scenario. An NPC loses their only \nDescriptor and replaces it with this one: I’ve lost my memory and have no idea where I am. \n5-6: The target hears a phrase whispered so quietly it is \nunintelligible, leaving them with the perception that a part \nof themselves is lost forever. The target loses the use of one \nGift for the rest of the Scenario (except Dark Ego). An NPC \nwho has no Gifts to lose reduces their OL by one category. If</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 223.","owner":"Snow of Memory","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646114,"modifiedTime":1781557646114,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-snow-of-memory-223","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":223,"role":"Threat"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: Tiny snowflakes that can freeze a person’s \nmemories forever until they forget everything. \nGift - Ice Oblivion: For each minute a subject is under \nthe snowfall, it is touched by a number of flakes equal to \nthe result of a die roll. The result determines the effect to be \napplied. If the subject does nothing to protect themselves \nfrom the snow, they cannot make a Defense Check against \nthe Threat. The Storyteller must evaluate, based on protective measures and the subject’s clothing, whether they are \nmore exposed to snowflakes (roll 2 dice and choose the \nhigher value) or are more sheltered (roll 2 dice and choose \nthe lower value). \n1-2: A severe headache accompanies a cherished memory \nthat slowly fades, leaving the target with the perception of \nan event lost forever. The target loses 2 Soma. An NPC reduces their OL by 1 for the remainder of the Scenario.\n3-4: The face of a loved one appears fleetingly in the tar -\nget’s mind before disappearing, leaving them with the feeling of having lost the memory of a loved one. The target \nloses the use of one of their Descriptors (except the Dark \nEgo) until the end of the Scenario. An NPC loses their only \nDescriptor and replaces it with this one: I’ve lost my memory and have no idea where I am. \n5-6: The target hears a phrase whispered so quietly it is \nunintelligible, leaving them with the perception that a part \nof themselves is lost forever. The target loses the use of one \nGift for the rest of the Scenario (except Dark Ego). An NPC \nwho has no Gifts to lose reduces their OL by one category. If</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646114,"modifiedTime":1781557646114,"lastModifiedBy":null,"exportSource":null}}
{"_id":"qLJlCXxy6Tf8IRVT","name":"Pepe","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"kDnohm4DbStp2Q4U","name":"Pepe - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pepe","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>I am the leader of the Bats and responsible for the sur -\nvival of my companions. I am brave and skilled with knives, and I like \nto whistle my mother’s lullaby, a happy memory from my childhood.</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 105.","positive":"I am the leader of the Bats and responsible for the sur -\nvival of my companions. I am brave and skilled with knives, and I like \nto whistle my mother’s lullaby, a happy memory from my childhood.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Pepe","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}},{"_id":"iLLt1u6QG3HvUXcv","name":"Gift - Big Brother","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pepe","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>Pepe will not allow anyone to harm his comrades. Against a target that threatens a Bat, Pepe inflicts 1 Additional \nWound. All Bats increase their OL by 1 when Pepe is present. \nThe Gang of Bats</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 105.","somaCost":0,"automaticSuccesses":0,"owner":"Pepe","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}},{"_id":"tnZFvvvkYuZ48tiW","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Pepe","source":"A Mother's Heart","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am the leader of the Bats and responsible for the sur -\nvival of my companions. I am brave and skilled with knives, and I like \nto whistle my mother’s lullaby, a happy memory from my childhood.\nAgenda: Robbing the people of Murcia as revenge for their indiffer -\nence to those who have nothing / Taking care of the Bats, whom I consider my new family. \nGift - Big Brother: Pepe will not allow anyone to harm his comrades. Against a target that threatens a Bat, Pepe inflicts 1 Additional \nWound. All Bats increase their OL by 1 when Pepe is present. \nThe Gang of Bats</p>","notes":"A Mother's Heart - bt-ls-book-1-ENG-SCREEN.pdf, page 105.","owner":"Pepe","source":"A Mother's Heart","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-mothers-heart-pepe-105","collection":"Lost Stories","adventureSlug":"a-mothers-heart","adventureTitle":"A Mother's Heart","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":105,"role":"Main NPC"}},"system":{"details":{"concept":"A Mother's Heart","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am the leader of the Bats and responsible for the sur -\nvival of my companions. I am brave and skilled with knives, and I like \nto whistle my mother’s lullaby, a happy memory from my childhood.\nAgenda: Robbing the people of Murcia as revenge for their indiffer -\nence to those who have nothing / Taking care of the Bats, whom I consider my new family. \nGift - Big Brother: Pepe will not allow anyone to harm his comrades. Against a target that threatens a Bat, Pepe inflicts 1 Additional \nWound. All Bats increase their OL by 1 when Pepe is present. \nThe Gang of Bats</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Robbing the people of Murcia as revenge for their indiffer -\nence to those who have nothing / Taking care of the Bats, whom I consider my new family.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557639930,"modifiedTime":1781557639930,"lastModifiedBy":null,"exportSource":null}}
{"_id":"qmNupbdbncTjr6qY","name":"Gerda the Swindler","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"qwgPyiMjUuShiYqm","name":"Gerda the Swindler - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Gerda the Swindler","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a skilled trickster, my sharp mind matched \nonly by my nerve. While studying Lady Storm’s books, I discovered that I can also dabble in magic, and I have no qualms \nabout using it to my own advantage.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 224.","positive":"I am a skilled trickster, my sharp mind matched \nonly by my nerve. While studying Lady Storm’s books, I discovered that I can also dabble in magic, and I have no qualms \nabout using it to my own advantage.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Gerda the Swindler","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646208,"modifiedTime":1781557646208,"lastModifiedBy":null,"exportSource":null}},{"_id":"DLJjtuf9kiNGCKyc","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Gerda the Swindler","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a skilled trickster, my sharp mind matched \nonly by my nerve. While studying Lady Storm’s books, I discovered that I can also dabble in magic, and I have no qualms \nabout using it to my own advantage. \nAgenda: Living in luxury without working and increasing \nmy power to get my hands on more wealth / Supporting Kay \nin his whims, because even though I think he is an idiot, I \nneed a trustworthy sidekick who will always do what I say. \nShard Descriptor: I am a naive girl who struggles \nto express her feelings. Thanks to the magic I have learned, I \ncan help others. \nShard Agenda: Save my beloved Kay from the sad \nfate that befell him / Defeat the Ice Heart.\nGift - Power of the Shard: The Shard of the Mirror of \nthe Other Self reverses the Descriptor and Agenda of the \nperson it injured. The holder increases their OL by 1 if they \nact in accordance with the altered part of their Descriptor \nor Agenda.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 224.","owner":"Gerda the Swindler","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646208,"modifiedTime":1781557646208,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-gerda-the-swindler-224","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":224,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a skilled trickster, my sharp mind matched \nonly by my nerve. While studying Lady Storm’s books, I discovered that I can also dabble in magic, and I have no qualms \nabout using it to my own advantage. \nAgenda: Living in luxury without working and increasing \nmy power to get my hands on more wealth / Supporting Kay \nin his whims, because even though I think he is an idiot, I \nneed a trustworthy sidekick who will always do what I say. \nShard Descriptor: I am a naive girl who struggles \nto express her feelings. Thanks to the magic I have learned, I \ncan help others. \nShard Agenda: Save my beloved Kay from the sad \nfate that befell him / Defeat the Ice Heart.\nGift - Power of the Shard: The Shard of the Mirror of \nthe Other Self reverses the Descriptor and Agenda of the \nperson it injured. The holder increases their OL by 1 if they \nact in accordance with the altered part of their Descriptor \nor Agenda.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Living in luxury without working and increasing \nmy power to get my hands on more wealth / Supporting Kay \nin his whims, because even though I think he is an idiot, I \nneed a trustworthy sidekick who will always do what I say. \nShard Descriptor: I am a naive girl who struggles \nto express her feelings. Thanks to the magic I have learned, I \ncan help others. \nShard Agenda: Save my beloved Kay from the sad \nfate that befell him / Defeat the Ice Heart.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646208,"modifiedTime":1781557646208,"lastModifiedBy":null,"exportSource":null}}
{"_id":"qqclosrwhT5MHUOz","name":"The Elephant-Eared Giant","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"2TWScGor6cjxO9GQ","name":"The Elephant-Eared Giant - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a huge Giant of herculean strength, I \nhave no natural predators on the island. I consider all creatures smaller than me to be weak, and I am not afraid that \nthey will harm me.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 155.","positive":"I am a huge Giant of herculean strength, I \nhave no natural predators on the island. I consider all creatures smaller than me to be weak, and I am not afraid that \nthey will harm me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}},{"_id":"3LjYFSCqfTH3Mcs1","name":"Gift - Elephant Ears","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>As a free action, the Giant can use \nits massive ears to create a gust of wind capable of hurling \na human thirty feet. The gust affects 2 targets and can be \navoided with a Defense Check. If someone is pushed back, \nroll 1 die: \n1-2: Loses an Equipment.\n3-4: Suffers 1 Wound.\n5-6: Ends up in impassable terrain, requiring a Check to \nget out. \n5A An Old Bride\nThe story that led us here...\nThe ship lands on a large island that is familiar to Sinbad. \nThe old sailor goes down with some of his crew to resupply, \nbut only one of his men returns. The survivor tells the Hunters that Sinbad once married the daughter of the island’s king, \nbut she died shortly after the wedding. According to local tradition, Sinbad was buried alive with his bride to be united \nwith her forever. The cunning traveler, however, managed to \nescape, and now that more than fifty years had passed, he believed that all had been forgotten by the new ruler. But to his \nastonishment, Sinbad and his people found themselves in the \npresence of a centenarian king who did not hesitate to return \npoor Sinbad to the tomb of his wife. \nPlace: A large pyramid-shaped tomb not far from the \ntown where the island’s ruler resides.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 155.","somaCost":0,"automaticSuccesses":0,"owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}},{"_id":"TrUXn7k3PotzI5hZ","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a huge Giant of herculean strength, I \nhave no natural predators on the island. I consider all creatures smaller than me to be weak, and I am not afraid that \nthey will harm me.\nGift - Elephant Ears: As a free action, the Giant can use \nits massive ears to create a gust of wind capable of hurling \na human thirty feet. The gust affects 2 targets and can be \navoided with a Defense Check. If someone is pushed back, \nroll 1 die: \n1-2: Loses an Equipment.\n3-4: Suffers 1 Wound.\n5-6: Ends up in impassable terrain, requiring a Check to \nget out. \n5A An Old Bride\nThe story that led us here...\nThe ship lands on a large island that is familiar to Sinbad. \nThe old sailor goes down with some of his crew to resupply, \nbut only one of his men returns. The survivor tells the Hunters that Sinbad once married the daughter of the island’s king, \nbut she died shortly after the wedding. According to local tradition, Sinbad was buried alive with his bride to be united \nwith her forever. The cunning traveler, however, managed to \nescape, and now that more than fifty years had passed, he believed that all had been forgotten by the new ruler. But to his \nastonishment, Sinbad and his people found themselves in the \npresence of a centenarian king who did not hesitate to return \npoor Sinbad to the tomb of his wife. \nPlace: A large pyramid-shaped tomb not far from the \ntown where the island’s ruler resides. \nInformation: The tomb is protected by a notorious order \nof Guardians who are said to devour intruders alive. \nChallenges: The tomb is patrolled by over a hundred \nGuardians. Entering it requires some sort of distraction. \nOn the east side of the tomb, there is a crack in the wall \nthrough which a person can safely pass. While waiting for \nit to be repaired, a team of six Guardians stands watch by \nthe wall. The king is the only one who insists on enforcing</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 155.","owner":"The Elephant-Eared Giant","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-elephant-eared-giant-155","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":155,"role":"Main NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a huge Giant of herculean strength, I \nhave no natural predators on the island. I consider all creatures smaller than me to be weak, and I am not afraid that \nthey will harm me.\nGift - Elephant Ears: As a free action, the Giant can use \nits massive ears to create a gust of wind capable of hurling \na human thirty feet. The gust affects 2 targets and can be \navoided with a Defense Check. If someone is pushed back, \nroll 1 die: \n1-2: Loses an Equipment.\n3-4: Suffers 1 Wound.\n5-6: Ends up in impassable terrain, requiring a Check to \nget out. \n5A An Old Bride\nThe story that led us here...\nThe ship lands on a large island that is familiar to Sinbad. \nThe old sailor goes down with some of his crew to resupply, \nbut only one of his men returns. The survivor tells the Hunters that Sinbad once married the daughter of the island’s king, \nbut she died shortly after the wedding. According to local tradition, Sinbad was buried alive with his bride to be united \nwith her forever. The cunning traveler, however, managed to \nescape, and now that more than fifty years had passed, he believed that all had been forgotten by the new ruler. But to his \nastonishment, Sinbad and his people found themselves in the \npresence of a centenarian king who did not hesitate to return \npoor Sinbad to the tomb of his wife. \nPlace: A large pyramid-shaped tomb not far from the \ntown where the island’s ruler resides. \nInformation: The tomb is protected by a notorious order \nof Guardians who are said to devour intruders alive. \nChallenges: The tomb is patrolled by over a hundred \nGuardians. Entering it requires some sort of distraction. \nOn the east side of the tomb, there is a crack in the wall \nthrough which a person can safely pass. While waiting for \nit to be repaired, a team of six Guardians stands watch by \nthe wall. The king is the only one who insists on enforcing</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rLrvmvHW6gjuzl3J","name":"5: Usko","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"RnjHeodlxGZkLmrP","name":"5: Usko - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"5: Usko","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a prospector and direct the \nwork of recovering metals from the big river \neast of Rovaniemi.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","positive":"I am a prospector and direct the \nwork of recovering metals from the big river \neast of Rovaniemi.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"5: Usko","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}},{"_id":"2DEMuAedX2Y5sKsD","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"5: Usko","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (2 \nWounds)\nDescriptor: I am a prospector and direct the \nwork of recovering metals from the big river \neast of Rovaniemi.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","owner":"5: Usko","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-5-usko-119","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":119,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (2 \nWounds)\nDescriptor: I am a prospector and direct the \nwork of recovering metals from the big river \neast of Rovaniemi.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rQHWHqCHebYyHVce","name":"Warden Casket","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"7xpGerZmaKbW8Sum","name":"Warden Casket - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Warden Casket","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a fierce Warden Casket, ready to bite any \nthief with my sharp teeth. I am very sensitive to bad smells, \nwhich makes me sneeze until I vomit my contents.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 207.","positive":"I am a fierce Warden Casket, ready to bite any \nthief with my sharp teeth. I am very sensitive to bad smells, \nwhich makes me sneeze until I vomit my contents.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Warden Casket","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}},{"_id":"t2KHpykujDVy7gLt","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Warden Casket","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a fierce Warden Casket, ready to bite any \nthief with my sharp teeth. I am very sensitive to bad smells, \nwhich makes me sneeze until I vomit my contents. \nInformation: Flora’s diary describes Gerda and Kay, two \ncriminals who proposed the Frozen Madness scam to Flora. Flora seems to have agreed mainly to take revenge on an \nold rival of hers, a witch named Lady Storm. The contact \nbetween Flora and the two criminals was facilitated by a \nwoman named Lene, who is identified in the diary as Ger -\nda’s mother. Flora reports that she is not too happy about \ninvolving so many innocent people in this plan, but the \nchance to teach the arrogant and haughty Lady Storm a \nlesson was too good to pass up. Flora does not trust Gerda \nand Kay, but she does not believe that the two criminals can \npose any real danger to her. \nStoreroom\nDescriptor: A small room filled with books, gardening \ntools, and strange vials.\nInformation: Hidden among the many stacked objects it \nis possible to find a Treasure of the Order. The Storyteller is \nfree to decide which one.\nThe Greenhouse\nDescriptor: A large greenhouse filled with vegetation. A \nthick mist of pollen chokes those who walk through the rows \nof plants and flowers with its smell. \nInformation: Flora has taken up residence in the Greenhouse, where she repeats the same tasks over and over \nagain. Without her careful oversight, many of the plants \nhave grown beyond control, and the ecosystem of the place \nhas become mixed with the witch’s out-of-control magic. \nMoving inside the Greenhouse activates the Threat - Magic \nGreenhouse. Flora is in the center of it and will not move \nunder any circumstances.\nThreat - Magic Greenhouse</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 207.","owner":"Warden Casket","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-warden-casket-207","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":207,"role":"Minor NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (3 Wounds)\nDescriptor: I am a fierce Warden Casket, ready to bite any \nthief with my sharp teeth. I am very sensitive to bad smells, \nwhich makes me sneeze until I vomit my contents. \nInformation: Flora’s diary describes Gerda and Kay, two \ncriminals who proposed the Frozen Madness scam to Flora. Flora seems to have agreed mainly to take revenge on an \nold rival of hers, a witch named Lady Storm. The contact \nbetween Flora and the two criminals was facilitated by a \nwoman named Lene, who is identified in the diary as Ger -\nda’s mother. Flora reports that she is not too happy about \ninvolving so many innocent people in this plan, but the \nchance to teach the arrogant and haughty Lady Storm a \nlesson was too good to pass up. Flora does not trust Gerda \nand Kay, but she does not believe that the two criminals can \npose any real danger to her. \nStoreroom\nDescriptor: A small room filled with books, gardening \ntools, and strange vials.\nInformation: Hidden among the many stacked objects it \nis possible to find a Treasure of the Order. The Storyteller is \nfree to decide which one.\nThe Greenhouse\nDescriptor: A large greenhouse filled with vegetation. A \nthick mist of pollen chokes those who walk through the rows \nof plants and flowers with its smell. \nInformation: Flora has taken up residence in the Greenhouse, where she repeats the same tasks over and over \nagain. Without her careful oversight, many of the plants \nhave grown beyond control, and the ecosystem of the place \nhas become mixed with the witch’s out-of-control magic. \nMoving inside the Greenhouse activates the Threat - Magic \nGreenhouse. Flora is in the center of it and will not move \nunder any circumstances.\nThreat - Magic Greenhouse</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645098,"modifiedTime":1781557645098,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rY1ZaY9BaOxbIabI","name":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"AyRru6l3n76ZAVfp","name":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>I am a skilled spy in the service of the Papacy \nand can assume different identities as needed. I do not like \ndirect action and prefer to support the Hunters from behind \nthe scenes.</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 59.","positive":"I am a skilled spy in the service of the Papacy \nand can assume different identities as needed. I do not like \ndirect action and prefer to support the Hunters from behind \nthe scenes.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638197,"modifiedTime":1781557638197,"lastModifiedBy":null,"exportSource":null}},{"_id":"0GokxLz03ibo7g43","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a skilled spy in the service of the Papacy \nand can assume different identities as needed. I do not like \ndirect action and prefer to support the Hunters from behind \nthe scenes.\nAgenda: Gather all possible information about secrets and \ncuriosities to report to the Order.\nGift - Thousand Faces: An Eye of Order can change \ntheir identity by disguising themselves to appear as an ordinary villager or play any other social role. While disguised \nor hidden, an Eye of Order increases their OL by 1 on all \nChecks made to detect them.</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 59.","owner":"The Eyes of the Order are men and women of faith who gather useful clues to ferret out hum","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638197,"modifiedTime":1781557638197,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-rome-city-of-the-order-the-eyes-of-the-order-are-men-and-women-of-faith-who-gather-useful-clues-to-ferret-out-hum-59","collection":"Lost Stories","adventureSlug":"rome-city-of-the-order","adventureTitle":"Rome, City of the Order","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":59,"role":"Minor NPC"}},"system":{"details":{"concept":"Rome, City of the Order","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a skilled spy in the service of the Papacy \nand can assume different identities as needed. I do not like \ndirect action and prefer to support the Hunters from behind \nthe scenes.\nAgenda: Gather all possible information about secrets and \ncuriosities to report to the Order.\nGift - Thousand Faces: An Eye of Order can change \ntheir identity by disguising themselves to appear as an ordinary villager or play any other social role. While disguised \nor hidden, an Eye of Order increases their OL by 1 on all \nChecks made to detect them.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Gather all possible information about secrets and \ncuriosities to report to the Order.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638197,"modifiedTime":1781557638197,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rhBwxK3e2jqlz12K","name":"Brigit the Cook","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"1Fvm19dAk6P7H781","name":"Brigit the Cook - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Brigit the Cook","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>I am a good cook, the best. I love my tavern \nand can’t stand any argument between my tables. \nThe Old Barracks\nDescriptor: A dirty old building where soldiers on leave \ncan sleep for free.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 141.","positive":"I am a good cook, the best. I love my tavern \nand can’t stand any argument between my tables. \nThe Old Barracks\nDescriptor: A dirty old building where soldiers on leave \ncan sleep for free.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Brigit the Cook","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641651,"modifiedTime":1781557641651,"lastModifiedBy":null,"exportSource":null}},{"_id":"fAkuoLbrxrmUjSJi","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Brigit the Cook","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a good cook, the best. I love my tavern \nand can’t stand any argument between my tables. \nThe Old Barracks\nDescriptor: A dirty old building where soldiers on leave \ncan sleep for free.\nInformation: Bastian sleeps in the Old Barracks, but \nhas never told anyone about it because it would damage \nthe image of wealth and prosperity he is trying to build \nin Alena’s eyes. Bastian has joined forces with four other \ndeserters who will help him in his plan to rob Villa Wagner. In the Barracks, many people know Bastian and will \ndescribe him as a blowhard, but too stupid to actually \namount to anything.\nIf Bastian is present: At night, Bastian sleeps in a secret room on the second floor of the building. If discovered, he will try to escape by throwing himself out the \nwindow to cause a Reset.\nAfter any Reset caused in this Place: Bastian will \nnot go back to sleep but will use Ulrich to send messages \nto his co-conspirators.\nBritta’s House\nDescriptor: A small abandoned house near the gra -\nveyard. In the garden, in the middle of a vegetable patch \nand near a well, there is an old hollow tree with no leaves.\nInformation: The Hollow Tree in the garden hides a \nburrow that leads to a series of Caves. Descending into \nthe Caves, Hunters can find Britta’s decapitated body. The \nwitch’s spirit is still bound to the body, but the only way to \ncommunicate with her is with a Gift that allows it. In the \nlittle house, Hunters can find Britta’s diary open on the \nkitchen table. In the diary, the witch describes in detail</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 141.","owner":"Brigit the Cook","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641651,"modifiedTime":1781557641651,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-brigit-the-cook-141","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":141,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a good cook, the best. I love my tavern \nand can’t stand any argument between my tables. \nThe Old Barracks\nDescriptor: A dirty old building where soldiers on leave \ncan sleep for free.\nInformation: Bastian sleeps in the Old Barracks, but \nhas never told anyone about it because it would damage \nthe image of wealth and prosperity he is trying to build \nin Alena’s eyes. Bastian has joined forces with four other \ndeserters who will help him in his plan to rob Villa Wagner. In the Barracks, many people know Bastian and will \ndescribe him as a blowhard, but too stupid to actually \namount to anything.\nIf Bastian is present: At night, Bastian sleeps in a secret room on the second floor of the building. If discovered, he will try to escape by throwing himself out the \nwindow to cause a Reset.\nAfter any Reset caused in this Place: Bastian will \nnot go back to sleep but will use Ulrich to send messages \nto his co-conspirators.\nBritta’s House\nDescriptor: A small abandoned house near the gra -\nveyard. In the garden, in the middle of a vegetable patch \nand near a well, there is an old hollow tree with no leaves.\nInformation: The Hollow Tree in the garden hides a \nburrow that leads to a series of Caves. Descending into \nthe Caves, Hunters can find Britta’s decapitated body. The \nwitch’s spirit is still bound to the body, but the only way to \ncommunicate with her is with a Gift that allows it. In the \nlittle house, Hunters can find Britta’s diary open on the \nkitchen table. In the diary, the witch describes in detail</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641651,"modifiedTime":1781557641651,"lastModifiedBy":null,"exportSource":null}}
{"_id":"rzds0J3XPXmv4O7p","name":"Alena Wagner","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"7P66f4uE6yLsxE1y","name":"Alena Wagner - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alena Wagner","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>I am the young scion of the Wagner family. I \nlove adventure and romance novels. I’m cultured and dream \nof becoming a teacher one day.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 139.","positive":"I am the young scion of the Wagner family. I \nlove adventure and romance novels. I’m cultured and dream \nof becoming a teacher one day.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Alena Wagner","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}},{"_id":"ABsEbcbhGesjWvV5","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Alena Wagner","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am the young scion of the Wagner family. I \nlove adventure and romance novels. I’m cultured and dream \nof becoming a teacher one day. \nAgenda: To have a good adventure like the ones I read \nabout in novels.\nWagner Treasury\nDescriptor: A small fortified tower connected to \nthe Villa by an underground tunnel. Aside from the \ntunnel, the only way to access the tower is to know \nthe combination of the large metal door that \nblocks the main entrance.\nInformation: The Treasury is permanently \nmanned by 4 Guards who change shifts every \neight hours.\nFirst, Second, and Third Reset: Bastian</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 139.","owner":"Alena Wagner","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-alena-wagner-139","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":139,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am the young scion of the Wagner family. I \nlove adventure and romance novels. I’m cultured and dream \nof becoming a teacher one day. \nAgenda: To have a good adventure like the ones I read \nabout in novels.\nWagner Treasury\nDescriptor: A small fortified tower connected to \nthe Villa by an underground tunnel. Aside from the \ntunnel, the only way to access the tower is to know \nthe combination of the large metal door that \nblocks the main entrance.\nInformation: The Treasury is permanently \nmanned by 4 Guards who change shifts every \neight hours.\nFirst, Second, and Third Reset: Bastian</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"To have a good adventure like the ones I read \nabout in novels.\nWagner Treasury\nDescriptor: A small fortified tower connected to \nthe Villa by an underground tunnel. Aside from the \ntunnel, the only way to access the tower is to know \nthe combination of the large metal door that \nblocks the main entrance.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641606,"modifiedTime":1781557641606,"lastModifiedBy":null,"exportSource":null}}
{"_id":"sA8gseJZkSxDxqyt","name":"Guinevere the Fugitive","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"E5yBVYtfOPOWab8u","name":"Guinevere the Fugitive - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am the queen of Camelot, and my good heart \nis matched only by my beauty.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 186.","positive":"I am the queen of Camelot, and my good heart \nis matched only by my beauty.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643894,"modifiedTime":1781557643894,"lastModifiedBy":null,"exportSource":null}},{"_id":"9CAc28i1UsQ2X151","name":"Gift - Virtue of Love","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Imbued with the power of the Virtue of Love, Guinevere cannot be killed: when she reaches \n0 Wounds, she will fall into a state of apparent death, waking up fully healed at the end of the Scene. Guinevere will \ngive the power of her Virtue to those who show a sincere \ninterest in stopping Arthur’s madness: when this happens, \nthe Virtue transforms into a heart-shaped pendant. While \nimbued with the power of Virtue, Guinevere cannot be deceived in any way and will see everything for what it really \nis, breaking all magic and deception.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 186.","somaCost":0,"automaticSuccesses":0,"owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643894,"modifiedTime":1781557643894,"lastModifiedBy":null,"exportSource":null}},{"_id":"tIprAGp7St9Y9o65","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (1 Wound)\nDescriptor: I am the queen of Camelot, and my good heart \nis matched only by my beauty.\nAgenda: To find a cure for the madness that has taken hold \nof my beloved Arthur. \nGift - Virtue of Love: Imbued with the power of the Virtue of Love, Guinevere cannot be killed: when she reaches \n0 Wounds, she will fall into a state of apparent death, waking up fully healed at the end of the Scene. Guinevere will \ngive the power of her Virtue to those who show a sincere \ninterest in stopping Arthur’s madness: when this happens, \nthe Virtue transforms into a heart-shaped pendant. While \nimbued with the power of Virtue, Guinevere cannot be deceived in any way and will see everything for what it really \nis, breaking all magic and deception.\nInformation: Guinevere poses as a common Villager, \nthough her noble features are hard to hide. Guinevere is \naware that Arthur has gone mad because he has lost his \nVirtues. Indeed, the woman is seeking help and will not \nhesitate to reveal herself to the Hunters if they prove trustworthy.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 186.","owner":"Guinevere the Fugitive","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643894,"modifiedTime":1781557643894,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-guinevere-the-fugitive-186","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":186,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (1 Wound)\nDescriptor: I am the queen of Camelot, and my good heart \nis matched only by my beauty.\nAgenda: To find a cure for the madness that has taken hold \nof my beloved Arthur. \nGift - Virtue of Love: Imbued with the power of the Virtue of Love, Guinevere cannot be killed: when she reaches \n0 Wounds, she will fall into a state of apparent death, waking up fully healed at the end of the Scene. Guinevere will \ngive the power of her Virtue to those who show a sincere \ninterest in stopping Arthur’s madness: when this happens, \nthe Virtue transforms into a heart-shaped pendant. While \nimbued with the power of Virtue, Guinevere cannot be deceived in any way and will see everything for what it really \nis, breaking all magic and deception.\nInformation: Guinevere poses as a common Villager, \nthough her noble features are hard to hide. Guinevere is \naware that Arthur has gone mad because he has lost his \nVirtues. Indeed, the woman is seeking help and will not \nhesitate to reveal herself to the Hunters if they prove trustworthy.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To find a cure for the madness that has taken hold \nof my beloved Arthur.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643894,"modifiedTime":1781557643894,"lastModifiedBy":null,"exportSource":null}}
{"_id":"sWEBU01G9L79djoa","name":"The Ice Heart","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"QsxbsHnSYUZaZr47","name":"The Ice Heart - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Ice Heart","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a fragment of pure power and live only \nto punish all humans guilty of hurting my Lady Storm. I am \nthe castle and within it, all is in my power. I have no human \nmalice and speak my mind without a filter.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 225.","positive":"I am a fragment of pure power and live only \nto punish all humans guilty of hurting my Lady Storm. I am \nthe castle and within it, all is in my power. I have no human \nmalice and speak my mind without a filter.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Ice Heart","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646239,"modifiedTime":1781557646239,"lastModifiedBy":null,"exportSource":null}},{"_id":"KDsMOW7cAiNhTGHs","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Ice Heart","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a fragment of pure power and live only \nto punish all humans guilty of hurting my Lady Storm. I am \nthe castle and within it, all is in my power. I have no human \nmalice and speak my mind without a filter. \nAgenda: Punish Gerda for what she did to Lady Storm / \nPunish humanity and freeze it in eternal ice. \nGift - I Am Winter: The Ice Heart is a manifestation of \npower and can manipulate anything within the castle. As \nan action, the Heart can inflict 1Wound from cold on any \nsubject in the castle without the ability to make a Defense \nCheck. The only safe place in the castle is the Library, where \nthe Heart’s power cannot reach because of the seal Gerda \ncreated. A sincere expression of love or friendship in the \npresence of the Ice Heart can immediately shatter and destroy it.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 225.","owner":"The Ice Heart","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646239,"modifiedTime":1781557646239,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-the-ice-heart-225","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":225,"role":"Main NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a fragment of pure power and live only \nto punish all humans guilty of hurting my Lady Storm. I am \nthe castle and within it, all is in my power. I have no human \nmalice and speak my mind without a filter. \nAgenda: Punish Gerda for what she did to Lady Storm / \nPunish humanity and freeze it in eternal ice. \nGift - I Am Winter: The Ice Heart is a manifestation of \npower and can manipulate anything within the castle. As \nan action, the Heart can inflict 1Wound from cold on any \nsubject in the castle without the ability to make a Defense \nCheck. The only safe place in the castle is the Library, where \nthe Heart’s power cannot reach because of the seal Gerda \ncreated. A sincere expression of love or friendship in the \npresence of the Ice Heart can immediately shatter and destroy it.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Punish Gerda for what she did to Lady Storm / \nPunish humanity and freeze it in eternal ice.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557646239,"modifiedTime":1781557646239,"lastModifiedBy":null,"exportSource":null}}
{"_id":"sox8SkLT6YEavjmR","name":"Aladdin the Mad Sultan","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"n9xDarZyyXcJ4c6O","name":"Aladdin the Mad Sultan - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am drunk with the power the lamp gives me \nand I demand that the whole world do as I command. I have \na background as a street thief and know all the tricks of the \ntrade.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","positive":"I am drunk with the power the lamp gives me \nand I demand that the whole world do as I command. I have \na background as a street thief and know all the tricks of the \ntrade.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}},{"_id":"JoETxcBKeeEhEaqy","name":"Gift - Wishing Lamp","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Whatever Aladdin wishes for will \nbe granted by the Djinn who lives in the lamp. As an action, \nAladdin can rub the lamp and ask for the following wishes:\n1. Eliminate: (as an action) The target is somehow \nknocked out and suffers all the remaining Wounds, or is \nteleported to a place where they cannot harm Aladdin. The \ntarget can make a Defense Check to avoid the effect of the \nwish, but will still take 1 Wound even if it succeeds.\n2. Create: (1 time per Scene) Aladdin creates up to 4 \nMonsters to do his bidding.\n3. Block: (as an action) Aladdin will remove the effect of \na spell or mind control from a subject. Alternatively, he can \nprevent the use of a Gift that he has already seen in action \nin the Scene.\nAladdin has already made some wishes to make himself \nmore powerful, so he can act up to 3 times in an Exchange \n(but not back-to-back).\nCity Guards</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","somaCost":0,"automaticSuccesses":0,"owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}},{"_id":"L4XRSVeqEWWOoBhL","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am drunk with the power the lamp gives me \nand I demand that the whole world do as I command. I have \na background as a street thief and know all the tricks of the \ntrade. \nAgenda: To find something to kill my terrible boredom.\nGift - Wishing Lamp: Whatever Aladdin wishes for will \nbe granted by the Djinn who lives in the lamp. As an action, \nAladdin can rub the lamp and ask for the following wishes:\n1. Eliminate: (as an action) The target is somehow \nknocked out and suffers all the remaining Wounds, or is \nteleported to a place where they cannot harm Aladdin. The \ntarget can make a Defense Check to avoid the effect of the \nwish, but will still take 1 Wound even if it succeeds.\n2. Create: (1 time per Scene) Aladdin creates up to 4 \nMonsters to do his bidding.\n3. Block: (as an action) Aladdin will remove the effect of \na spell or mind control from a subject. Alternatively, he can \nprevent the use of a Gift that he has already seen in action \nin the Scene.\nAladdin has already made some wishes to make himself \nmore powerful, so he can act up to 3 times in an Exchange \n(but not back-to-back).\nCity Guards</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","owner":"Aladdin the Mad Sultan","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-aladdin-the-mad-sultan-160","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":160,"role":"Main NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am drunk with the power the lamp gives me \nand I demand that the whole world do as I command. I have \na background as a street thief and know all the tricks of the \ntrade. \nAgenda: To find something to kill my terrible boredom.\nGift - Wishing Lamp: Whatever Aladdin wishes for will \nbe granted by the Djinn who lives in the lamp. As an action, \nAladdin can rub the lamp and ask for the following wishes:\n1. Eliminate: (as an action) The target is somehow \nknocked out and suffers all the remaining Wounds, or is \nteleported to a place where they cannot harm Aladdin. The \ntarget can make a Defense Check to avoid the effect of the \nwish, but will still take 1 Wound even if it succeeds.\n2. Create: (1 time per Scene) Aladdin creates up to 4 \nMonsters to do his bidding.\n3. Block: (as an action) Aladdin will remove the effect of \na spell or mind control from a subject. Alternatively, he can \nprevent the use of a Gift that he has already seen in action \nin the Scene.\nAladdin has already made some wishes to make himself \nmore powerful, so he can act up to 3 times in an Exchange \n(but not back-to-back).\nCity Guards</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To find something to kill my terrible boredom.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}
{"_id":"tNqHtihrJCAJp5xF","name":"Aleksander Okland","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"abbDQ7s4Q9Uxs0Pp","name":"Aleksander Okland - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Aleksander Okland","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>I am a rich and powerful nobleman, and I use my position to help \nall unfortunate people. I can’t stand the bullying of the weak by the powerful, \nand I strive to change society so that everything is more equal.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 205.","positive":"I am a rich and powerful nobleman, and I use my position to help \nall unfortunate people. I can’t stand the bullying of the weak by the powerful, \nand I strive to change society so that everything is more equal.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Aleksander Okland","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645007,"modifiedTime":1781557645007,"lastModifiedBy":null,"exportSource":null}},{"_id":"QdncmmGzx7SAtgsK","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Aleksander Okland","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a rich and powerful nobleman, and I use my position to help \nall unfortunate people. I can’t stand the bullying of the weak by the powerful, \nand I strive to change society so that everything is more equal. \nAgenda: Helping others find their way and realize their plans. \nShard Descriptor: I am a rich and powerful nobleman, and I use my \nposition to bend everyone to my command. I can’t stand to be told no, and I \nabuse all the people I consider inferior.\nShard Agenda: Satisfying my thirst for power by crushing those who are \nweaker. \nGift - Power of the Shard: The Shard of the Mirror of the Other Self reverses the Descriptor and Agenda of the person it injured. The holder increases their OL by 1 if they act in accordance with the altered part of their Descriptor or Agenda. \nEnd of Scene: The Hunters must decide whether to contact Flora or the \nBlack Feathers through Lene. Go to SECOND SCENE OPTION A - Flora’s \nGreenhouse or SECOND SCENE OPTION B - Lene’s House.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 205.","owner":"Aleksander Okland","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645007,"modifiedTime":1781557645007,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-aleksander-okland-205","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":205,"role":"Minor NPC"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am a rich and powerful nobleman, and I use my position to help \nall unfortunate people. I can’t stand the bullying of the weak by the powerful, \nand I strive to change society so that everything is more equal. \nAgenda: Helping others find their way and realize their plans. \nShard Descriptor: I am a rich and powerful nobleman, and I use my \nposition to bend everyone to my command. I can’t stand to be told no, and I \nabuse all the people I consider inferior.\nShard Agenda: Satisfying my thirst for power by crushing those who are \nweaker. \nGift - Power of the Shard: The Shard of the Mirror of the Other Self reverses the Descriptor and Agenda of the person it injured. The holder increases their OL by 1 if they act in accordance with the altered part of their Descriptor or Agenda. \nEnd of Scene: The Hunters must decide whether to contact Flora or the \nBlack Feathers through Lene. Go to SECOND SCENE OPTION A - Flora’s \nGreenhouse or SECOND SCENE OPTION B - Lene’s House.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"Helping others find their way and realize their plans. \nShard Descriptor: I am a rich and powerful nobleman, and I use my \nposition to bend everyone to my command. I can’t stand to be told no, and I \nabuse all the people I consider inferior.\nShard Agenda: Satisfying my thirst for power by crushing those who are \nweaker.","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645007,"modifiedTime":1781557645007,"lastModifiedBy":null,"exportSource":null}}
{"_id":"tdLgvr1dRa7rO0Nz","name":"The Furious Djinn","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"q3ayrswfjUh1cCny","name":"The Furious Djinn - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a powerful Djinn, skilled with a scimitar. \nI hate lies and those who break agreements.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 153.","positive":"I am a powerful Djinn, skilled with a scimitar. \nI hate lies and those who break agreements.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}},{"_id":"v6Zp5EnJIFw2dbKr","name":"Gift - Frenzied","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>When the Djinn suffers 1 Wound, it can \nimmediately attack with its giant scimitar to strike the one \nwho did the damage. \n2A The Island Fish\nThe story that led us here...\nSinbad’s ship has docked at a large island dense with plants \nthat bear delicious fruits. The entire crew has gone ashore to \nresupply, but what no one can imagine is that this lush land is \nactually resting on the back of a giant, sleeping fish. While the \nsailors are busy harvesting fruit, the island begins to tremble \nand the land cracks. Sinbad begs the Hunters to save his men, \nor no one will be able to sail the ship to continue the journey. \n \nPlace: A large natural island filled with plants and fruits.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 153.","somaCost":0,"automaticSuccesses":0,"owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}},{"_id":"2NZpvgrfy4ZCdDOs","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Main NPC (4 Wounds)\nDescriptor: I am a powerful Djinn, skilled with a scimitar. \nI hate lies and those who break agreements.\nAgenda: To avenge my son’s death by punishing the Mer -\nchant who caused it. \nGift - Frenzied: When the Djinn suffers 1 Wound, it can \nimmediately attack with its giant scimitar to strike the one \nwho did the damage. \n2A The Island Fish\nThe story that led us here...\nSinbad’s ship has docked at a large island dense with plants \nthat bear delicious fruits. The entire crew has gone ashore to \nresupply, but what no one can imagine is that this lush land is \nactually resting on the back of a giant, sleeping fish. While the \nsailors are busy harvesting fruit, the island begins to tremble \nand the land cracks. Sinbad begs the Hunters to save his men, \nor no one will be able to sail the ship to continue the journey. \n \nPlace: A large natural island filled with plants and fruits. \nInformation: Sailors are divided into six groups, each in a \ndifferent part of the island. \nChallenges: Traveling by land is very dangerous due to the \nconstant movements of the Island Fish. When a group of \nsailors is rescued, roll 1 die: if you roll a 6, the sailors are \ncarrying a strange barrel found in the vegetation. If a 6 is \nnever rolled, the barrel is automatically in the hands of the \nsixth party.\nHow to get the Tarì: Found inside the barrel.\nThreat – The Island Fish</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 153.","owner":"The Furious Djinn","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-furious-djinn-153","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":153,"role":"Main NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (4 Wounds)\nDescriptor: I am a powerful Djinn, skilled with a scimitar. \nI hate lies and those who break agreements.\nAgenda: To avenge my son’s death by punishing the Mer -\nchant who caused it. \nGift - Frenzied: When the Djinn suffers 1 Wound, it can \nimmediately attack with its giant scimitar to strike the one \nwho did the damage. \n2A The Island Fish\nThe story that led us here...\nSinbad’s ship has docked at a large island dense with plants \nthat bear delicious fruits. The entire crew has gone ashore to \nresupply, but what no one can imagine is that this lush land is \nactually resting on the back of a giant, sleeping fish. While the \nsailors are busy harvesting fruit, the island begins to tremble \nand the land cracks. Sinbad begs the Hunters to save his men, \nor no one will be able to sail the ship to continue the journey. \n \nPlace: A large natural island filled with plants and fruits. \nInformation: Sailors are divided into six groups, each in a \ndifferent part of the island. \nChallenges: Traveling by land is very dangerous due to the \nconstant movements of the Island Fish. When a group of \nsailors is rescued, roll 1 die: if you roll a 6, the sailors are \ncarrying a strange barrel found in the vegetation. If a 6 is \nnever rolled, the barrel is automatically in the hands of the \nsixth party.\nHow to get the Tarì: Found inside the barrel.\nThreat – The Island Fish</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":4},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"To avenge my son’s death by punishing the Mer -\nchant who caused it.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}}
{"_id":"twWKKGCHHiBdBoMn","name":"Head in the Clouds","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"i5peEw3n7cnaKMGv","name":"Head in the Clouds - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Head in the Clouds","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>A dreamy spirit who cannot keep his attention on the living for more than a few seconds.\nIf the Hunters can get the spirit’s attention, he will tell them \nabout the strange, inky-handed figure who bought his \nmansion for far more than it was worth. After his death \n(which occurred when he fell out of the tree where he had \nmoved to live), the Baron wandered around the mansion \nand learned part of the magic formula to open the door. He \nwill also know the name of the alchemist who worked on \nthe door and who should know the rest of the formula. To \nget these two pieces of information, the Baron will ask the \nHunters to perform two missions for him.\nTo reveal the part of the formula he knows: He will \nask the Hunters to make sure one of his descendants is okay. \nThe Storyteller will describe a Minor NPC from a Scenario \nyet to be played, and create a problem about them that is \nrelated to the Hunters’ main antagonist in that context. If \nthe Hunters return the Baron’s relative safely to Rome, the \nspirit will reveal the first part of the formula: A Fairytale. \nTo know the identity of the creator of the door: The \nBaron will only make this request after the Hunters have \ncompleted the first task. The spirit will describe a Main \nNPC of a yet-to-be-played Scenario as the one who created the door. The Storyteller must edit the NPC’s profile to \ngive him a Descriptor or Gift that makes them a de facto \nalchemist capable of creating the door. The NPC in question, if convinced, will reveal the second part of the formula: Turned Upside Down.\nA note on the Baron’s spirit: Discovering the formula \nto open the Alchemical Door opens a direct route for the \nHunters to track down the One Who Plots in the Shadows. \nFor this reason, obtaining the two parts of the formula is \nvery important and has been tied to two playable Scenarios \nthat the Storyteller may propose as they see fit during the \ncourse of the Campaign, thus affecting the duration of the \nCampaign itself. \nIf Silvan is present: If the guide has already been to the \nAlchemical Door with the Hunters, he will recognize the \nspirit of the Baron and allow you to meet and talk to him \nwithout any Checks.</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 68.","positive":"A dreamy spirit who cannot keep his attention on the living for more than a few seconds.\nIf the Hunters can get the spirit’s attention, he will tell them \nabout the strange, inky-handed figure who bought his \nmansion for far more than it was worth. After his death \n(which occurred when he fell out of the tree where he had \nmoved to live), the Baron wandered around the mansion \nand learned part of the magic formula to open the door. He \nwill also know the name of the alchemist who worked on \nthe door and who should know the rest of the formula. To \nget these two pieces of information, the Baron will ask the \nHunters to perform two missions for him.\nTo reveal the part of the formula he knows: He will \nask the Hunters to make sure one of his descendants is okay. \nThe Storyteller will describe a Minor NPC from a Scenario \nyet to be played, and create a problem about them that is \nrelated to the Hunters’ main antagonist in that context. If \nthe Hunters return the Baron’s relative safely to Rome, the \nspirit will reveal the first part of the formula: A Fairytale. \nTo know the identity of the creator of the door: The \nBaron will only make this request after the Hunters have \ncompleted the first task. The spirit will describe a Main \nNPC of a yet-to-be-played Scenario as the one who created the door. The Storyteller must edit the NPC’s profile to \ngive him a Descriptor or Gift that makes them a de facto \nalchemist capable of creating the door. The NPC in question, if convinced, will reveal the second part of the formula: Turned Upside Down.\nA note on the Baron’s spirit: Discovering the formula \nto open the Alchemical Door opens a direct route for the \nHunters to track down the One Who Plots in the Shadows. \nFor this reason, obtaining the two parts of the formula is \nvery important and has been tied to two playable Scenarios \nthat the Storyteller may propose as they see fit during the \ncourse of the Campaign, thus affecting the duration of the \nCampaign itself. \nIf Silvan is present: If the guide has already been to the \nAlchemical Door with the Hunters, he will recognize the \nspirit of the Baron and allow you to meet and talk to him \nwithout any Checks.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Head in the Clouds","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}},{"_id":"tkMgIalIPHqdlYqZ","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Head in the Clouds","source":"Rome, City of the Order","category":"threat"}},"system":{"description":"<p>Descriptor: A dreamy spirit who cannot keep his attention on the living for more than a few seconds.\nIf the Hunters can get the spirit’s attention, he will tell them \nabout the strange, inky-handed figure who bought his \nmansion for far more than it was worth. After his death \n(which occurred when he fell out of the tree where he had \nmoved to live), the Baron wandered around the mansion \nand learned part of the magic formula to open the door. He \nwill also know the name of the alchemist who worked on \nthe door and who should know the rest of the formula. To \nget these two pieces of information, the Baron will ask the \nHunters to perform two missions for him.\nTo reveal the part of the formula he knows: He will \nask the Hunters to make sure one of his descendants is okay. \nThe Storyteller will describe a Minor NPC from a Scenario \nyet to be played, and create a problem about them that is \nrelated to the Hunters’ main antagonist in that context. If \nthe Hunters return the Baron’s relative safely to Rome, the \nspirit will reveal the first part of the formula: A Fairytale. \nTo know the identity of the creator of the door: The \nBaron will only make this request after the Hunters have \ncompleted the first task. The spirit will describe a Main \nNPC of a yet-to-be-played Scenario as the one who created the door. The Storyteller must edit the NPC’s profile to \ngive him a Descriptor or Gift that makes them a de facto \nalchemist capable of creating the door. The NPC in question, if convinced, will reveal the second part of the formula: Turned Upside Down.\nA note on the Baron’s spirit: Discovering the formula \nto open the Alchemical Door opens a direct route for the \nHunters to track down the One Who Plots in the Shadows. \nFor this reason, obtaining the two parts of the formula is \nvery important and has been tied to two playable Scenarios \nthat the Storyteller may propose as they see fit during the \ncourse of the Campaign, thus affecting the duration of the \nCampaign itself. \nIf Silvan is present: If the guide has already been to the \nAlchemical Door with the Hunters, he will recognize the \nspirit of the Baron and allow you to meet and talk to him \nwithout any Checks.</p>","notes":"Rome, City of the Order - bt-ls-book-1-ENG-SCREEN.pdf, page 68.","owner":"Head in the Clouds","source":"Rome, City of the Order","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-rome-city-of-the-order-head-in-the-clouds-68","collection":"Lost Stories","adventureSlug":"rome-city-of-the-order","adventureTitle":"Rome, City of the Order","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":68,"role":"Threat"}},"system":{"details":{"concept":"Rome, City of the Order","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A dreamy spirit who cannot keep his attention on the living for more than a few seconds.\nIf the Hunters can get the spirit’s attention, he will tell them \nabout the strange, inky-handed figure who bought his \nmansion for far more than it was worth. After his death \n(which occurred when he fell out of the tree where he had \nmoved to live), the Baron wandered around the mansion \nand learned part of the magic formula to open the door. He \nwill also know the name of the alchemist who worked on \nthe door and who should know the rest of the formula. To \nget these two pieces of information, the Baron will ask the \nHunters to perform two missions for him.\nTo reveal the part of the formula he knows: He will \nask the Hunters to make sure one of his descendants is okay. \nThe Storyteller will describe a Minor NPC from a Scenario \nyet to be played, and create a problem about them that is \nrelated to the Hunters’ main antagonist in that context. If \nthe Hunters return the Baron’s relative safely to Rome, the \nspirit will reveal the first part of the formula: A Fairytale. \nTo know the identity of the creator of the door: The \nBaron will only make this request after the Hunters have \ncompleted the first task. The spirit will describe a Main \nNPC of a yet-to-be-played Scenario as the one who created the door. The Storyteller must edit the NPC’s profile to \ngive him a Descriptor or Gift that makes them a de facto \nalchemist capable of creating the door. The NPC in question, if convinced, will reveal the second part of the formula: Turned Upside Down.\nA note on the Baron’s spirit: Discovering the formula \nto open the Alchemical Door opens a direct route for the \nHunters to track down the One Who Plots in the Shadows. \nFor this reason, obtaining the two parts of the formula is \nvery important and has been tied to two playable Scenarios \nthat the Storyteller may propose as they see fit during the \ncourse of the Campaign, thus affecting the duration of the \nCampaign itself. \nIf Silvan is present: If the guide has already been to the \nAlchemical Door with the Hunters, he will recognize the \nspirit of the Baron and allow you to meet and talk to him \nwithout any Checks.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557638487,"modifiedTime":1781557638487,"lastModifiedBy":null,"exportSource":null}}
{"_id":"tyxiOi2mO1T1X5aY","name":"Dirana the Faithful Slave","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"9dTqBdlB0SZjMRcD","name":"Dirana the Faithful Slave - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a fighting slave and fear nothing and no \none. My kicks can even cut through metal as if it were plain \npaper.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","positive":"I am a fighting slave and fear nothing and no \none. My kicks can even cut through metal as if it were plain \npaper.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}},{"_id":"stnUxJ7aVLvDsLYy","name":"Gift - Death Machine","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>As deadly as she is agile, Dirana \ncan act 2 times during an Exchange. \nThe Thieves</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","somaCost":0,"automaticSuccesses":0,"owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}},{"_id":"ImG5I9ZSVxOSH5OQ","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Main NPC (2 Wounds)\nDescriptor: I am a fighting slave and fear nothing and no \none. My kicks can even cut through metal as if it were plain \npaper.\nAgenda: Baba saved my life and now I will do the same to \nrepay him. \nGift - Death Machine: As deadly as she is agile, Dirana \ncan act 2 times during an Exchange. \nThe Thieves</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 162.","owner":"Dirana the Faithful Slave","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-dirana-the-faithful-slave-162","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":162,"role":"Main NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (2 Wounds)\nDescriptor: I am a fighting slave and fear nothing and no \none. My kicks can even cut through metal as if it were plain \npaper.\nAgenda: Baba saved my life and now I will do the same to \nrepay him. \nGift - Death Machine: As deadly as she is agile, Dirana \ncan act 2 times during an Exchange. \nThe Thieves</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"Baba saved my life and now I will do the same to \nrepay him.","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642567,"modifiedTime":1781557642567,"lastModifiedBy":null,"exportSource":null}}
{"_id":"uVrZcTV7fbEvnMXB","name":"Shadows of Sherazade (Dark Presence Opponent)","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"7R4EBkn3kkjVCW2T","name":"Shadows of Sherazade (Dark Presence Opponent) - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>We disguise ourselves as helpless citizens, but \nin reality, we are ready to strike with our shadow sabers.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 166.","positive":"We disguise ourselves as helpless citizens, but \nin reality, we are ready to strike with our shadow sabers.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}},{"_id":"4IfIxHVXgC6YaHIv","name":"Gift - Shadow Body","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>A Shadow is a darker, sadder ver -\nsion of the original. They can speak and behave like the \ncharacter they are modelled after, but on a careful inspection they will appear cold and mechanical. Once per Scene, \na Shadow can appear or disappear from the darkness by \nmoving through walls and other solid obstacles. When it \nspawns, it increases its OL by 1 because of the element of \nsurprise. When it suffers the Wound that would kill it, the \nShadow dissipates until its turn in the Exchange. At that \npoint, it will emerge from the darkness as if nothing had \nhappened. The Shadow will not reappear if the area the \nHunters are in is fully illuminated with light sources or \nmagic. The only way to truly destroy the Shadow is to expose it to sunlight.\nSultan’s Guards</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 166.","somaCost":0,"automaticSuccesses":0,"owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}},{"_id":"Fap0HWVGlVUll8oX","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- (1 Wound)\nDescriptor: We disguise ourselves as helpless citizens, but \nin reality, we are ready to strike with our shadow sabers. \nAgenda: Interfere with and complicate the lives of the Or -\nder’s Hunters, preventing them from fulfilling their mission.\nGift - Shadow Body: A Shadow is a darker, sadder ver -\nsion of the original. They can speak and behave like the \ncharacter they are modelled after, but on a careful inspection they will appear cold and mechanical. Once per Scene, \na Shadow can appear or disappear from the darkness by \nmoving through walls and other solid obstacles. When it \nspawns, it increases its OL by 1 because of the element of \nsurprise. When it suffers the Wound that would kill it, the \nShadow dissipates until its turn in the Exchange. At that \npoint, it will emerge from the darkness as if nothing had \nhappened. The Shadow will not reappear if the area the \nHunters are in is fully illuminated with light sources or \nmagic. The only way to truly destroy the Shadow is to expose it to sunlight.\nSultan’s Guards</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 166.","owner":"Shadows of Sherazade (Dark Presence Opponent)","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-shadows-of-sherazade-dark-presence-opponent-166","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":166,"role":"Scenario Actor"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Scenario Actor","notes":"<p>- (1 Wound)\nDescriptor: We disguise ourselves as helpless citizens, but \nin reality, we are ready to strike with our shadow sabers. \nAgenda: Interfere with and complicate the lives of the Or -\nder’s Hunters, preventing them from fulfilling their mission.\nGift - Shadow Body: A Shadow is a darker, sadder ver -\nsion of the original. They can speak and behave like the \ncharacter they are modelled after, but on a careful inspection they will appear cold and mechanical. Once per Scene, \na Shadow can appear or disappear from the darkness by \nmoving through walls and other solid obstacles. When it \nspawns, it increases its OL by 1 because of the element of \nsurprise. When it suffers the Wound that would kill it, the \nShadow dissipates until its turn in the Exchange. At that \npoint, it will emerge from the darkness as if nothing had \nhappened. The Shadow will not reappear if the area the \nHunters are in is fully illuminated with light sources or \nmagic. The only way to truly destroy the Shadow is to expose it to sunlight.\nSultan’s Guards</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Interfere with and complicate the lives of the Or -\nder’s Hunters, preventing them from fulfilling their mission.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642795,"modifiedTime":1781557642795,"lastModifiedBy":null,"exportSource":null}}
{"_id":"vEvyW2Sp40nYEwbT","name":"Cutthroat","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"A2uouUsfRDP780ZT","name":"Cutthroat - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Cutthroat","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>We are ruthless killers who will do anything to \nmake a profit. We eliminate the target with chilling efficiency.</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","positive":"We are ruthless killers who will do anything to \nmake a profit. We eliminate the target with chilling efficiency.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Cutthroat","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}},{"_id":"D5hX5rk3z8Vl3hnk","name":"Gift - Assassin","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Cutthroat","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>If they act to kill, they are considered to</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","somaCost":0,"automaticSuccesses":0,"owner":"Cutthroat","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}},{"_id":"9Ov5zWRhBUWahG6q","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Cutthroat","source":"The Last Wish","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are ruthless killers who will do anything to \nmake a profit. We eliminate the target with chilling efficiency. \nGift - Assassin: If they act to kill, they are considered to</p>","notes":"The Last Wish - bt-ls-book-1-ENG-SCREEN.pdf, page 136.","owner":"Cutthroat","source":"The Last Wish","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-last-wish-cutthroat-136","collection":"Lost Stories","adventureSlug":"the-last-wish","adventureTitle":"The Last Wish","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":136,"role":"Minor NPC"}},"system":{"details":{"concept":"The Last Wish","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: We are ruthless killers who will do anything to \nmake a profit. We eliminate the target with chilling efficiency. \nGift - Assassin: If they act to kill, they are considered to</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":3,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Easy 3","impulse":"","oppositionLevel":3}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557641427,"modifiedTime":1781557641427,"lastModifiedBy":null,"exportSource":null}}
{"_id":"vfzGiuaPLCPBMaGd","name":"Glatisant","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"YxG9t8M7gQP3HIls","name":"Glatisant - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Glatisant","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am a giant snake-headed monster with a deformed body, the result of the union of more than ten different \nanimals. I have an insatiable appetite for flesh.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 190.","positive":"I am a giant snake-headed monster with a deformed body, the result of the union of more than ten different \nanimals. I have an insatiable appetite for flesh.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Glatisant","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644083,"modifiedTime":1781557644083,"lastModifiedBy":null,"exportSource":null}},{"_id":"wqvFsjuA0SDqn9yn","name":"Gift - Monstrous Abomination","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Glatisant","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Glatisant can act 2 \ntimes during an Exchange, but not back to back. Its long \nneck allows it to snatch prey up to thirty feet away, and \nwhen it moves, it can make great leaps, ignoring enemies \nand terrain in its path. Glatisant is obsessed with the flesh of \nthe Twrch Trwyth and, if given the opportunity, will spend \nthe entire Exchange devouring it, ignoring even potential \nenemies.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 190.","somaCost":0,"automaticSuccesses":0,"owner":"Glatisant","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644083,"modifiedTime":1781557644083,"lastModifiedBy":null,"exportSource":null}},{"_id":"ZxAijHHJRlp1xfQ7","name":"Gift - Virtue of Courage","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Glatisant","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Glatisant unknowingly carries \nthe Virtue of Courage, encased in a sword embedded in his \nright side. Defeating the beast will allow the Hunters to recover the power of Courage. \nZone 4 – Village of \nCorrinton \nDescription: A fishing village buzzing with activity. The \npeople are friendly and hospitable, though it is clear from \ntheir faces that something is troubling the community.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 190.","somaCost":0,"automaticSuccesses":0,"owner":"Glatisant","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644083,"modifiedTime":1781557644083,"lastModifiedBy":null,"exportSource":null}},{"_id":"sMvqAHweLaMHeccX","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Glatisant","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a giant snake-headed monster with a deformed body, the result of the union of more than ten different \nanimals. I have an insatiable appetite for flesh.\nAgenda: I devour every delicious human I meet, though my \nfavorite prey is the tasty Twrch Trwyth.\nGift - Monstrous Abomination: Glatisant can act 2 \ntimes during an Exchange, but not back to back. Its long \nneck allows it to snatch prey up to thirty feet away, and \nwhen it moves, it can make great leaps, ignoring enemies \nand terrain in its path. Glatisant is obsessed with the flesh of \nthe Twrch Trwyth and, if given the opportunity, will spend \nthe entire Exchange devouring it, ignoring even potential \nenemies.\nGift - Virtue of Courage: Glatisant unknowingly carries \nthe Virtue of Courage, encased in a sword embedded in his \nright side. Defeating the beast will allow the Hunters to recover the power of Courage. \nZone 4 – Village of \nCorrinton \nDescription: A fishing village buzzing with activity. The \npeople are friendly and hospitable, though it is clear from \ntheir faces that something is troubling the community. \nInformation: Chatting with the locals is another way to \nget the information revealed in the Encounter with the Villagers (page 181). At the explicit request of the Hunters, \nsome fishermen will take them by boat along the coast but \nwill ask for payment. This arrangement allows the Hunters \nto choose any coastal Zone as their destination (i.e., all except 7, 8, and 9). Unless special arrangements are made, the \nfishermen are in a hurry to return to their activities, and \nonce they have unloaded the Hunters, they will not wait for \nthem to return.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 190.","owner":"Glatisant","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644083,"modifiedTime":1781557644083,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-glatisant-190","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":190,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (6 Wounds)\nDescriptor: I am a giant snake-headed monster with a deformed body, the result of the union of more than ten different \nanimals. I have an insatiable appetite for flesh.\nAgenda: I devour every delicious human I meet, though my \nfavorite prey is the tasty Twrch Trwyth.\nGift - Monstrous Abomination: Glatisant can act 2 \ntimes during an Exchange, but not back to back. Its long \nneck allows it to snatch prey up to thirty feet away, and \nwhen it moves, it can make great leaps, ignoring enemies \nand terrain in its path. Glatisant is obsessed with the flesh of \nthe Twrch Trwyth and, if given the opportunity, will spend \nthe entire Exchange devouring it, ignoring even potential \nenemies.\nGift - Virtue of Courage: Glatisant unknowingly carries \nthe Virtue of Courage, encased in a sword embedded in his \nright side. Defeating the beast will allow the Hunters to recover the power of Courage. \nZone 4 – Village of \nCorrinton \nDescription: A fishing village buzzing with activity. The \npeople are friendly and hospitable, though it is clear from \ntheir faces that something is troubling the community. \nInformation: Chatting with the locals is another way to \nget the information revealed in the Encounter with the Villagers (page 181). At the explicit request of the Hunters, \nsome fishermen will take them by boat along the coast but \nwill ask for payment. This arrangement allows the Hunters \nto choose any coastal Zone as their destination (i.e., all except 7, 8, and 9). Unless special arrangements are made, the \nfishermen are in a hurry to return to their activities, and \nonce they have unloaded the Hunters, they will not wait for \nthem to return.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":6},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"I devour every delicious human I meet, though my \nfavorite prey is the tasty Twrch Trwyth.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644083,"modifiedTime":1781557644083,"lastModifiedBy":null,"exportSource":null}}
{"_id":"vprTm5CXkSSA4aHd","name":"The Island Fish","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"zRF6qLuO5OTjpQPQ","name":"The Island Fish - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Island Fish","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>The earth cracks and trees fall on those unlucky \nenough to be nearby. Seawater slowly submerges everything.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 153.","positive":"The earth cracks and trees fall on those unlucky \nenough to be nearby. Seawater slowly submerges everything.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Island Fish","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}},{"_id":"7OhyFgpQaz4AUM5R","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Island Fish","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Descriptor: The earth cracks and trees fall on those unlucky \nenough to be nearby. Seawater slowly submerges everything. \nGift - The Island Moves!: Moving around the island is \nvery dangerous, rescuing a group of sailors requires at least \n2 Checks against this Threat, one to get to the group and one \nto return to the ship. The Check can only be made by the \nHunter leading the search party. For each failed Check, roll \n1 die and apply the result to one of the Hunters.\n1: Suffers 1 Wound caused by falling trees and rocks.\n2: Receives 1 Penalty at the next Check due to mud. \n3: Loses 1 Soma due to fatigue. \n4: Loses 1 Equipment in the waves of the sea.\n5: Loses more time than expected. Increase the OL of this \nThreat by 1 for those performing the next Check.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 153.","owner":"The Island Fish","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-island-fish-153","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":153,"role":"Threat"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: The earth cracks and trees fall on those unlucky \nenough to be nearby. Seawater slowly submerges everything. \nGift - The Island Moves!: Moving around the island is \nvery dangerous, rescuing a group of sailors requires at least \n2 Checks against this Threat, one to get to the group and one \nto return to the ship. The Check can only be made by the \nHunter leading the search party. For each failed Check, roll \n1 die and apply the result to one of the Hunters.\n1: Suffers 1 Wound caused by falling trees and rocks.\n2: Receives 1 Penalty at the next Check due to mud. \n3: Loses 1 Soma due to fatigue. \n4: Loses 1 Equipment in the waves of the sea.\n5: Loses more time than expected. Increase the OL of this \nThreat by 1 for those performing the next Check.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642170,"modifiedTime":1781557642170,"lastModifiedBy":null,"exportSource":null}}
{"_id":"wsPcP3W2amjkzEoX","name":"4: Katri","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"EGgeryLfGojF6vpC","name":"4: Katri - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"4: Katri","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>I am a good hunter, but now my venerable age \nkeeps me from hunting. I know the area around Rovaniemi \nvery well.</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","positive":"I am a good hunter, but now my venerable age \nkeeps me from hunting. I know the area around Rovaniemi \nvery well.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"4: Katri","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}},{"_id":"9LyZvv4p3M22N6aW","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"4: Katri","source":"Nikola's Pledge","category":"threat"}},"system":{"description":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a good hunter, but now my venerable age \nkeeps me from hunting. I know the area around Rovaniemi \nvery well.\nAgenda: Defend the village of Rovaniemi from any possible \nthreat from the wilderness. \nInformation: Katri leads the hunters in the Village, and \nlately she has been told that the presence of animals has \ndecreased dramatically. There are several hunting lodges \nin the forest around the Village, where one \ncan find shelter. The area where Nikola Lupei’s mansion was built is full of ravines and \nnatural caves. \n5: Usko</p>","notes":"Nikola's Pledge - bt-ls-book-1-ENG-SCREEN.pdf, page 119.","owner":"4: Katri","source":"Nikola's Pledge","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-nikolas-pledge-4-katri-119","collection":"Lost Stories","adventureSlug":"nikolas-pledge","adventureTitle":"Nikola's Pledge","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":119,"role":"Minor NPC"}},"system":{"details":{"concept":"Nikola's Pledge","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (2 Wounds)\nDescriptor: I am a good hunter, but now my venerable age \nkeeps me from hunting. I know the area around Rovaniemi \nvery well.\nAgenda: Defend the village of Rovaniemi from any possible \nthreat from the wilderness. \nInformation: Katri leads the hunters in the Village, and \nlately she has been told that the presence of animals has \ndecreased dramatically. There are several hunting lodges \nin the forest around the Village, where one \ncan find shelter. The area where Nikola Lupei’s mansion was built is full of ravines and \nnatural caves. \n5: Usko</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":2},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Defend the village of Rovaniemi from any possible \nthreat from the wilderness.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557640550,"modifiedTime":1781557640550,"lastModifiedBy":null,"exportSource":null}}
{"_id":"wwkTNF2FxgMuKbsp","name":"The Red Knight","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"l5IGhYIVRWT4niHB","name":"The Red Knight - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Red Knight","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am an immortal spirit in a knight’s armor, \nand with my skeletal steed I travel all over Avalon in search \nof the one who killed me.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","positive":"I am an immortal spirit in a knight’s armor, \nand with my skeletal steed I travel all over Avalon in search \nof the one who killed me.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Red Knight","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}},{"_id":"gFg0x5sMXo3FGSrR","name":"Gift - Eternal Vengeance","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Red Knight","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>When Percival the Seeker \nappears on the Scene, if he is present, the Red Knight will \nattack, ignoring all other risks. If Percival is not present, \nthe Red Knight will see the face of the hated opponent in \nthe most skilled subject in combat among those present, \nactivating this Gift as well. As long as the Red Knight has \nhis target in sight, no effect can block or prevent him from \nattacking. In the heat of vengeance, the Red Knight ignores \nall other enemies and reduces his OL against them to Easy \n3.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","somaCost":0,"automaticSuccesses":0,"owner":"The Red Knight","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}},{"_id":"8O3t0RK8ZReXerZ8","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Red Knight","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (4 Wounds)\nDescriptor: I am an immortal spirit in a knight’s armor, \nand with my skeletal steed I travel all over Avalon in search \nof the one who killed me.\nAgenda: Death has clouded my consciousness, and in every \nperson I meet I see my hated enemy, Percival. \nGift - Eternal Vengeance: When Percival the Seeker \nappears on the Scene, if he is present, the Red Knight will \nattack, ignoring all other risks. If Percival is not present, \nthe Red Knight will see the face of the hated opponent in \nthe most skilled subject in combat among those present, \nactivating this Gift as well. As long as the Red Knight has \nhis target in sight, no effect can block or prevent him from \nattacking. In the heat of vengeance, the Red Knight ignores \nall other enemies and reduces his OL against them to Easy \n3. \nInformation: The Red Knight is unable to communicate, \nand the only words he utters are vengeful epithets directed at Percival the Seeker. If the Hunters eliminate the Red \nKnight, he will not appear in Zone 12 - Cliff (page 197).</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 184.","owner":"The Red Knight","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-the-red-knight-184","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":184,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (4 Wounds)\nDescriptor: I am an immortal spirit in a knight’s armor, \nand with my skeletal steed I travel all over Avalon in search \nof the one who killed me.\nAgenda: Death has clouded my consciousness, and in every \nperson I meet I see my hated enemy, Percival. \nGift - Eternal Vengeance: When Percival the Seeker \nappears on the Scene, if he is present, the Red Knight will \nattack, ignoring all other risks. If Percival is not present, \nthe Red Knight will see the face of the hated opponent in \nthe most skilled subject in combat among those present, \nactivating this Gift as well. As long as the Red Knight has \nhis target in sight, no effect can block or prevent him from \nattacking. In the heat of vengeance, the Red Knight ignores \nall other enemies and reduces his OL against them to Easy \n3. \nInformation: The Red Knight is unable to communicate, \nand the only words he utters are vengeful epithets directed at Percival the Seeker. If the Hunters eliminate the Red \nKnight, he will not appear in Zone 12 - Cliff (page 197).</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":4},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":7,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Hard 7","impulse":"Death has clouded my consciousness, and in every \nperson I meet I see my hated enemy, Percival.","oppositionLevel":7}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643831,"modifiedTime":1781557643831,"lastModifiedBy":null,"exportSource":null}}
{"_id":"xLx3Qoav0DOMjvGg","name":"Murder of Crows","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"cRbNVzF0YI46VRJs","name":"Murder of Crows - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Murder of Crows","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>We are a great murder of crows and watch over \nour beloved human brothers Ravn and Kråke.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 211.","positive":"We are a great murder of crows and watch over \nour beloved human brothers Ravn and Kråke.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Murder of Crows","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645350,"modifiedTime":1781557645350,"lastModifiedBy":null,"exportSource":null}},{"_id":"ng3dEOT331SskCdw","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Murder of Crows","source":"A Frozen Reflection","category":"threat"}},"system":{"description":"<p>Descriptor: We are a great murder of crows and watch over \nour beloved human brothers Ravn and Kråke.\nGift - The Three Feathers: The Murder of Crows acts in \nthe service of Kråke and Ravn to protect them and treat them \nas if they were a Crow. Once per Exchange, both Kråke and \nRavn can enjoy one of the following effects:\n1. Coat of Feathers: The Murder shields a Black Feather, \nwhich increases their OL to Hard 7 against an attack.\n2. Flight of the Crow: The Murder lifts the Black Feather \noff the ground and allows it to run over their feathery bodies. \nThe Black Feather can move anywhere within a thirty-foot \nradius, and no one can block them. If they make an attack \nafter moving, the Black Feather increases their OL by 1.\n3. Feather Storm: The Murder encircles a target while it \nperforms an action that is not a physical attack. This effect \ncan be activated when an opponent acts, but it still counts \nagainst the limit of one effect per Exchange. The target must \npass a Defense Check or lose the action.\nEpilogue\nIt takes two days of sailing to get to the White Hospital.\nIf a Black Feather is captured, they will not agree to talk, but \nthe Hunters can use magic or other means to force them to \nreveal the following information:\n ◆ The mission of the Black Feathers is to take the wealthiest \npatients to Os, where the famous White Hospital is located, but even that is a cover-up by Gerda and Kay. The \nreal goal is to get the patients into the hands of a certain \nReinsdyr, who will then lead them through the forest to \nbe robbed by a group of bandits.\n ◆ The Black Feathers do not know how to get to the castle where Gerda and Kay live, but they have heard more \nthan once from the two fraudsters about witches who \nhelp them. \nStoryteller’s Note: The Hunters’ journey continues in \nPART TWO - Towards Lady Storm’s Castle. Keep track of the \nfate of the Black Feathers, for they will be recurring enemies \nin the next parts. \nScenario Events\nThere are 3 Events in this Scenario, though the Storyteller \nshould feel free to create new ones in response to the Hunter’s \nactions.\nIf the Hunters use violence to stop Aleksander: his \ndaughter will stand up for him, going so far as to beg the \nHunters to spare him. If the situation is not resolved, Fredrika will send the Hunters away with less information to end \nthe dinner quickly. \nIf the Hunters try to destroy Flora’s Greenhouse to \nforce her out: the old witch will use her magic to call for \nhelp, causing many townspeople to rush to her defense. \nIf  the  Hunters  inflict  at  least  one  Wound  on  both \nBlack Feathers or corner them: the two will attempt to \nescape by transforming into a rook and a raven and mingling \nwith the Murder.</p>","notes":"A Frozen Reflection - bt-ls-book-1-ENG-SCREEN.pdf, page 211.","owner":"Murder of Crows","source":"A Frozen Reflection","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645350,"modifiedTime":1781557645350,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-a-frozen-reflection-murder-of-crows-211","collection":"Lost Stories","adventureSlug":"a-frozen-reflection","adventureTitle":"A Frozen Reflection","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":211,"role":"Threat"}},"system":{"details":{"concept":"A Frozen Reflection","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: We are a great murder of crows and watch over \nour beloved human brothers Ravn and Kråke.\nGift - The Three Feathers: The Murder of Crows acts in \nthe service of Kråke and Ravn to protect them and treat them \nas if they were a Crow. Once per Exchange, both Kråke and \nRavn can enjoy one of the following effects:\n1. Coat of Feathers: The Murder shields a Black Feather, \nwhich increases their OL to Hard 7 against an attack.\n2. Flight of the Crow: The Murder lifts the Black Feather \noff the ground and allows it to run over their feathery bodies. \nThe Black Feather can move anywhere within a thirty-foot \nradius, and no one can block them. If they make an attack \nafter moving, the Black Feather increases their OL by 1.\n3. Feather Storm: The Murder encircles a target while it \nperforms an action that is not a physical attack. This effect \ncan be activated when an opponent acts, but it still counts \nagainst the limit of one effect per Exchange. The target must \npass a Defense Check or lose the action.\nEpilogue\nIt takes two days of sailing to get to the White Hospital.\nIf a Black Feather is captured, they will not agree to talk, but \nthe Hunters can use magic or other means to force them to \nreveal the following information:\n ◆ The mission of the Black Feathers is to take the wealthiest \npatients to Os, where the famous White Hospital is located, but even that is a cover-up by Gerda and Kay. The \nreal goal is to get the patients into the hands of a certain \nReinsdyr, who will then lead them through the forest to \nbe robbed by a group of bandits.\n ◆ The Black Feathers do not know how to get to the castle where Gerda and Kay live, but they have heard more \nthan once from the two fraudsters about witches who \nhelp them. \nStoryteller’s Note: The Hunters’ journey continues in \nPART TWO - Towards Lady Storm’s Castle. Keep track of the \nfate of the Black Feathers, for they will be recurring enemies \nin the next parts. \nScenario Events\nThere are 3 Events in this Scenario, though the Storyteller \nshould feel free to create new ones in response to the Hunter’s \nactions.\nIf the Hunters use violence to stop Aleksander: his \ndaughter will stand up for him, going so far as to beg the \nHunters to spare him. If the situation is not resolved, Fredrika will send the Hunters away with less information to end \nthe dinner quickly. \nIf the Hunters try to destroy Flora’s Greenhouse to \nforce her out: the old witch will use her magic to call for \nhelp, causing many townspeople to rush to her defense. \nIf  the  Hunters  inflict  at  least  one  Wound  on  both \nBlack Feathers or corner them: the two will attempt to \nescape by transforming into a rook and a raven and mingling \nwith the Murder.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557645350,"modifiedTime":1781557645350,"lastModifiedBy":null,"exportSource":null}}
{"_id":"y6AcALXGWGxXaCVN","name":"Mordred the Peaceless","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"ZE0pA1SMhmzGSgej","name":"Mordred the Peaceless - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Mordred the Peaceless","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am an undead knight in the service of the evil \nMerlin. I do whatever my master tells me to do, though I only \nwish to return to the grave from which I was torn. \nAgenda (if Merlin is present): Obey my master’s orders.\nAgenda (if Merlin is not present): Eliminate anyone \nwho approaches the waters of the lake, as ordered by my master / Be destroyed and return to death, receiving a farewell \nprayer.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 199.","positive":"I am an undead knight in the service of the evil \nMerlin. I do whatever my master tells me to do, though I only \nwish to return to the grave from which I was torn. \nAgenda (if Merlin is present): Obey my master’s orders.\nAgenda (if Merlin is not present): Eliminate anyone \nwho approaches the waters of the lake, as ordered by my master / Be destroyed and return to death, receiving a farewell \nprayer.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Mordred the Peaceless","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644521,"modifiedTime":1781557644521,"lastModifiedBy":null,"exportSource":null}},{"_id":"VTzTwwadu5zFlgXh","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Mordred the Peaceless","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Minor NPC (4 Wounds)\nDescriptor: I am an undead knight in the service of the evil \nMerlin. I do whatever my master tells me to do, though I only \nwish to return to the grave from which I was torn. \nAgenda (if Merlin is present): Obey my master’s orders.\nAgenda (if Merlin is not present): Eliminate anyone \nwho approaches the waters of the lake, as ordered by my master / Be destroyed and return to death, receiving a farewell \nprayer. \nInformation: Mordred can be persuaded to surrender in \nexchange for the promise of a burial that will bring peace \nto his soul. If peace is granted, Mordred will reveal Merlin’s \nplans for why he wants the Virtue of Wisdom and the Secret Landing.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 199.","owner":"Mordred the Peaceless","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644521,"modifiedTime":1781557644521,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-mordred-the-peaceless-199","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":199,"role":"Minor NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (4 Wounds)\nDescriptor: I am an undead knight in the service of the evil \nMerlin. I do whatever my master tells me to do, though I only \nwish to return to the grave from which I was torn. \nAgenda (if Merlin is present): Obey my master’s orders.\nAgenda (if Merlin is not present): Eliminate anyone \nwho approaches the waters of the lake, as ordered by my master / Be destroyed and return to death, receiving a farewell \nprayer. \nInformation: Mordred can be persuaded to surrender in \nexchange for the promise of a burial that will bring peace \nto his soul. If peace is granted, Mordred will reveal Merlin’s \nplans for why he wants the Virtue of Wisdom and the Secret Landing.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":4},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644521,"modifiedTime":1781557644521,"lastModifiedBy":null,"exportSource":null}}
{"_id":"yNbD7Z7ieBOlL4vf","name":"The Sacred Cup Among the Rocks","type":"threat","img":"icons/svg/cowled.svg","items":[{"_id":"66QzFi6jcW7smEw2","name":"The Sacred Cup Among the Rocks - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Sacred Cup Among the Rocks","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>A steep cliff overlooking the sea that hides the \ncup of the Holy Grail in its rocks. \nNote: Getting to the cup requires moving along the slippery, pointy rocks as the sea crashes relentlessly. Retrieving the embedded cup requires breaking the rock or finding a way to slide it out.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 198.","positive":"A steep cliff overlooking the sea that hides the \ncup of the Holy Grail in its rocks. \nNote: Getting to the cup requires moving along the slippery, pointy rocks as the sea crashes relentlessly. Retrieving the embedded cup requires breaking the rock or finding a way to slide it out.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"The Sacred Cup Among the Rocks","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644505,"modifiedTime":1781557644505,"lastModifiedBy":null,"exportSource":null}},{"_id":"LrvPJ1SCtFYb0HGM","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"The Sacred Cup Among the Rocks","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Descriptor: A steep cliff overlooking the sea that hides the \ncup of the Holy Grail in its rocks. \nNote: Getting to the cup requires moving along the slippery, pointy rocks as the sea crashes relentlessly. Retrieving the embedded cup requires breaking the rock or finding a way to slide it out.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 198.","owner":"The Sacred Cup Among the Rocks","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644505,"modifiedTime":1781557644505,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-the-sacred-cup-among-the-rocks-198","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":198,"role":"Threat"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Threat","notes":"<p>Descriptor: A steep cliff overlooking the sea that hides the \ncup of the Holy Grail in its rocks. \nNote: Getting to the cup requires moving along the slippery, pointy rocks as the sea crashes relentlessly. Retrieving the embedded cup requires breaking the rock or finding a way to slide it out.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644505,"modifiedTime":1781557644505,"lastModifiedBy":null,"exportSource":null}}
{"_id":"zb47g8daygvAoOYo","name":"Djinn of the Dream Gate","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"8HHgHO6oubrdWQSZ","name":"Djinn of the Dream Gate - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am a powerful Djinn, my body is pure magic \nand my strength transcends that of wretched humans. I pay \nrespect to those who show purity of spirit and courage.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 167.","positive":"I am a powerful Djinn, my body is pure magic \nand my strength transcends that of wretched humans. I pay \nrespect to those who show purity of spirit and courage.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642827,"modifiedTime":1781557642827,"lastModifiedBy":null,"exportSource":null}},{"_id":"xnNDKYb2d5s03vkq","name":"Gift - Duty","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>Each Djinn is immune to any effect of mind \ncontrol, deception, or magic that would influence them to \nrelinquish their duty.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 167.","somaCost":0,"automaticSuccesses":0,"owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642827,"modifiedTime":1781557642827,"lastModifiedBy":null,"exportSource":null}},{"_id":"KVYdcTM7pSYjBkZP","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Main NPC \n(3 Wounds - the Guardian and the Servant) \n(1 Wound - All other Djinn) \n(1 Djinn for each undelivered Tarì)\nDescriptor: I am a powerful Djinn, my body is pure magic \nand my strength transcends that of wretched humans. I pay \nrespect to those who show purity of spirit and courage. \nGift - Duty: Each Djinn is immune to any effect of mind \ncontrol, deception, or magic that would influence them to \nrelinquish their duty.\nGift - Power of the Djinn: Each Djinn has a different \npower:\nFirst - The Guardian: If the Djinn receives 1 Wound, \nroll a die; on a roll of 5 or 6, the person who inflicted the \nWound receives 1 in turn. \nSecond - The Warrior: Once per Scene, even if a Defense Check to avoid a Djinn attack succeeds, the target still \nsuffers 1 Wound.\nThird - The Mage: If an enemy uses a magic-related Gift \nin the presence of the Djinn, they must spend 1 Soma or see \ntheir spell dissolve without effect.\nFourth - The Servant: If a Djinn takes 1 Wound, it can \ntransfer it to the Servant who takes it instead.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 167.","owner":"Djinn of the Dream Gate","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642827,"modifiedTime":1781557642827,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-djinn-of-the-dream-gate-167","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":167,"role":"Main NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC \n(3 Wounds - the Guardian and the Servant) \n(1 Wound - All other Djinn) \n(1 Djinn for each undelivered Tarì)\nDescriptor: I am a powerful Djinn, my body is pure magic \nand my strength transcends that of wretched humans. I pay \nrespect to those who show purity of spirit and courage. \nGift - Duty: Each Djinn is immune to any effect of mind \ncontrol, deception, or magic that would influence them to \nrelinquish their duty.\nGift - Power of the Djinn: Each Djinn has a different \npower:\nFirst - The Guardian: If the Djinn receives 1 Wound, \nroll a die; on a roll of 5 or 6, the person who inflicted the \nWound receives 1 in turn. \nSecond - The Warrior: Once per Scene, even if a Defense Check to avoid a Djinn attack succeeds, the target still \nsuffers 1 Wound.\nThird - The Mage: If an enemy uses a magic-related Gift \nin the presence of the Djinn, they must spend 1 Soma or see \ntheir spell dissolve without effect.\nFourth - The Servant: If a Djinn takes 1 Wound, it can \ntransfer it to the Servant who takes it instead.</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642827,"modifiedTime":1781557642827,"lastModifiedBy":null,"exportSource":null}}
{"_id":"zbiXkgU65H5k2dlS","name":"Jasmina the Brave","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"PhGOs1F3SbGgLTOj","name":"Jasmina the Brave - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Jasmina the Brave","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>I am the true ruler of the island and would \ngive my life for my people. I am charismatic and skilled with \na scimitar.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","positive":"I am the true ruler of the island and would \ngive my life for my people. I am charismatic and skilled with \na scimitar.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Jasmina the Brave","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}},{"_id":"p37vRmvbwMgP7fUs","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Jasmina the Brave","source":"Journey of a Thousand and One Nights","category":"threat"}},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: I am the true ruler of the island and would \ngive my life for my people. I am charismatic and skilled with \na scimitar. \nAgenda: Defeat Aladdin and restore the island’s fortunes. \nMonsters Summoned by Aladdin</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 160.","owner":"Jasmina the Brave","source":"Journey of a Thousand and One Nights","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-jasmina-the-brave-160","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":160,"role":"Minor NPC"}},"system":{"details":{"concept":"Journey of a Thousand and One Nights","origin":"Lost Stories","role":"Minor NPC","notes":"<p>- Minor NPC (1 Wound)\nDescriptor: I am the true ruler of the island and would \ngive my life for my people. I am charismatic and skilled with \na scimitar. \nAgenda: Defeat Aladdin and restore the island’s fortunes. \nMonsters Summoned by Aladdin</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":1},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Defeat Aladdin and restore the island’s fortunes. \nMonsters Summoned by Aladdin","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642505,"modifiedTime":1781557642505,"lastModifiedBy":null,"exportSource":null}}
{"_id":"zz0bzgwmQMIPNTHb","name":"Percival the Seeker","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"SEcJ8wBRqBlfOofZ","name":"Percival the Seeker - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>I am a disgraced knight. My body is immortal, \nbut my mind has lost bits of memory over the centuries.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 187.","positive":"I am a disgraced knight. My body is immortal, \nbut my mind has lost bits of memory over the centuries.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false,"owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644040,"modifiedTime":1781557644040,"lastModifiedBy":null,"exportSource":null}},{"_id":"0585e3LaedRvTTXO","name":"Gift - Virtue of Faith","type":"gift","img":"icons/svg/aura.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>Imbued with the power of the Virtue of Faith, Percival cannot be killed. When he reaches 0 \nWounds, he will fall into a state of apparent death and will \nawake at the end of the Scene fully healed. Percival’s Virtue \ncannot be granted because it is inside the Grail chalice that \nthe Knight remembers throwing between the rocks and \nshoals in Zone 12 - Cliff (page 197).</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 187.","somaCost":0,"automaticSuccesses":0,"owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644041,"modifiedTime":1781557644041,"lastModifiedBy":null,"exportSource":null}},{"_id":"QSmt1q1vtZzMovEs","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"}},"system":{"description":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a disgraced knight. My body is immortal, \nbut my mind has lost bits of memory over the centuries. \nAgenda: Remember why I am on this strange island. \nGift - Virtue of Faith: Imbued with the power of the Virtue of Faith, Percival cannot be killed. When he reaches 0 \nWounds, he will fall into a state of apparent death and will \nawake at the end of the Scene fully healed. Percival’s Virtue \ncannot be granted because it is inside the Grail chalice that \nthe Knight remembers throwing between the rocks and \nshoals in Zone 12 - Cliff (page 197).\nInformation: Percival only remembers things when he \nis in his little house on the Cliff: he cycles back to Camelot, \nbut on the way he loses his memory and remembers only \nthe place he left from. Upon his return, Percival remembers \nhis mission and the cycle begins again.\n \nThe Map of Camelot\nZone 1 - Landing Zone 2 - Beach Zone 3 - Glatisant's \nLair \nZone 4 - Village of \nCorrinton\nZone 5 -Merlin’s \nTower\nZone 6 - Forest Zone 7 - Battlefield Zone 8 - Camelot \nCastle Zone 9 - Fairy Falls Zone 10 - Circle of \nStones\nZone 11 - Town of \nStow Zone 12 - Cliff Zone 13 - Lake Zone 14 - Abandoned House\nZone 15 - Secret \nLanding</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 187.","owner":"Percival the Seeker","source":"The King's Awakening","category":"threat"},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644041,"modifiedTime":1781557644041,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-percival-the-seeker-187","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"The King's Awakening","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":187,"role":"Main NPC"}},"system":{"details":{"concept":"The King's Awakening","origin":"Lost Stories","role":"Main NPC","notes":"<p>- Main NPC (3 Wounds)\nDescriptor: I am a disgraced knight. My body is immortal, \nbut my mind has lost bits of memory over the centuries. \nAgenda: Remember why I am on this strange island. \nGift - Virtue of Faith: Imbued with the power of the Virtue of Faith, Percival cannot be killed. When he reaches 0 \nWounds, he will fall into a state of apparent death and will \nawake at the end of the Scene fully healed. Percival’s Virtue \ncannot be granted because it is inside the Grail chalice that \nthe Knight remembers throwing between the rocks and \nshoals in Zone 12 - Cliff (page 197).\nInformation: Percival only remembers things when he \nis in his little house on the Cliff: he cycles back to Camelot, \nbut on the way he loses his memory and remembers only \nthe place he left from. Upon his return, Percival remembers \nhis mission and the cycle begins again.\n \nThe Map of Camelot\nZone 1 - Landing Zone 2 - Beach Zone 3 - Glatisant's \nLair \nZone 4 - Village of \nCorrinton\nZone 5 -Merlin’s \nTower\nZone 6 - Forest Zone 7 - Battlefield Zone 8 - Camelot \nCastle Zone 9 - Fairy Falls Zone 10 - Circle of \nStones\nZone 11 - Town of \nStow Zone 12 - Cliff Zone 13 - Lake Zone 14 - Abandoned House\nZone 15 - Secret \nLanding</p>"},"resources":{"soma":{"value":0,"max":0},"xp":0,"wounds":{"value":0,"max":3},"darkness":{"value":0,"max":6}},"opposition":{"defaultLevel":5,"modifier":0},"bookmark":{"wound1":"","wound2":"","wound3":"","extraWound":""},"threat":{"rank":"Medium 5","impulse":"Remember why I am on this strange island.","oppositionLevel":5}},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557644041,"modifiedTime":1781557644041,"lastModifiedBy":null,"exportSource":null}}

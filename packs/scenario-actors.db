{"_id":"KxJhc6UYj8AaI8CM","name":"The Monkeys","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"a7TQ6UWHDNS6te86","name":"The Monkeys - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{},"system":{"description":"<p>We are agile and fast, and we move quickly \nthrough the trees to escape threats.</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 155.","positive":"We are agile and fast, and we move quickly \nthrough the trees to escape threats.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}},{"_id":"9Sjd1Q8qX1EWs86O","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are agile and fast, and we move quickly \nthrough the trees to escape threats. \nAgenda: Satisfy the Giant’s hunger to prevent it from devouring us. \nThe Elephant-Eared Giant</p>","notes":"Journey of a Thousand and One Nights - bt-ls-book-1-ENG-SCREEN.pdf, page 155."},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557642301,"modifiedTime":1781557642301,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-journey-of-a-thousand-and-one-nights-the-monkeys-155","collection":"Lost Stories","adventureSlug":"journey-of-a-thousand-and-one-nights","adventureTitle":"Journey of a Thousand and One Nights","sourceFile":"bt-ls-book-1-ENG-SCREEN.pdf","page":155,"role":"Minor NPC"}},"
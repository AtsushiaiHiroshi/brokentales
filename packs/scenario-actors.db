{"_id":"Kstu4ZK2G8hXefaK","name":"Villagers","type":"threat","img":"icons/svg/mystery-man.svg","items":[{"_id":"GCU9MhHp321WVbBR","name":"Villagers - Descriptor","type":"descriptor","img":"icons/svg/book.svg","effects":[],"folder":null,"flags":{},"system":{"description":"<p>We are poor villagers who sell vegetables and \nlivestock.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 182.","positive":"We are poor villagers who sell vegetables and \nlivestock.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643740,"modifiedTime":1781557643740,"lastModifiedBy":null,"exportSource":null}},{"_id":"Kk4eUTyTVXnB6EpS","name":"Source Text","type":"storyElement","img":"icons/svg/scroll.svg","effects":[],"folder":null,"flags":{},"system":{"description":"<p>- Minor NPC (1 Wound)\nDescriptor: We are poor villagers who sell vegetables and \nlivestock.\nAgenda: Travel between island settlements to conduct business.\nInformation: Upon encountering them, the Storyteller \nrolls 1 die to determine which settlement the Villagers are \nfrom. The table below lists the information they can give \nthe Hunters, and in parentheses, who can give the information because they are from a particular settlement.</p>","notes":"The King's Awakening - bt-ls-book-1-ENG-SCREEN.pdf, page 182."},"sort":0,"ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"coreVersion":"13.351","systemId":"broken-tales","systemVersion":"0.2.0","createdTime":1781557643740,"modifiedTime":1781557643740,"lastModifiedBy":null,"exportSource":null}}],"effects":[],"folder":null,"flags":{"broken-tales":{"scenarioActorSlug":"lost-stories-the-kings-awakening-villagers-182","collection":"Lost Stories","adventureSlug":"the-kings-awakening","adventureTitle":"T
    {
        "_id": "Wolf-killer",
        "name": "Wolf-killer",
        "type": "scenario_gift",
        "data": {
            "requirement": "Having faced the wolves in a fight at least once.",
            "effect": "You know how to deal with the fiercest of wolves and are careful not to be surrounded. When you obtain at least a Standard Outcome on a Position or Defense Check against a pack of beasts, you can immediately eliminate 1 Minor animal NPC with 1 Wound."

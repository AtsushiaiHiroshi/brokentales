{"_id":"013cjy7ee7yjc310","name":"Medoro - The Old Bear - Descriptor","type":"descriptor","img":"systems/broken-tales/assets/icons/descriptor-improvement.webp","effects":[],"folder":null,"flags":{"broken-tales":{"owner":"Medoro - The Old Bear","ownerKey":"medoro-the-old-bear","itemKey":"descriptor-principal.amenaza","sourcePack":"broken-tales.scenario-actors","translations":{"es":{"name":"Medoro - The Old Bear - Descriptor","system":{"description":"<p>I am a deformed old bear that has lost all its fur. Azzurra treats me like her faithful dog and I serve her happily. I have retained most of my animal strength, despite the scars and the passing of time.</p>","positive":"I am a deformed old bear that has lost all its fur. Azzurra treats me like her faithful dog and I serve her happily. I have retained most of my animal strength, despite the scars and the passing of time."}}},"sourceActor":"Medoro - The Old Bear"}},"system":{"description":"<p>I am a deformed old bear that has lost all its fur. Azzurra treats me like her faithful dog and I serve her happily. I have retained most of my animal strength, despite the scars and the passing of time.</p>","notes":"Creatures.db (legacy structured backup)","key":"descriptor-principal.amenaza","owner":"Medoro - The Old Bear","category":"Threat Descriptor","source":"Creatures.db (legacy structured backup)","positive":"I am a deformed old bear that has lost all its fur. Azzurra treats me like her faithful dog and I serve her happily. I have retained most of my animal strength, despite the scars and the passing of time.","negative":"","exhausted":false,"xpMarked":false,"specialization":false,"sceneUsed":false}}
